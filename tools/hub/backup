        f'.local/lib/{PY_VER}/site-packages/interpreter/core/utils/truncate_output.py',
        f'.local/lib/{PY_VER}/site-packages/interpreter/terminal_interface/magic_commands.py',
        f'.local/lib/{PY_VER}/site-packages/interpreter/core/computer/terminal/languages/subprocess_language.py',
        f'.local/lib/{PY_VER}/site-packages/interpreter/terminal_interface/components/code_block.py',
        f'.local/lib/{PY_VER}/site-packages/interpreter/core/respond.py',
    ]),
