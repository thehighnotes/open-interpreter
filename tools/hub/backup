#!/usr/bin/env python3
"""backup — Back up the hub ecosystem to the configured backup target.

Rsyncs all critical files (hub tools, configs, OI patches, display setup,
XFCE customizations) to the backup destination. Also prints sudo commands
for system-level files that can't be backed up directly.

Usage:
    backup              Run full backup to AGX
    backup --dry-run    Show what would be transferred
    backup --list       List all backed-up file categories
    backup --help
"""

import os
import subprocess
import sys
import time
from datetime import datetime
from pathlib import Path

sys.path.insert(0, str(Path.home()))
from hub_common import *

# BACKUP_DEST is imported from hub_common (config-derived)
HOME = str(Path.home())
PY_VER = f'python{sys.version_info.major}.{sys.version_info.minor}'
LOCAL_USER = HOSTS.get(LOCAL_HOST, {}).get('user', os.environ.get('USER', 'user'))

# ─────────────────────────────────────────────────────────────────────────────
# File manifest — everything worth backing up
# ─────────────────────────────────────────────────────────────────────────────

