def probe_nano_health():
    """Get local Nano health info."""
    info = {}
    try:
        result = subprocess.run(['free', '-m'], capture_output=True, text=True, timeout=5)
        if result.returncode == 0:
            for line in result.stdout.split('\n'):
                if 'Mem:' in line:
                    parts = line.split()
                    info['ram_used'] = parts[2]
                    info['ram_total'] = parts[1]
    except Exception:
        pass
    try:
        result = subprocess.run(['uptime', '-p'], capture_output=True, text=True, timeout=5)
        if result.returncode == 0:
            info['uptime'] = result.stdout.strip()
    except Exception:
        pass
    return info


def probe_remote_host(host_key, reachable):
    """Get remote host info (uptime, RAM, optionally Ollama). Returns dict."""
    if not reachable:
        return {'online': False}
    info = {'online': True}

    # Build SSH probe command — include LLM check if this is the LLM host
    cmd = 'echo "===UPTIME===" && uptime -p 2>/dev/null && echo "===MEM===" && free -m 2>/dev/null | grep Mem'
    if host_key == LLM_HOST:
        if LLM_BACKEND == 'vllm':
            cmd += f' && echo "===LLM===" && curl -s http://localhost:{LLM_PORT}/v1/models 2>/dev/null'
        else:
            cmd += f' && echo "===LLM===" && curl -s http://localhost:{OLLAMA_PORT}/api/ps 2>/dev/null'

    ok, output = ssh_cmd(host_key, cmd, timeout=10)
    if ok and output:
        sections = output.split('===')
        for i in range(1, len(sections), 2):
            key = sections[i].strip()
            val = sections[i + 1].strip() if i + 1 < len(sections) else ''
            if key == 'UPTIME':
                info['uptime'] = val
            elif key == 'MEM':
                parts = val.split()
                if len(parts) >= 3:
                    info['ram_used'] = parts[2]
                    info['ram_total'] = parts[1]
            elif key == 'LLM':
                try:
                    import json
                    data = json.loads(val)
                    if LLM_BACKEND == 'vllm':
                        models = [m.get('id', '?') for m in data.get('data', [])]
                        info['llm'] = ', '.join(models) if models else 'loading'
                    else:
                        models = data.get('models', [])
                        if models:
                            info['llm'] = ', '.join(m.get('name', '?') for m in models)
                        else:
                            info['llm'] = 'idle'
                except Exception:
                    info['llm'] = 'running'
    return info


def get_autosummary_status():
    """Check if autosummary is running. Returns (running, pid)."""
    pid_file = OVERVIEW_CACHE_DIR / 'autosummary.pid'
    if not pid_file.exists():
        return False, None
    try:
        pid = int(pid_file.read_text().strip())
        os.kill(pid, 0)
        return True, pid
    except (ValueError, OSError):
        return False, None


def get_research_last_fetch():
    """Get last research fetch time. Returns (age_str, age_seconds).

    age_str is like '5m ago', '3h ago', or 'never'. age_seconds is float or None.
    """
    import json
    state_file = RESEARCH_CACHE_DIR / 'state.json'
    if not state_file.exists():
        return 'never', None
    try:
        state = json.loads(state_file.read_text())
        last = state.get('arxiv_last_fetch')
        if not last:
            return 'never', None
        # Parse ISO timestamp
        try:
            dt = datetime.strptime(last, '%Y-%m-%dT%H:%M:%S')
            age = (datetime.utcnow() - dt).total_seconds()
            if age < 3600:
                return f"{int(age / 60)}m ago", age
            elif age < 86400:
                return f"{int(age / 3600)}h ago", age
            else:
                return f"{int(age / 86400)}d ago", age
        except ValueError:
            return last, None
    except (Exception):
        return 'error', None


def get_cache_ages():
    """Get overview cache ages for all projects. Returns ({key: age_str}, {key: age_seconds})."""
    ages = {}
    ages_s = {}
    for pk in PROJECT_ORDER:
        cache_file = OVERVIEW_CACHE_DIR / f"{pk}.json"
        if cache_file.exists():
            try:
                age = time.time() - cache_file.stat().st_mtime
                ages_s[pk] = age
                if age < 3600:
                    ages[pk] = f"{int(age / 60)}m"
                elif age < 86400:
                    ages[pk] = f"{int(age / 3600)}h"
                else:
                    ages[pk] = f"{int(age / 86400)}d"
            except OSError:
                ages[pk] = '?'
                ages_s[pk] = None
        else:
            ages[pk] = '--'
            ages_s[pk] = None
    return ages, ages_s


