def render_status():
    """Fast compact dashboard."""
    now = datetime.now().strftime('%a %d %b %H:%M')
    state = gather_state()

    host_info = state['host_info']
    as_running = state['as_running']
    as_pid = state['as_pid']
    research_last = state['research_last']
    cache_ages = state['cache_ages']
    host_reachable = state['host_reachable']
    ca_up = state['ca_up']
    ca_projects = state['ca_projects']
    ca_watcher_status = state['ca_watcher']
    git_all = state['git_all']

    unread = get_unread_count()

    print()
    header_bar()
    unread_label = f"  {YELLOW}{unread} unread{RESET}" if unread else ""
    print_right(f"{BRIGHT_GREEN}  HUB STATUS{RESET}{unread_label}", f"{BRIGHT_GREEN}{now}{RESET}")
    header_bar()

    # HOSTS
    print(f"  {WHITE}HOSTS{RESET}")
    divider()

    # Local host
    local = host_info.get(LOCAL_HOST, {})
    local_name = HOSTS.get(LOCAL_HOST, {}).get('name', LOCAL_HOST)
    local_parts = []
    if local.get('uptime'):
        local_parts.append(local['uptime'])
    if local.get('ram_used'):
        local_parts.append(f"{local['ram_used']}M/{local['ram_total']}M RAM")
    print(f"  {GREEN}●{RESET} {WHITE}{local_name:<8}{RESET} hub     | {' | '.join(local_parts) if local_parts else 'local'}")

    # Remote hosts (dynamic)
    for hkey in HOSTS:
        if hkey == LOCAL_HOST:
            continue
        h = host_info.get(hkey, {})
        hname = HOSTS[hkey]['name']
        is_wakeable = 'wakeable' in HOSTS[hkey].get('roles', [])
        if h.get('online'):
            parts = []
            if h.get('uptime'):
                parts.append(h['uptime'])
            if h.get('ram_used'):
                parts.append(f"{h['ram_used']}M/{h['ram_total']}M RAM")
            if h.get('llm'):
                parts.append(f"LLM: {h['llm']}")
            print(f"  {GREEN}●{RESET} {WHITE}{hname:<8}{RESET} | {' | '.join(parts)}")
        elif is_wakeable:
            print(f"  {YELLOW}●{RESET} {WHITE}{hname:<8}{RESET} | {YELLOW}SUSPENDED{RESET} — run {WHITE}prepare <project>{RESET}")
        else:
            print(f"  {RED}●{RESET} {WHITE}{hname:<8}{RESET} | {RED}OFFLINE{RESET}")

    # Host hints
    hints = generate_hints(state)
    for h in hints.get('hosts', []):
        print(f"  {DIM}  → {h}{RESET}")

    print()

    # BACKGROUND
    print(f"  {WHITE}BACKGROUND{RESET}")
    divider()
    if as_running:
        print(f"  {GREEN}●{RESET} autosummary   running (PID {as_pid})")
    else:
        print(f"  {GRAY}●{RESET} autosummary   {GRAY}not running{RESET}")
    print(f"  {GREEN}●{RESET} research      last fetch: {research_last}")

    # Code Assistant
    if ca_up:
        if ca_projects and 'projects' in ca_projects:
            ca_list = ca_projects['projects']
            total_files = sum(p.get('code_count', 0) + p.get('doc_count', 0) for p in ca_list)
            proj_parts = []
            for p in ca_list:
                n = p.get('code_count', 0) + p.get('doc_count', 0)
                proj_parts.append(f"{p['name']}:{n}")
            watcher_label = ''
            if ca_watcher_status:
                if ca_watcher_status.get('running'):
                    watcher_label = f"  {GREEN}w{RESET}"
                else:
                    watcher_label = f"  {GRAY}w{RESET}"
            print(f"  {GREEN}●{RESET} code assist    {_CA_LABEL}  {GRAY}{' · '.join(proj_parts)}  ({total_files} files){RESET}{watcher_label}")
        else:
            print(f"  {GREEN}●{RESET} code assist    {_CA_LABEL} ({len(CODE_ASSISTANT_PROJECTS)} projects)")
    else:
        print(f"  {GRAY}●{RESET} code assist    {GRAY}offline{RESET}")

    # Dev services summary
    all_dev_enabled = []
    for pk in PROJECT_ORDER:
        for ds in PROJECTS[pk].get('dev_services', []):
            if ds.get('enabled'):
                all_dev_enabled.append((pk, ds))
    if all_dev_enabled:
        dev_labels = []
        for pk, ds in all_dev_enabled:
            dev_labels.append(f"{pk}:{ds['port']}")
        print(f"  {YELLOW}●{RESET} dev services   {GRAY}{' · '.join(dev_labels)}{RESET}     {GRAY}hub --dev{RESET}")

    # GIT summary
    n_repos = sum(1 for s in git_all.values() if s.get('is_git'))
    n_dirty = sum(1 for s in git_all.values() if s.get('is_git') and (s.get('dirty', 0) + s.get('untracked', 0)) > 0)
    n_ahead = sum(1 for s in git_all.values() if s.get('is_git') and isinstance(s.get('ahead'), int) and s['ahead'] > 0)
    git_parts = [f"{n_repos}/{len(PROJECT_ORDER)} repos"]
    if n_dirty:
        git_parts.append(f"{YELLOW}{n_dirty} dirty{RESET}")
    if n_ahead:
        git_parts.append(f"{CYAN}{n_ahead} ahead{RESET}")
    print(f"  {GREEN}●{RESET} git            {'  '.join(git_parts)}     {GRAY}repo{RESET}")

    # Background + Git hints
    for h in hints.get('background', []):
        print(f"  {DIM}  → {h}{RESET}")
    for h in hints.get('git', []):
        print(f"  {DIM}  → {h}{RESET}")

    print()

    # CACHES
    print(f"  {WHITE}CACHES{RESET}")
    divider()
    # Render in pairs
    items = list(cache_ages.items())
    line = '  '
    for i, (pk, age) in enumerate(items):
        age_color = GREEN if age not in ('--', '?') and not age.endswith('d') else YELLOW if age.endswith('d') else GRAY
        line += f"{pk:<12s} {age_color}{age:>4s}{RESET}   "
        if (i + 1) % 3 == 0 or i == len(items) - 1:
            print(line)
            line = '  '

    # Cache hints
    for h in hints.get('caches', []):
        print(f"  {DIM}  → {h}{RESET}")

    header_bar()


