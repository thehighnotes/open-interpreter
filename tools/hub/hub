def generate_next_items(state):
    """Scan all state and return prioritized action items.

    Returns list of {priority, icon, desc, command, project} dicts, sorted by priority.
    """
    host_reachable = state['host_reachable']
    git_all = state['git_all']
    cache_ages = state['cache_ages']
    cache_age_s = state['cache_age_s']
    deploy_states = state['deploy_states']
    items = []

    # P1 — Data loss risk
    for pk in PROJECT_ORDER:
        s = git_all.get(pk)
        if not s or not s.get('is_git'):
            continue
        dirty = s.get('dirty', 0) + s.get('untracked', 0)
        if dirty > 0 and not s.get('remote_url'):
            items.append({
                'priority': 1, 'icon': f'{RED}!{RESET}',
                'desc': f"{PROJECTS[pk]['name']}: {dirty} changes with no remote backup",
                'command': f'repo create {pk}', 'project': pk,
            })
        elif dirty > 0:
            items.append({
                'priority': 1, 'icon': f'{RED}!{RESET}',
                'desc': f"{PROJECTS[pk]['name']}: {dirty} uncommitted changes",
                'command': f'repo commit {pk} "msg"', 'project': pk,
            })
        elif isinstance(s.get('ahead'), int) and s['ahead'] > 0:
            items.append({
                'priority': 1, 'icon': f'{RED}!{RESET}',
                'desc': f"{PROJECTS[pk]['name']}: {s['ahead']} unpushed commits",
                'command': f'repo push {pk}', 'project': pk,
            })

    # P2 — Production out of sync
    for pk in PROJECT_ORDER:
        ds = deploy_states.get(pk)
        s = git_all.get(pk)
        proj = PROJECTS[pk]
        if ds and s and s.get('head') and ds.get('head') != s['head'] and proj.get('services'):
            items.append({
                'priority': 2, 'icon': f'{YELLOW}!{RESET}',
                'desc': f"{proj['name']}: deploy stale, services running old code",
                'command': f'repo deploy {pk}', 'project': pk,
            })

    # P3 — Degraded functionality (dynamic host checks)
    for hkey in HOSTS:
        if hkey == LOCAL_HOST:
            continue
        if not host_reachable.get(hkey):
            hname = HOSTS[hkey]['name']
            host_projects = sum(1 for pk in PROJECT_ORDER if PROJECTS[pk]['host'] == hkey)
            if host_projects:
                items.append({
                    'priority': 3, 'icon': f'{YELLOW}●{RESET}',
                    'desc': f"{hname} offline — {host_projects} project(s) unavailable",
                    'command': '', 'project': None,
                })
    if not state['as_running']:
        items.append({
            'priority': 3, 'icon': f'{YELLOW}●{RESET}',
            'desc': "autosummary not running — sessions won't auto-cache",
            'command': 'autosummary (in tmux)', 'project': None,
        })
    ca_host_n = HUB_CONFIG['code_assistant']['host']
    ca_reachable_n = host_reachable.get(ca_host_n, True) if ca_host_n != LOCAL_HOST else True
    if not state['ca_up'] and ca_reachable_n:
        items.append({
            'priority': 3, 'icon': f'{YELLOW}●{RESET}',
            'desc': 'Code Assistant offline — code search unavailable',
            'command': '', 'project': None,
        })

    # P4 — Stale context
    for pk in PROJECT_ORDER:
        age_s = cache_age_s.get(pk)
        if age_s is not None and age_s > 259200:
            items.append({
                'priority': 4, 'icon': f'{GRAY}●{RESET}',
                'desc': f"{PROJECTS[pk]['name']}: overview cache {cache_ages[pk]} old",
                'command': f'overview {pk} --refresh', 'project': pk,
            })
        elif cache_ages.get(pk) == '--':
            items.append({
                'priority': 4, 'icon': f'{GRAY}●{RESET}',
                'desc': f"{PROJECTS[pk]['name']}: no overview cache",
                'command': f'overview {pk}', 'project': pk,
            })
    research_age_s = state.get('research_age_s')
    if research_age_s is None or research_age_s > 86400:
        items.append({
            'priority': 4, 'icon': f'{GRAY}●{RESET}',
            'desc': f"Research data {state['research_last']}",
            'command': 'research --fetch', 'project': None,
        })
    backup_age_s = state.get('backup_age_s')
    backup_age = state.get('backup_age', 'unknown')
    if backup_age_s is not None and backup_age_s > 604800:
        items.append({
            'priority': 4, 'icon': f'{GRAY}●{RESET}',
            'desc': f"No recent backup ({backup_age})",
            'command': 'backup', 'project': None,
        })
    elif backup_age == 'never':
        items.append({
            'priority': 4, 'icon': f'{GRAY}●{RESET}',
            'desc': 'No recent backup (never)',
            'command': 'backup', 'project': None,
        })

    # P5 — Maintenance
    for pk in PROJECT_ORDER:
        s = git_all.get(pk)
        if not s:
            continue
        if s.get('has_pat'):
            items.append({
                'priority': 5, 'icon': f'{GRAY}·{RESET}',
                'desc': f"{PROJECTS[pk]['name']}: PAT token in git remote",
                'command': f'repo fix {pk}', 'project': pk,
            })
        if s.get('is_git') and not s.get('remote_url') and s.get('commits', 0) > 0:
            # Only if not already in P1 (dirty + no remote)
            dirty = s.get('dirty', 0) + s.get('untracked', 0)
            if dirty == 0:
                items.append({
                    'priority': 5, 'icon': f'{GRAY}·{RESET}',
                    'desc': f"{PROJECTS[pk]['name']}: no remote configured",
                    'command': f'repo create {pk}', 'project': pk,
                })
    if state['ca_up'] and state['ca_watcher'] and not state['ca_watcher'].get('running'):
        items.append({
            'priority': 5, 'icon': f'{GRAY}·{RESET}',
            'desc': 'Code Assistant file watcher stopped',
            'command': 'code manage', 'project': None,
        })

    # Sort by priority, then PROJECT_ORDER for same-priority items
    order_map = {pk: i for i, pk in enumerate(PROJECT_ORDER)}
    items.sort(key=lambda x: (x['priority'], order_map.get(x.get('project'), 999)))

    return items


