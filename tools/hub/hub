def render_dev(args=None):
    """Show, enable, or disable npm dev services.

    hub --dev               Show all dev services with enabled status
    hub --dev enable <pk>   Enable all dev services for a project (or specific by name)
    hub --dev disable <pk>  Disable all dev services for a project (or specific by name)
    """
    # Collect all dev services
    all_devs = []
    for pk in PROJECT_ORDER:
        proj = PROJECTS[pk]
        for ds in proj.get('dev_services', []):
            all_devs.append((pk, proj, ds))

    if not all_devs and not args:
        print(f"\n  {GRAY}No dev services configured{RESET}")
        print(f"  {DIM}Run {WHITE}hub --scan <host>{RESET}{DIM} to discover npm dev services{RESET}\n")
        return

    # Parse sub-action
    action = args[0].lower() if args else None

    if action in ('enable', 'disable'):
        if len(args) < 2:
            print(f"\n  Usage: hub --dev {action} <project> [service-name]\n")
            return

        target_pk = resolve_project(args[1])
        if not target_pk:
            print(f"\n  {RED}Unknown project: {args[1]}{RESET}\n")
            return

        proj = PROJECTS[target_pk]
        dev_svcs = proj.get('dev_services', [])
        if not dev_svcs:
            print(f"\n  {GRAY}No dev services for {target_pk}{RESET}\n")
            return

        # Optional: filter by service name
        target_name = ' '.join(args[2:]).strip() if len(args) > 2 else None
        new_state = action == 'enable'
        toggled = 0

        projects_dict = dict(PROJECTS)
        for ds in projects_dict[target_pk].get('dev_services', []):
            if target_name and target_name.lower() not in ds['name'].lower():
                continue
            if ds.get('enabled') != new_state:
                ds['enabled'] = new_state
                toggled += 1

        if toggled == 0:
            state_word = 'enabled' if new_state else 'disabled'
            print(f"\n  {GRAY}Already {state_word} (or no match){RESET}\n")
            return

        save_projects(projects_dict, PROJECT_ORDER, IGNORED)
        reload_projects()

        state_word = 'enabled' if new_state else 'disabled'
        icon = GREEN if new_state else YELLOW
        print(f"\n  {icon}✓{RESET} {state_word.title()} {toggled} dev service(s) for {WHITE}{target_pk}{RESET}")
        if new_state:
            print(f"  {DIM}Will auto-start on next {WHITE}prepare{RESET}{DIM} / {WHITE}work{RESET}")
        print()
        return

    # Default: interactive toggle menu
    # Build flat item list with group headers
    menu_items = []
    current_pk = None
    for pk, proj, ds in all_devs:
        if pk != current_pk:
            current_pk = pk
            menu_items.append(('header', pk, proj, None))
        menu_items.append(('service', pk, proj, ds))

    # Snapshot original states for discard
    orig_states = {}
    for _, pk, _, ds in menu_items:
        if ds is not None:
            orig_states[id(ds)] = ds.get('enabled', False)

    def _dev_render(item, idx, highlighted):
        kind, pk, proj, ds = item
        if kind == 'header':
            host = proj['host']
            return f"  {WHITE}{pk}{RESET}  {GRAY}({host}:{proj['path']}){RESET}"
        # Service row
        enabled = ds.get('enabled', False)
        toggle_text = '[ON]' if enabled else '[  ]'
        toggle_color = GREEN if enabled else GRAY
        name = ds['name']
        port = f":{ds['port']}"
        if highlighted:
            toggle = f"{toggle_color}{toggle_text}{RESET}"
            return f"    {toggle} {HIGHLIGHT_BG}{name:<25} {port:<6}{HIGHLIGHT_OFF}"
        toggle = f"{toggle_color}{toggle_text}{RESET}"
        return f"    {toggle} {name:<25} {port:<6}"

    def _dev_get_state(item):
        kind, _, _, ds = item
        if kind == 'header':
            return None  # Non-toggleable
        return ds.get('enabled', False)

    def _dev_set_state(item, val):
        _, _, _, ds = item
        if ds is not None:
            ds['enabled'] = val

    def _dev_save():
        projects_dict = dict(PROJECTS)
        # Apply toggled states to projects dict
        for _, pk, _, ds in menu_items:
            if ds is not None:
                for d in projects_dict[pk].get('dev_services', []):
                    if d['name'] == ds['name'] and d['port'] == ds['port']:
                        d['enabled'] = ds.get('enabled', False)
        save_projects(projects_dict, PROJECT_ORDER, IGNORED)
        reload_projects()

    print()
    title = f"  {WHITE}DEV SERVICES{RESET}  {GRAY}— space=toggle  enter=save  q=discard{RESET}"
    saved = interactive_toggle(
        menu_items, _dev_render, _dev_get_state, _dev_set_state,
        title=title, on_save=_dev_save,
    )

    if saved:
        # Count changes
        changed = sum(1 for _, pk, _, ds in menu_items
                      if ds is not None and ds.get('enabled', False) != orig_states.get(id(ds), False))
        if changed:
            print(f"  {GREEN}✓{RESET} Saved {changed} change(s)")
        else:
            print(f"  {GREEN}✓{RESET} Saved (no changes)")
    else:
        # Restore original states
        for _, pk, _, ds in menu_items:
            if ds is not None:
                ds['enabled'] = orig_states.get(id(ds), False)
        print(f"  {GRAY}Discarded{RESET}")
    print()


