def print_usage():
    print(f"""
{WHITE}hub{RESET} — Central entry point for the Orin Nano hub ecosystem

{WHITE}Usage:{RESET}
  hub                  Full reference with live system status
  hub --explain        Same as above (default)
  hub --status         Compact dashboard (fast)
  hub --next           Prioritized action list — what needs attention
  hub --services       Service status across all projects
  hub --dev            Show/toggle npm dev services (enable/disable per project)
  hub --vllm           Manage vLLM server (status/start/stop/restart)
  hub --manage         Edit, delete, or reorder project entries
  hub --scan <host>    Discover new projects on a host (agx, ws)
  hub --scan --ignore <host>   Manage ignored dirs on a host
  hub --help           This help
""")


def main():
    args = sys.argv[1:]

    if '-h' in args or '--help' in args:
        print_usage()
        sys.exit(0)

    if '--scan' in args:
        idx = args.index('--scan')
        if '--ignore' in args or '--ignored' in args:
            # hub --scan --ignore <host>
            ignore_idx = args.index('--ignore') if '--ignore' in args else args.index('--ignored')
            # Host can be after --scan or after --ignore
            host_arg = None
            for i in (idx + 1, ignore_idx + 1):
                if i < len(args) and not args[i].startswith('--'):
                    host_arg = args[i]
                    break
            if not host_arg:
                host_list = ', '.join(k for k in HOSTS if k != LOCAL_HOST)
                print(f"{RED}--scan --ignore requires a host argument ({host_list}){RESET}")
                sys.exit(1)
            scan_ignore(host_arg)
        else:
            if idx + 1 >= len(args):
                host_list = ', '.join(k for k in HOSTS if k != LOCAL_HOST)
                print(f"{RED}--scan requires a host argument ({host_list}){RESET}")
                sys.exit(1)
            scan_projects(args[idx + 1])
    elif '--dev' in args:
        dev_idx = args.index('--dev')
        dev_args = args[dev_idx + 1:]
        render_dev(dev_args)
    elif '--vllm' in args:
        vllm_idx = args.index('--vllm')
        vllm_args = args[vllm_idx + 1:]
        render_vllm(vllm_args)
    elif '--manage' in args:
        manage_projects()
    elif '--services' in args:
        render_services()
    elif '--status' in args:
        render_status()
    elif '--next' in args:
        render_next()
    else:
        render_explain()


if __name__ == '__main__':
    main()
