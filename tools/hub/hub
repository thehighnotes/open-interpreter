def generate_hints(state):
    """Generate contextual hints based on system state.

    Returns {hosts: [], background: [], git: [], caches: []} — lists of hint strings.
    Empty list = no hints = quiet section.
    """
    host_reachable = state['host_reachable']
    git_all = state['git_all']
    cache_ages = state['cache_ages']
    cache_age_s = state['cache_age_s']

    hints = {'hosts': [], 'background': [], 'git': [], 'caches': []}

    # HOSTS hints (max 3, dynamic)
    for hkey in HOSTS:
        if hkey == LOCAL_HOST:
            continue
        hname = HOSTS[hkey]['name']
        if not host_reachable.get(hkey):
            is_wakeable = 'wakeable' in HOSTS[hkey].get('roles', [])
            if is_wakeable:
                # Check if any projects on this host have uncommitted work
                host_dirty = sum(1 for pk, s in git_all.items()
                                 if PROJECTS.get(pk, {}).get('host') == hkey
                                 and s.get('is_git') and (s.get('dirty', 0) + s.get('untracked', 0)) > 0)
                if host_dirty:
                    hints['hosts'].append(f'{hname} suspended — {host_dirty} project(s) have uncommitted work')
            else:
                hints['hosts'].append(f'{hname} offline')
        if len(hints['hosts']) >= 3:
            break

    # BACKGROUND hints (max 3)
    if not state['as_running']:
        hints['background'].append('autosummary — start in tmux for auto-caching between sessions')
    research_age_s = state.get('research_age_s')
    if research_age_s is None or research_age_s > 86400:
        age_label = state['research_last'] if state['research_last'] != 'never' else 'never fetched'
        hints['background'].append(f'research --fetch — data is {age_label}')
    ca_host_2 = HUB_CONFIG['code_assistant']['host']
    ca_reachable_2 = host_reachable.get(ca_host_2, True) if ca_host_2 != LOCAL_HOST else True
    if not state['ca_up'] and ca_reachable_2:
        hints['background'].append(f'Code Assistant offline on {_CA_LABEL} — code search unavailable')
    elif state['ca_up'] and state['ca_watcher'] and not state['ca_watcher'].get('running'):
        hints['background'].append('code manage — file watcher stopped, indexes may be stale')
    unread = get_unread_count()
    if unread > 0:
        hints['background'].append(f'notify — {unread} unread notification(s)')

    # GIT hints (max 3)
    dirty_pks = [pk for pk, s in git_all.items()
                 if s.get('is_git') and (s.get('dirty', 0) + s.get('untracked', 0)) > 0]
    ahead_only_pks = [pk for pk, s in git_all.items()
                      if s.get('is_git') and isinstance(s.get('ahead'), int) and s['ahead'] > 0
                      and pk not in dirty_pks]
    pat_pks = [pk for pk, s in git_all.items() if s.get('has_pat')]
    no_git_pks = [pk for pk, s in git_all.items() if not s.get('is_git')]

    git_hints = []
    if dirty_pks:
        git_hints.append(f'repo checkpoint — {len(dirty_pks)} project(s) have uncommitted changes')
    if ahead_only_pks:
        git_hints.append(f'repo checkpoint — {len(ahead_only_pks)} project(s) have unpushed commits')
    if pat_pks:
        git_hints.append(f'repo fix {pat_pks[0]} — PAT token exposed in remote URL')
    if no_git_pks:
        git_hints.append(f'repo init {no_git_pks[0]} — not a git repo yet')
    hints['git'] = git_hints[:3]

    # CACHES hints (max 2)
    cache_hints = []
    # Find stalest project (>3 days)
    stalest_pk = None
    stalest_age = 0
    missing_pks = []
    for pk in PROJECT_ORDER:
        age_s = cache_age_s.get(pk)
        if age_s is None and cache_ages.get(pk) == '--':
            missing_pks.append(pk)
        elif age_s is not None and age_s > 259200 and age_s > stalest_age:
            stalest_age = age_s
            stalest_pk = pk
    if stalest_pk:
        cache_hints.append(f'work {stalest_pk} — cache is {cache_ages[stalest_pk]} old (refreshes automatically)')
    if missing_pks:
        cache_hints.append(f'overview {missing_pks[0]} — no cache yet, run to generate')
    hints['caches'] = cache_hints[:2]

    return hints


