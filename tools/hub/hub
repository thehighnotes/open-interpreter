def _prompt(msg, default=''):
    """Prompt for input with a default. Returns default on empty/EOF/Ctrl-C."""
    try:
        val = input(msg).strip()
        return val if val else default
    except (EOFError, KeyboardInterrupt):
        print()
        return default


def _discover_services_on_host(host_alias):
    """Discover all listening TCP ports and their process info via SSH.

    Returns list of dicts: {port, pid, cmd, cwd}
    """
    # Step 1: Get ss output and extract port+pid pairs
    ok, raw = ssh_cmd(host_alias, 'ss -tlnp 2>/dev/null', timeout=10)
    if not ok or not raw.strip():
        return []

    # Parse ss output locally (avoids shell quoting issues)
    port_pids = []
    for line in raw.strip().split('\n'):
        if 'LISTEN' not in line:
            continue
        # Extract port from local address (4th column, after last colon)
        parts = line.split()
        if len(parts) < 4:
            continue
        addr = parts[3]
        port_str = addr.rsplit(':', 1)[-1]
        try:
            port = int(port_str)
        except ValueError:
            continue
        # Skip low/system ports
        if port < 1024:
            continue
        # Extract pid from "pid=NNN"
        pid_match = re.search(r'pid=(\d+)', line)
        if not pid_match:
            continue
        port_pids.append((port, pid_match.group(1)))

    if not port_pids:
        return []

    # Step 2: For each pid, get cmd and cwd (batch SSH call)
    pid_set = set(pid for _, pid in port_pids)
    info_parts = []
    for pid in pid_set:
        info_parts.append(
            f'echo "{pid}|$(readlink /proc/{pid}/cwd 2>/dev/null)|$(cat /proc/{pid}/cmdline 2>/dev/null | tr "\\0" " " | head -c 200)"'
        )
    info_cmd = '; '.join(info_parts)
    ok2, info_raw = ssh_cmd(host_alias, info_cmd, timeout=10)

    pid_info = {}
    if ok2 and info_raw.strip():
        for line in info_raw.strip().split('\n'):
            parts = line.split('|', 2)
            if len(parts) >= 3:
                pid_info[parts[0]] = {'cwd': parts[1], 'cmd': parts[2].strip()}

    # Build service list
    services = []
    seen_ports = set()
    for port, pid in port_pids:
        if port in seen_ports:
            continue
        seen_ports.add(port)
        info = pid_info.get(pid, {})
        services.append({
            'port': port,
            'pid': pid,
            'cwd': info.get('cwd', ''),
            'cmd': info.get('cmd', ''),
        })
    return services


def _match_services_to_project(all_services, project_path_expanded, registered_ports):
    """Filter discovered services to those running from a project's directory.

    Returns list of service dicts not already registered.
    """
    candidates = []
    for svc in all_services:
        if not svc['cwd']:
            continue
        # Match if process cwd starts with the project path
        if svc['cwd'].startswith(project_path_expanded) and svc['port'] not in registered_ports:
            candidates.append(svc)
    return candidates


def _interactive_service_curation(host_alias, project_path, all_host_services, existing_services):
    """Show discovered services for a project, let user pick which to register.

    Returns list of new service dicts to add (with name, port, start_cmd, dir).
    """
    # Expand ~ in project path for matching
    ok, expanded = ssh_cmd(host_alias, f'echo {project_path}', timeout=5)
    expanded_path = expanded.strip() if ok and expanded.strip() else project_path

    registered_ports = {s['port'] for s in existing_services}
    candidates = _match_services_to_project(all_host_services, expanded_path, registered_ports)

    if not candidates:
        return []

    # Tag each with selection state
    for svc in candidates:
        svc['_selected'] = False

    def _svc_render(item, idx, highlighted):
        sel = f"{GREEN}[+]{RESET}" if item['_selected'] else f"{GRAY}[ ]{RESET}"
        cmd_short = item['cmd'][:60]
        if highlighted:
            return f"    {sel} {HIGHLIGHT_BG}:{item['port']}  {cmd_short}{HIGHLIGHT_OFF}"
        return f"    {sel} :{item['port']}  {DIM}{cmd_short}{RESET}"

    print()
    saved = interactive_toggle(
        candidates, _svc_render,
        get_state=lambda item: item['_selected'],
        set_state=lambda item, v: item.__setitem__('_selected', v),
        title=f"    {WHITE}Discovered services{RESET}  {GRAY}— space=select  enter=confirm  q=skip{RESET}",
    )

    if not saved:
        return []

    chosen = [svc for svc in candidates if svc['_selected']]
    if not chosen:
        return []

    new_services = []
    for svc in chosen:
        # Guess a name from the command
        cmd = svc['cmd']
        default_name = ''
        if 'python' in cmd:
            parts = cmd.split()
            for p in parts:
                if p.endswith('.py'):
                    default_name = p.rsplit('/', 1)[-1].replace('.py', '').replace('_', ' ').title()
                    break
        elif 'node' in cmd:
            parts = cmd.split()
            for p in parts:
                if p.endswith('.js'):
                    default_name = p.rsplit('/', 1)[-1].replace('.js', '').replace('-', ' ').title()
                    break
        if not default_name:
            default_name = f"Service :{svc['port']}"

        # Guess start_cmd from the running command
        default_start = cmd.strip()
        default_start = re.sub(r'^/usr/bin/(python3|node)\s+', r'\1 ', default_start)
        default_start = re.sub(r'^/usr/local/bin/(python3|node)\s+', r'\1 ', default_start)
        if ok and expanded.strip():
            default_start = default_start.replace(expanded.strip() + '/', '')

        name = _prompt(f"      name      [{WHITE}{default_name}{RESET}]: ", default_name)
        start_cmd = _prompt(f"      start_cmd [{WHITE}{default_start}{RESET}]: ", default_start)

        new_services.append({
            'port': svc['port'],
            'name': name,
            'start_cmd': start_cmd,
            'dir': '.',
        })

    return new_services


def _discover_npm_dev_services(host_alias, project_path):
    """Discover npm dev services from package.json in project dir + 1-level subdirs.

    Returns list of dev service candidate dicts:
        {name, port, dev_cmd, dir, subdir}
    Only returns entries where a port is detectable.
    """
    # SCP a small Python script to remote, run it there (avoids shell quoting hell)
    import tempfile as _tf
    scanner_script = f'''import json, os, re, sys
base = os.path.realpath(os.path.expanduser("{project_path}"))
seen = set()
# Collect package.json from: project root + immediate children
dirs_to_scan = [base]
for d in os.listdir(base):
    p = os.path.join(base, d)
    if os.path.isdir(p):
        dirs_to_scan.append(p)
for d in dirs_to_scan:
    pj = os.path.join(d, "package.json")
    rp = os.path.realpath(d)
    if rp in seen or not os.path.isfile(pj):
        continue
    seen.add(rp)
    try:
        data = json.load(open(pj))
    except Exception:
        continue
    scripts = data.get("scripts", {{}})
    reldir = os.path.relpath(rp, base)
    for name, cmd in scripts.items():
        # For node scripts, try to find a PORT or .listen() in the JS file
        file_port = ""
        if cmd.startswith("node "):
            js_file = cmd.split()[1]
            js_path = os.path.join(rp, js_file)
            if os.path.isfile(js_path):
                try:
                    src = open(js_path).read(8192)
                    # Match: const PORT = 3456, .listen(3001, PORT=3000
                    m = re.search(r"\.listen\(\s*(\d{{4,5}})", src)
                    if not m:
                        m = re.search(r"(?:PORT|port)\s*[=:]\s*(?:process\.env\.PORT\s*\|\|\s*)?(\d{{4,5}})", src)
                    if m:
                        file_port = m.group(1)
                except Exception:
                    pass
        print(f"PKG|{{reldir}}|{{name}}|{{cmd}}|{{file_port}}")
'''
    # Write to temp, SCP, run, clean up
    with _tf.NamedTemporaryFile(mode='w', suffix='.py', delete=False) as tmp:
        tmp.write(scanner_script)
        local_path = tmp.name
    remote_path = f'/tmp/_npm_scan_{uuid.uuid4().hex[:8]}.py'
    subprocess.run(['scp', '-q', local_path, f'{host_alias}:{remote_path}'],
                   capture_output=True, timeout=10)
    os.unlink(local_path)
    ok, output = ssh_cmd(host_alias, f'python3 {remote_path}; rm -f {remote_path}', timeout=15)
    if not ok or not output.strip():
        return []

    import re as _re

    # Auto-detect port from command string, URL patterns, and dir context
    def _guess_port(cmd, reldir=''):
        # Explicit port flags or env vars
        m = _re.search(r'(?:-p|--port)\s+(\d{4,5})', cmd)
        if m: return int(m.group(1))
        m = _re.search(r'PORT=(\d{4,5})', cmd)
        if m: return int(m.group(1))
        # URL in command (e.g. xdg-open http://localhost:3001)
        m = _re.search(r'localhost:(\d{4,5})', cmd)
        if m: return int(m.group(1))
        # Framework-specific defaults
        if 'react-scripts' in cmd: return 3000
        if 'next' in cmd: return 3000
        if 'nuxt' in cmd: return 3000
        if 'remix' in cmd: return 3000
        if 'gatsby' in cmd: return 8000
        if 'vite' in cmd: return 5173
        if 'svelte' in cmd or 'sveltekit' in cmd: return 5173
        if 'astro' in cmd: return 4321
        if _re.search(r'\bng\s+serve', cmd) or 'angular' in cmd: return 4200
        if 'webpack-dev-server' in cmd or 'webpack serve' in cmd: return 8080
        if 'func start' in cmd or 'func ' in cmd: return 7071
        # Directory-based heuristic: API/functions dirs likely serve on 7071
        dir_lower = reldir.lower().rstrip('/')
        if dir_lower in ('api', 'functions', 'azure-functions') and 'func' not in cmd:
            if cmd.startswith('node ') and ('start' in cmd or 'server' in cmd or 'logging' in cmd):
                return 7071
        return None

    candidates = []
    for line in output.strip().split('\n'):
        if not line.startswith('PKG|'):
            continue
        parts = line.split('|', 4)
        if len(parts) < 4:
            continue
        _, reldir, script_name, script_cmd = parts[0], parts[1], parts[2], parts[3]
        file_port = int(parts[4]) if len(parts) > 4 and parts[4].strip().isdigit() else None

        dev_cmd = 'npm start' if script_name == 'start' else f'npm run {script_name}'
        port = _guess_port(script_cmd, reldir)
        # Fall back to port found in the JS source file
        if port is None and file_port:
            port = file_port

        candidates.append({
            'script_name': script_name,
            'script_cmd': script_cmd,
            'dev_cmd': dev_cmd,
            'port': port,
            'dir': reldir,
        })

    return candidates


def _interactive_npm_dev_curation(host_alias, project_path, candidates, existing_dev_services):
    """Interactive toggle menu to pick npm scripts to register as dev services.

    Only shows scripts with a detectable port. Groups by subdir with
    non-toggleable header rows.
    Returns list of new dev_service dicts.
    """
    # Filter out already-registered and portless scripts
    existing_keys = {(s.get('dev_cmd', ''), s.get('dir', '.')) for s in existing_dev_services}
    new_candidates = [c for c in candidates
                      if (c['dev_cmd'], c['dir']) not in existing_keys and c.get('port')]

    if not new_candidates:
        return []

    # Build flat item list with group headers
    menu_items = []
    current_dir = None
    for c in new_candidates:
        if c['dir'] != current_dir:
            current_dir = c['dir']
            dir_label = current_dir if current_dir != '.' else 'root'
            menu_items.append(('header', dir_label, None))
        c['_selected'] = False
        menu_items.append(('script', None, c))

    def _npm_render(item, idx, highlighted):
        kind, label, c = item
        if kind == 'header':
            return f"    {GRAY}({label}){RESET}"
        sel = f"{GREEN}[+]{RESET}" if c['_selected'] else f"{GRAY}[ ]{RESET}"
        cmd_short = c['script_cmd'][:45]
        if highlighted:
            return f"    {sel} {HIGHLIGHT_BG}{c['script_name']:<22} :{c['port']:<6} {cmd_short}{HIGHLIGHT_OFF}"
        return f"    {sel} {c['script_name']:<22} :{c['port']:<6} {DIM}{cmd_short}{RESET}"

    print()
    saved = interactive_toggle(
        menu_items, _npm_render,
        get_state=lambda item: None if item[0] == 'header' else item[2]['_selected'],
        set_state=lambda item, v: item[2].__setitem__('_selected', v) if item[0] != 'header' else None,
        title=f"    {WHITE}npm dev services{RESET}  {GRAY}— space=select  enter=confirm  q=skip{RESET}",
    )

    if not saved:
        return []

    chosen = [item[2] for item in menu_items if item[0] == 'script' and item[2]['_selected']]
    if not chosen:
        return []

    # For each chosen, prompt for name (port already known)
    new_devs = []
    print()
    for c in chosen:
        default_name = c['script_name']
        if c['dir'] != '.':
            default_name = f"{c['dir']}/{c['script_name']}"

        print(f"    {CYAN}●{RESET} {c['dev_cmd']}  :{c['port']}  {DIM}{c['script_cmd'][:60]}{RESET}")
        name = _prompt(f"      name [{WHITE}{default_name}{RESET}]: ", default_name)

        new_devs.append({
            'name': name,
            'port': c['port'],
            'dev_cmd': c['dev_cmd'],
            'dir': c['dir'],
            'enabled': False,
        })

    return new_devs


def scan_projects(host_key):
    """Discover new projects on a remote host and interactively add them."""
    if host_key not in HOSTS:
        print(f"{RED}Unknown host '{host_key}'. Available: {', '.join(HOSTS.keys())}{RESET}")
        sys.exit(1)

    host = HOSTS[host_key]
    host_alias = host['alias']
    host_name = host['name']

    print()
    print(f"  {CYAN}Scanning {host_name} ({host['ip']})...{RESET}")

    # Check reachability
    if not check_host_reachable(host_alias):
        print(f"\n  {RED}● {host_name} is offline{RESET}")
        sys.exit(1)

    # Single SSH call to discover projects
    # For each dir in ~/projects/: check git, CLAUDE.md, .py files, and extract title
    scan_cmd = r'''
for d in ~/projects/*/; do
    [ -d "$d" ] || continue
    dirname=$(basename "$d")
    git=no; [ -d "$d/.git" ] && git=yes
    claude_md=none
    [ -f "$d/CLAUDE.md" ] && claude_md=CLAUDE.md
    [ -f "$d/claude.md" ] && claude_md=claude.md
    has_py=no; ls "$d"/*.py "$d"/**/*.py 2>/dev/null | head -1 | grep -q . && has_py=yes
    title=""
    if [ "$claude_md" != "none" ]; then
        title=$(head -5 "$d/$claude_md" 2>/dev/null | grep "^#" | head -1 | sed "s/^#\+\s*//")
    fi
    echo "${dirname}|${git}|${claude_md}|${has_py}|${title}"
done
'''
    ok, output = ssh_cmd(host_alias, scan_cmd, timeout=15)
    if not ok or not output.strip():
        print(f"\n  {GRAY}No ~/projects/ directory found or empty{RESET}")
        sys.exit(0)

    # Discover all listening services on this host (one SSH call)
    all_host_services = _discover_services_on_host(host_alias)

    # Parse results, separate into new candidates and already-registered
    existing_paths = {}  # dirname_lower → project key
    for pk, proj in PROJECTS.items():
        if proj['host'] == host_key:
            existing_paths[proj['path'].rsplit('/', 1)[-1].lower()] = pk

    host_ignored = set(IGNORED.get(host_key, []))
    candidates = []
    registered = []
    ignored_dirs = []
    for line in output.strip().split('\n'):
        parts = line.split('|', 4)
        if len(parts) < 5:
            continue
        dirname, git, claude_md, has_py, title = parts

        entry = {
            'dirname': dirname,
            'git': git == 'yes',
            'claude_md': claude_md if claude_md != 'none' else None,
            'title': title.strip() if title.strip() else None,
            'strong': git == 'yes' or claude_md != 'none',  # git or CLAUDE.md = prominent
        }

        if dirname.lower() in existing_paths:
            entry['key'] = existing_paths[dirname.lower()]
            registered.append(entry)
        elif dirname in host_ignored:
            ignored_dirs.append(dirname)
        elif git == 'yes' or claude_md != 'none' or has_py == 'yes':
            candidates.append(entry)

    if not candidates and not registered:
        print(f"\n  {GRAY}No ~/projects/ directory found or empty{RESET}")
        sys.exit(0)

    # Compute column width from all entries (candidates + registered)
    all_entries = candidates + registered
    max_dir = max(len(e['dirname']) for e in all_entries) if all_entries else 20
    dir_width = max(max_dir + 2, 20)

    # Display new candidates
    if candidates:
        print(f"\n  {WHITE}New projects found:{RESET}\n")
        print(f"  {GRAY}{'#':<4}{'Directory':<{dir_width}}{'Git':<6}{'CLAUDE.md':<12}{'Name'}{RESET}")
        print(f"  {GRAY}{'─' * (dir_width + 40)}{RESET}")

        for i, c in enumerate(candidates, 1):
            if c['strong']:
                git_str = f"{GREEN}git{RESET}" if c['git'] else f"{GRAY}-{RESET}"
                claude_str = f"{GREEN}{c['claude_md']}{RESET}" if c['claude_md'] else f"{GRAY}-{RESET}"
                name_str = c['title'] or f"{GRAY}{c['dirname']}{RESET}"
                dirname_padded = c['dirname'] + ' ' * max(0, dir_width - len(c['dirname']))
                git_padded = git_str + ' ' * max(0, 6 - (3 if c['git'] else 1))
                claude_vis = c['claude_md'] or '-'
                claude_padded = claude_str + ' ' * max(0, 12 - len(claude_vis))
                print(f"  {WHITE}{i:<4}{RESET}{dirname_padded}{git_padded}{claude_padded}{name_str}")
            else:
                # Weak candidate (only .py files) — dim the entire row
                dirname_padded = c['dirname'] + ' ' * max(0, dir_width - len(c['dirname']))
                print(f"  {DIM}{i:<4}{dirname_padded}-     -           {c['dirname']}{RESET}")
    else:
        print(f"\n  {GREEN}✓{RESET} No new projects found on {host_name}")

    # Display already-registered projects (dimmed) + service drift
    if registered:
        print(f"\n  {GRAY}Already registered:{RESET}")
        drift_projects = []
        for r in registered:
            pk = r['key']
            proj = PROJECTS[pk]
            existing_svcs = proj.get('services', [])
            registered_ports = {s['port'] for s in existing_svcs}
            # Expand path for matching
            ok_exp, expanded = ssh_cmd(host_alias, f'echo {proj["path"]}', timeout=5)
            expanded_path = expanded.strip() if ok_exp and expanded.strip() else proj['path']
            new_svcs = _match_services_to_project(all_host_services, expanded_path, registered_ports)
            svc_info = f"  {GRAY}{len(existing_svcs)} svc{RESET}" if existing_svcs else ''
            drift_label = f"  {YELLOW}+{len(new_svcs)} unregistered{RESET}" if new_svcs else ''
            print(f"  {GRAY}  ·  {r['dirname']:<{dir_width}}{RESET}{DIM}→ {pk}{RESET}{svc_info}{drift_label}")
            if new_svcs:
                drift_projects.append((pk, proj, new_svcs))

        # Offer to register drifted services
        if drift_projects:
            print(f"\n  {YELLOW}Unregistered services found on existing projects:{RESET}")
            for pk, proj, new_svcs in drift_projects:
                print(f"    {WHITE}{pk}{RESET}:")
                for svc in new_svcs:
                    cmd_short = svc['cmd'][:60]
                    print(f"      :{svc['port']}  {DIM}{cmd_short}{RESET}")
            try:
                fix = input(f"\n  {WHITE}Register these? (y/N): {RESET}").strip().lower()
            except (EOFError, KeyboardInterrupt):
                fix = 'n'
            if fix in ('y', 'yes'):
                projects_dict = dict(PROJECTS)
                order = list(PROJECT_ORDER)
                for pk, proj, new_svcs in drift_projects:
                    added = _interactive_service_curation(
                        host_alias, proj['path'], all_host_services, proj.get('services', []))
                    if added:
                        current_svcs = list(proj.get('services', []))
                        current_svcs.extend(added)
                        projects_dict[pk]['services'] = current_svcs
                        for s in added:
                            print(f"    {GREEN}+{RESET} {pk}: {s['name']} :{s['port']}")
                save_projects(projects_dict, order, IGNORED)
                reload_projects()
                print(f"  {GREEN}✓{RESET} Services updated")

        # Check for npm dev services on registered projects
        npm_drift_projects = []
        for r in registered:
            pk = r['key']
            proj = PROJECTS[pk]
            npm_candidates = _discover_npm_dev_services(host_alias, proj['path'])
            existing_devs = proj.get('dev_services', [])
            existing_dev_ports = {d['port'] for d in existing_devs}
            new_npm = [c for c in npm_candidates if c.get('port') and c['port'] not in existing_dev_ports]
            if new_npm:
                npm_drift_projects.append((pk, proj, new_npm))

        if npm_drift_projects:
            print(f"\n  {YELLOW}Unregistered npm dev services on existing projects:{RESET}")
            for pk, proj, new_npm in npm_drift_projects:
                print(f"    {WHITE}{pk}{RESET}:")
                for c in new_npm:
                    dir_info = f" ({c['dir']})" if c['dir'] != '.' else ''
                    print(f"      :{c['port']}  {c['dev_cmd']}{DIM}{dir_info}{RESET}")
            try:
                fix_npm = input(f"\n  {WHITE}Register npm dev services? (y/N): {RESET}").strip().lower()
            except (EOFError, KeyboardInterrupt):
                fix_npm = 'n'
            if fix_npm in ('y', 'yes'):
                projects_dict = dict(PROJECTS)
                order = list(PROJECT_ORDER)
                for pk, proj, new_npm in npm_drift_projects:
                    added = _interactive_npm_dev_curation(
                        host_alias, proj['path'], new_npm, proj.get('dev_services', []))
                    if added:
                        current_devs = list(proj.get('dev_services', []))
                        current_devs.extend(added)
                        projects_dict[pk]['dev_services'] = current_devs
                        for d in added:
                            en = f"{GRAY}off{RESET}"
                            print(f"    {GREEN}+{RESET} {pk}: {d['name']} :{d['port']}  [{en}]")
                save_projects(projects_dict, order, IGNORED)
                reload_projects()
                print(f"  {GREEN}✓{RESET} Dev services updated (use {WHITE}hub --dev{RESET} to enable)")

    # Display ignored dirs (dimmed)
    if ignored_dirs:
        print(f"\n  {DIM}Ignored: {', '.join(sorted(ignored_dirs))}  (hub --scan --ignore {host_key} to manage){RESET}")

    if not candidates:
        print()
        sys.exit(0)

    # Interactive selection — toggle menu
    # Tag each candidate with a 'selected' flag
    for c in candidates:
        c['_selected'] = False

    def _scan_render(item, idx, highlighted):
        c = item
        sel = f"{GREEN}[+]{RESET}" if c['_selected'] else f"{GRAY}[ ]{RESET}"
        name_str = c['title'] or c['dirname']
        git_str = 'git' if c['git'] else '-'
        if highlighted:
            return f"  {sel} {HIGHLIGHT_BG}{c['dirname']:<{dir_width}}{git_str}  {name_str}{HIGHLIGHT_OFF}"
        git_col = f"{GREEN}{git_str}{RESET}" if c['git'] else f"{GRAY}{git_str}{RESET}"
        return f"  {sel} {c['dirname']:<{dir_width}}{git_col}  {name_str}"

    print()
    title = f"  {WHITE}Select projects to add{RESET}  {GRAY}— space=toggle  enter=confirm  q=cancel{RESET}"
    saved = interactive_toggle(
        candidates, _scan_render,
        get_state=lambda c: c['_selected'],
        set_state=lambda c, v: c.__setitem__('_selected', v),
        title=title,
    )

    if not saved:
        sys.exit(0)

    selected = [i for i, c in enumerate(candidates) if c['_selected']]
    if not selected:
        sys.exit(0)

    # Build project entries with inline editing
    print()
    print(f"  {WHITE}Configure each project{RESET} {GRAY}(Enter to accept, or type replacement){RESET}")
    divider()

    entries = []
    for idx in selected:
        c = candidates[idx]
        default_key = c['dirname'].lower().replace(' ', '-')
        default_name = (c['title'] or c['dirname']).upper()
        claude_md = c['claude_md'] or 'CLAUDE.md'
        path = f"~/projects/{c['dirname']}"

        # Try to get tagline from CLAUDE.md — only accept the line
        # immediately after the title heading (1 blank line gap max).
        # Reject structural/instruction lines.
        tagline = ''
        if c['claude_md']:
            tag_cmd = f'head -10 ~/projects/{c["dirname"]}/{c["claude_md"]} 2>/dev/null'
            tag_ok, tag_out = ssh_cmd(host_alias, tag_cmd, timeout=5)
            if tag_ok and tag_out:
                lines = tag_out.strip().split('\n')
                for j, line in enumerate(lines):
                    if line.startswith('# '):
                        # Look at only j+1 and j+2 (immediate vicinity)
                        for k in range(j + 1, min(j + 3, len(lines))):
                            candidate_line = lines[k].strip()
                            if not candidate_line:
                                continue  # skip one blank line
                            # Reject headings, code fences, list items, tables, key:value metadata
                            if (candidate_line.startswith(('#', '`', '|', '-', '*', '>'))
                                    or re.match(r'^[A-Za-z][\w\s]{0,18}:', candidate_line)
                                    or len(candidate_line) > 80):
                                break  # no tagline available
                            tagline = candidate_line[:80]
                            break
                        break

        print(f"\n  {CYAN}{c['dirname']}{RESET}  {GRAY}({path}){RESET}")
        key = _prompt(f"    key     [{WHITE}{default_key}{RESET}]: ", default_key)
        name = _prompt(f"    name    [{WHITE}{default_name}{RESET}]: ", default_name)
        tagline = _prompt(f"    tagline [{WHITE}{tagline or '(none)'}{RESET}]: ", tagline)

        # Auto-discover services for this project
        discovered_svcs = _interactive_service_curation(
            host_alias, path, all_host_services, existing_services=[])

        # Auto-discover npm dev services
        npm_candidates = _discover_npm_dev_services(host_alias, path)
        discovered_devs = _interactive_npm_dev_curation(
            host_alias, path, npm_candidates, existing_dev_services=[]) if npm_candidates else []

        entries.append({
            'key': key,
            'name': name,
            'tagline': tagline if tagline != '(none)' else '',
            'host': host_key,
            'path': path,
            'claude_md': claude_md,
            'services': discovered_svcs,
            'dev_services': discovered_devs,
        })

    # Confirmation review
    print()
    divider()
    print(f"\n  {WHITE}Review:{RESET}\n")
    for e in entries:
        tag_display = f"  {GRAY}{e['tagline']}{RESET}" if e['tagline'] else ''
        print(f"  {GREEN}+{RESET} {WHITE}{e['key']}{RESET}  {e['name']}{tag_display}")
        print(f"    {GRAY}{e['host']}:{e['path']}  ({e['claude_md']}){RESET}")
        if e.get('services'):
            for svc in e['services']:
                print(f"    {CYAN}●{RESET} {svc['name']} :{svc['port']}  {DIM}{svc.get('start_cmd', '')}{RESET}")
        if e.get('dev_services'):
            for ds in e['dev_services']:
                en = f"{GREEN}on{RESET}" if ds.get('enabled') else f"{GRAY}off{RESET}"
                dir_info = f" ({ds['dir']})" if ds['dir'] != '.' else ''
                print(f"    {YELLOW}●{RESET} {ds['name']} :{ds['port']}  {ds['dev_cmd']}{DIM}{dir_info}{RESET}  [{en}]")

    print()
    confirm = _prompt(f"  {WHITE}Confirm? (Y/n): {RESET}", 'y').lower()
    if confirm not in ('y', 'yes'):
        print(f"  {GRAY}Cancelled{RESET}")
        sys.exit(0)

    # Write to projects.json
    projects = dict(PROJECTS)
    order = list(PROJECT_ORDER)

    for e in entries:
        proj_data = {
            'name': e['name'],
            'tagline': e['tagline'],
            'host': e['host'],
            'path': e['path'],
            'claude_md': e['claude_md'],
            'services': e.get('services', []),
        }
        if e.get('dev_services'):
            proj_data['dev_services'] = e['dev_services']
        projects[e['key']] = proj_data
        if e['key'] not in order:
            order.append(e['key'])

    save_projects(projects, order, IGNORED)
    reload_projects()

    print()
    for e in entries:
        print(f"  {GREEN}+{RESET} {WHITE}{e['key']}{RESET}  ({e['name']})")
    print(f"\n  {GREEN}✓{RESET} {len(entries)} project(s) added to {PROJECTS_JSON}")
    print(f"  {GRAY}Run {WHITE}overview {entries[0]['key']}{GRAY} to generate initial cache{RESET}")
    print()


def scan_ignore(host_key):
    """Interactive ignore management — add/remove dirs from the ignored list."""
    if host_key not in HOSTS:
        print(f"{RED}Unknown host '{host_key}'. Available: {', '.join(HOSTS.keys())}{RESET}")
        sys.exit(1)

    host = HOSTS[host_key]
    host_alias = host['alias']
    host_name = host['name']

    print()
    print(f"  {CYAN}Scanning {host_name} for ignore management...{RESET}")

    if not check_host_reachable(host_alias):
        print(f"\n  {RED}● {host_name} is offline{RESET}")
        sys.exit(1)

    # Get all dirs
    scan_cmd = r'''
for d in ~/projects/*/; do
    [ -d "$d" ] || continue
    basename "$d"
done
'''
    ok, output = ssh_cmd(host_alias, scan_cmd, timeout=15)
    if not ok or not output.strip():
        print(f"\n  {GRAY}No ~/projects/ directory found or empty{RESET}")
        sys.exit(0)

    all_dirs = [d.strip() for d in output.strip().split('\n') if d.strip()]

    # Classify each dir
    existing_paths = set()
    for pk, proj in PROJECTS.items():
        if proj['host'] == host_key:
            existing_paths.add(proj['path'].rsplit('/', 1)[-1].lower())

    host_ignored = list(IGNORED.get(host_key, []))
    host_ignored_set = set(host_ignored)

    currently_ignored = []
    unregistered = []
    for d in sorted(all_dirs):
        if d.lower() in existing_paths:
            continue  # registered project — skip
        if d in host_ignored_set:
            currently_ignored.append(d)
        else:
            unregistered.append(d)

    if not currently_ignored and not unregistered:
        print(f"\n  {GREEN}✓{RESET} All dirs on {host_name} are either registered projects or empty")
        print()
        sys.exit(0)

    # Build toggle list — all non-registered dirs, with ignored=ON
    all_dirs_sorted = sorted(currently_ignored + unregistered)
    items = []
    for d in all_dirs_sorted:
        items.append({'name': d, 'ignored': d in host_ignored_set})

    # Snapshot original states
    orig_states = {item['name']: item['ignored'] for item in items}

    def _ignore_render(item, idx, highlighted):
        if item['ignored']:
            toggle = f"{YELLOW}[IGN]{RESET}"
        else:
            toggle = f"{GRAY}[   ]{RESET}"
        if highlighted:
            return f"  {toggle} {HIGHLIGHT_BG}{item['name']}{HIGHLIGHT_OFF}"
        return f"  {toggle} {item['name']}"

    title = f"  {WHITE}Ignore list — {host_name}{RESET}  {GRAY}— space=toggle  enter=save  q=discard{RESET}"

    def _ignore_save():
        new_ignored = dict(IGNORED)
        current_list = [item['name'] for item in items if item['ignored']]
        if current_list:
            new_ignored[host_key] = sorted(current_list)
        elif host_key in new_ignored:
            del new_ignored[host_key]
        save_projects(PROJECTS, PROJECT_ORDER, new_ignored)
        reload_projects()

    saved = interactive_toggle(
        items, _ignore_render,
        get_state=lambda item: item['ignored'],
        set_state=lambda item, v: item.__setitem__('ignored', v),
        title=title, on_save=_ignore_save,
    )

    if saved:
        # Report changes
        to_ignore = [item['name'] for item in items if item['ignored'] and not orig_states[item['name']]]
        to_unignore = [item['name'] for item in items if not item['ignored'] and orig_states[item['name']]]
        for d in to_ignore:
            print(f"  {GRAY}+ ignored: {d}{RESET}")
        for d in to_unignore:
            print(f"  {GREEN}- unignored: {d}{RESET}")
        if to_ignore or to_unignore:
            print(f"\n  {GREEN}✓{RESET} Updated {PROJECTS_JSON}")
        else:
            print(f"  {GREEN}✓{RESET} No changes")
    else:
        print(f"  {GRAY}Discarded{RESET}")
    print()


