def gather_state(include_extras=False):
    """Probe all system state. Returns a dict consumed by render_status() and render_next().

    When include_extras=True, also fetches backup_age (for --next).
    """
    # Probe hosts in parallel (dynamic from config)
    remote_hosts = [k for k in HOSTS if k != LOCAL_HOST]
    host_reachable = run_parallel({
        k: (lambda h=k: check_host_reachable(h)) for k in remote_hosts
    })

    probe_tasks = {LOCAL_HOST: lambda: probe_nano_health()}
    for k in remote_hosts:
        probe_tasks[k] = (lambda h=k: probe_remote_host(h, host_reachable.get(h, False)))
    results = run_parallel(probe_tasks)

    as_running, as_pid = get_autosummary_status()
    research_last, research_age_s = get_research_last_fetch()
    cache_ages, cache_age_s = get_cache_ages()

    # Code Assistant
    ca_host = HUB_CONFIG['code_assistant']['host']
    ca_reachable = host_reachable.get(ca_host, True) if ca_host != LOCAL_HOST else True
    ca_up = check_code_assistant() if ca_reachable else False
    ca_projects = None
    ca_watcher = None
    if ca_up:
        ca_projects = code_assistant_get('projects', timeout=3)
        ca_watcher = code_assistant_get('watcher/status', timeout=3)

    # GIT summary (quick batch probe)
    git_by_host = {}
    for pk in PROJECT_ORDER:
        p = PROJECTS[pk]
        git_by_host.setdefault(p['host'], []).append((pk, p))
    git_tasks = {}
    for h, entries in git_by_host.items():
        if host_reachable.get(h, False):
            git_tasks[h] = (lambda h=h, e=entries: fetch_git_status_batch(h, e))
    git_raw = run_parallel(git_tasks) if git_tasks else {}
    git_all = {}
    for h, r in git_raw.items():
        if isinstance(r, dict):
            git_all.update(r)

    # Deploy states
    deploy_states = {}
    for pk in PROJECT_ORDER:
        deploy_states[pk] = read_deploy_state(pk)

    state = {
        'host_reachable': host_reachable,
        'host_info': results,
        'as_running': as_running,
        'as_pid': as_pid,
        'research_last': research_last,
        'research_age_s': research_age_s,
        'cache_ages': cache_ages,
        'cache_age_s': cache_age_s,
        'ca_up': ca_up,
        'ca_projects': ca_projects,
        'ca_watcher': ca_watcher,
        'git_all': git_all,
        'deploy_states': deploy_states,
    }

    if include_extras:
        backup_host = BACKUP_DEST.split(':')[0] if ':' in BACKUP_DEST else LOCAL_HOST
        backup_reachable = host_reachable.get(backup_host, True) if backup_host != LOCAL_HOST else True
        if backup_reachable:
            backup_str, backup_s = get_backup_age()
            state['backup_age'] = backup_str
            state['backup_age_s'] = backup_s
        else:
            state['backup_age'] = 'unknown'
            state['backup_age_s'] = None

    return state


