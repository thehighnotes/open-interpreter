def _manage_edit_at(projects, order, ignored, idx):
    """Edit a single project's fields at the given index."""
    old_key = order[idx]
    proj = projects[old_key]

    print(f"\n  {WHITE}{old_key}{RESET}")
    print(f"  {'─' * 38}")

    # Editable fields: key, name, tagline, host, path, claude_md, code_index, git_remote, git_branch
    new_key = _prompt(f"    key     [{old_key}]: ", old_key)
    new_name = _prompt(f"    name    [{proj['name']}]: ", proj['name'])
    new_tagline = _prompt(f"    tagline [{proj.get('tagline', '')}]: ", proj.get('tagline', ''))
    valid_hosts = ', '.join(sorted(HOSTS.keys()))
    new_host = _prompt(f"    host    [{proj['host']}]: ({valid_hosts}) ", proj['host']).lower()
    if new_host not in HOSTS:
        print(f"  {RED}Invalid host '{new_host}' — must be one of: {valid_hosts}{RESET}")
        return
    new_path = _prompt(f"    path    [{proj['path']}]: ", proj['path'])
    if not new_path.startswith('~/') and not new_path.startswith('/'):
        print(f"  {RED}Path must start with ~/ or /{RESET}")
        return
    new_claude = _prompt(f"    claude  [{proj.get('claude_md', 'CLAUDE.md')}]: ", proj.get('claude_md', 'CLAUDE.md'))
    new_index = _prompt(f"    index   [{proj.get('code_index', '')}]: ", proj.get('code_index', ''))
    new_remote = _prompt(f"    remote  [{proj.get('git_remote', '')}]: ", proj.get('git_remote', ''))
    new_branch = _prompt(f"    branch  [{proj.get('git_branch', '')}]: ", proj.get('git_branch', ''))

    # Build changes list
    changes = []
    for field, old_val, new_val in [
        ('name', proj['name'], new_name),
        ('tagline', proj.get('tagline', ''), new_tagline),
        ('host', proj['host'], new_host),
        ('path', proj['path'], new_path),
        ('claude_md', proj.get('claude_md', 'CLAUDE.md'), new_claude),
    ]:
        if old_val != new_val:
            changes.append(field)
    proj['name'] = new_name
    proj['tagline'] = new_tagline
    proj['host'] = new_host
    proj['path'] = new_path
    proj['claude_md'] = new_claude

    # Optional fields: empty string → remove
    for field, val in [('code_index', new_index), ('git_remote', new_remote), ('git_branch', new_branch)]:
        if val:
            if proj.get(field) != val:
                changes.append(field)
            proj[field] = val
        else:
            if field in proj:
                changes.append(field)
                del proj[field]

    # Recompute claude_dir
    proj['claude_dir'] = derive_claude_dir(proj['host'], proj['path'])

    # Handle key rename
    if new_key != old_key:
        if new_key in projects:
            print(f"  {RED}Key '{new_key}' already exists{RESET}")
            return
        changes.append('key')
        projects[new_key] = proj
        del projects[old_key]
        order[idx] = new_key

    save_projects(projects, order, ignored)
    reload_projects()
    if changes:
        print(f"\n  {GREEN}✓{RESET} Updated {new_key} ({', '.join(changes)} changed)")
    else:
        print(f"\n  {GREEN}✓{RESET} Saved {new_key} (no changes)")
    print()


def _manage_delete_at(projects, order, ignored, idx):
    """Delete a project entry at the given index (not the files)."""
    key = order[idx]
    proj = projects[key]

    print(f"\n  {YELLOW}⚠{RESET} Remove {WHITE}{key}{RESET} ({proj['name']})?")
    print(f"  {GRAY}This only removes the hub entry, not the project files.{RESET}")
    confirm = _prompt("  Confirm? (y/N): ", 'n').lower()
    if confirm != 'y':
        print(f"  {GRAY}Cancelled{RESET}")
        return

    del projects[key]
    order.pop(idx)
    save_projects(projects, order, ignored)
    reload_projects()
    print(f"\n  {GREEN}✓{RESET} Removed {key}")
    print()


def _manage_reorder(projects, order, ignored):
    """Reorder projects via comma-separated numbers."""
    n = len(order)
    print(f"  {GRAY}Current order: {', '.join(order)}{RESET}")
    raw = _prompt(f"  New order (e.g. {','.join(str(i) for i in range(1, n+1))}): ")
    if not raw:
        return

    try:
        nums = [int(x.strip()) for x in raw.split(',')]
    except ValueError:
        print(f"  {RED}Enter comma-separated numbers{RESET}")
        return

    if sorted(nums) != list(range(1, n + 1)):
        print(f"  {RED}Must include each number 1-{n} exactly once{RESET}")
        return

    new_order = [order[i - 1] for i in nums]
    save_projects(projects, new_order, ignored)
    reload_projects()

    # Show what moved
    first_key = new_order[0]
    print(f"\n  {GREEN}✓{RESET} Reordered ({first_key} now first)")
    print()


def manage_projects():
    """Interactive project editor — arrow-key selection with action keys."""
    projects, order, ignored = load_projects()

    while True:
        # Build item list from current order
        items = []
        for key in order:
            proj = projects[key]
            items.append((key, proj))

        if not items:
            print(f"\n  {GRAY}No projects configured{RESET}\n")
            break

        def _manage_render(item, idx, highlighted):
            key, proj = item
            host_label = proj['host'].upper()
            ci = proj.get('code_index', '--')
            hl_start = HIGHLIGHT_BG if highlighted else ''
            hl_end = HIGHLIGHT_OFF if highlighted else ''
            return f"  {hl_start}{key:<18}{proj['name']:<25}{host_label:<7}{ci}{hl_end}"

        print()
        w = cols()
        print(f"  {WHITE}{'PROJECT MANAGER':^{w-4}}{RESET}")
        print(f"  {'═' * (w - 4)}")
        print()
        print(f"  {GRAY}{'Key':<18}{'Name':<25}{'Host':<7}{'Index'}{RESET}")
        print(f"  {'─' * (w - 4)}")

        action_keys = {
            'e': ('edit', 'Edit project fields'),
            'd': ('delete', 'Remove project entry'),
            'r': ('reorder', 'Reorder projects'),
        }
        footer = f"  {GRAY}e=edit  d=delete  r=reorder  enter=edit  q=quit{RESET}"

        action, idx = interactive_select(
            items, _manage_render, actions=action_keys, footer=footer,
        )

        if action is None:
            break
        elif action in ('e', KEY_ENTER):
            _manage_edit_at(projects, order, ignored, idx)
            # Reload after edit (key may have changed)
            projects, order, ignored = load_projects()
        elif action == 'd':
            _manage_delete_at(projects, order, ignored, idx)
            projects, order, ignored = load_projects()
        elif action == 'r':
            _manage_reorder(projects, order, ignored)
            projects, order, ignored = load_projects()


