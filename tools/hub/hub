def get_unread_count():
    """Return number of unread notifications from NOTIFY_LOG."""
    if not NOTIFY_LOG.exists():
        return 0
    count = 0
    for line in NOTIFY_LOG.read_text().splitlines():
        line = line.strip()
        if not line:
            continue
        try:
            entry = json.loads(line)
            if not entry.get('read'):
                count += 1
        except (json.JSONDecodeError, ValueError):
            continue
    return count


