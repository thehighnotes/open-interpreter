def render_vllm(args=None):
    """Manage vLLM inference server on AGX.

    hub --vllm              Show status
    hub --vllm start        Start server
    hub --vllm stop         Stop server (frees GPU memory)
    hub --vllm restart      Restart server
    """
    action = args[0] if args else 'status'

    if action not in ('status', 'start', 'stop', 'restart'):
        print(f"\n  {WHITE}hub --vllm{RESET} [status|start|stop|restart]\n")
        return

    llm_host = LLM_HOST
    llm_ip = HOSTS.get(llm_host, {}).get('ip', '127.0.0.1')
    service = 'vllm-server'

    if action == 'status':
        print(f"\n  {WHITE}vLLM Server{RESET} on {CYAN}{HOSTS.get(llm_host, {}).get('name', llm_host)}{RESET}\n")

        # Check systemd service
        ok, svc_out = ssh_cmd(llm_host, f'systemctl is-active {service}', timeout=5)
        svc_state = svc_out.strip() if ok else 'unknown'

        # Check HTTP health
        healthy = False
        model_name = ''
        try:
            import urllib.request
            req = urllib.request.urlopen(f'http://{llm_ip}:{LLM_PORT}/v1/models', timeout=3)
            import json as _j
            data = _j.loads(req.read())
            models = [m['id'] for m in data.get('data', [])]
            if models:
                healthy = True
                model_name = models[0]
        except Exception:
            pass

        if healthy:
            print(f"  {GREEN}●{RESET} Running — {model_name}")
            print(f"  {GRAY}Endpoint: http://{llm_ip}:{LLM_PORT}/v1{RESET}")
            print(f"  {GRAY}Context:  {LLM_CONTEXT_WINDOW:,} tokens{RESET}")
        elif svc_state == 'activating':
            print(f"  {YELLOW}●{RESET} Starting up (model loading, ~2-3 min)...")
        elif svc_state == 'active':
            print(f"  {YELLOW}●{RESET} Service active but not responding yet")
        else:
            print(f"  {RED}●{RESET} Not running")
            print(f"  {GRAY}Start with: hub --vllm start{RESET}")
        print()

    elif action == 'start':
        print(f"  Starting vLLM on {HOSTS.get(llm_host, {}).get('name', llm_host)}...")
        ok, out = ssh_cmd(llm_host, f'sudo systemctl start {service}', timeout=15)
        if ok:
            print(f"  {GREEN}✓{RESET} Service started (model loads in ~2-3 min)")
            print(f"  {GRAY}Check status: hub --vllm{RESET}")
        else:
            print(f"  {RED}✗{RESET} Failed to start: {out}")

    elif action == 'stop':
        print(f"  Stopping vLLM on {HOSTS.get(llm_host, {}).get('name', llm_host)}...")
        ok, out = ssh_cmd(llm_host, f'sudo systemctl stop {service}', timeout=15)
        if ok:
            print(f"  {GREEN}✓{RESET} Server stopped — GPU memory freed")
        else:
            print(f"  {RED}✗{RESET} Failed to stop: {out}")

    elif action == 'restart':
        print(f"  Restarting vLLM on {HOSTS.get(llm_host, {}).get('name', llm_host)}...")
        ok, out = ssh_cmd(llm_host, f'sudo systemctl restart {service}', timeout=15)
        if ok:
            print(f"  {GREEN}✓{RESET} Service restarted (model loads in ~2-3 min)")
        else:
            print(f"  {RED}✗{RESET} Failed to restart: {out}")


