def render_services():
    """Show all registered services grouped by host with live status."""
    print()
    header_bar()
    print(f"{BRIGHT_GREEN}  HUB — Services{RESET}")
    header_bar()

    # Group services by host
    by_host = {}
    for key in PROJECT_ORDER:
        proj = PROJECTS[key]
        services = proj.get('services', [])
        if not services:
            continue
        host_key = proj['host']
        if host_key not in by_host:
            by_host[host_key] = []
        for svc in services:
            by_host[host_key].append({
                'project': key,
                'project_name': proj['name'],
                'name': svc['name'],
                'port': svc['port'],
                'start_cmd': svc.get('start_cmd', ''),
                'host_alias': HOSTS[host_key]['alias'],
            })

    if not by_host:
        print(f"\n  {GRAY}No services configured in any project{RESET}")
        header_bar()
        return

    # Probe all services in parallel
    probe_tasks = {}
    host_reachable = {}
    for host_key, svcs in by_host.items():
        alias = HOSTS[host_key]['alias']
        host_reachable[host_key] = check_host_reachable(alias)
        if host_reachable[host_key]:
            for svc in svcs:
                task_key = f"{host_key}:{svc['port']}"
                port = svc['port']
                probe_tasks[task_key] = lambda a=alias, p=port: probe_service(a, p, timeout=3)

    with Spinner("Probing services..."):
        probe_results = run_parallel(probe_tasks) if probe_tasks else {}

    # Render by host
    for host_key, svcs in by_host.items():
        host = HOSTS[host_key]
        reachable = host_reachable.get(host_key, False)
        host_dot = f"{GREEN}●{RESET}" if reachable else f"{RED}●{RESET}"
        print(f"\n  {host_dot} {WHITE}{host['name']}{RESET} ({host['ip']})")
        thin_divider()

        # Column widths
        max_name = max(len(s['name']) for s in svcs)
        name_w = max(max_name + 2, 20)

        for svc in svcs:
            task_key = f"{host_key}:{svc['port']}"
            if not reachable:
                dot = f"{RED}●{RESET}"
                status_str = f"{RED}host offline{RESET}"
            elif task_key in probe_results:
                up = probe_results[task_key]
                dot = f"{GREEN}●{RESET}" if up else f"{RED}●{RESET}"
                status_str = f"{GREEN}running{RESET}" if up else f"{RED}down{RESET}"
            else:
                dot = f"{GRAY}●{RESET}"
                status_str = f"{GRAY}unknown{RESET}"

            name_padded = svc['name'] + ' ' * max(0, name_w - len(svc['name']))
            cmd_info = f"  {DIM}{svc['start_cmd']}{RESET}" if svc['start_cmd'] else ''
            print(f"    {dot} {name_padded}:{svc['port']:<6} {status_str}  {GRAY}{svc['project']}{RESET}{cmd_info}")

    # Summary
    total = sum(len(svcs) for svcs in by_host.values())
    up_count = sum(1 for v in probe_results.values() if v)
    print()
    print(f"  {GRAY}{up_count}/{total} services running across {len(by_host)} host(s){RESET}")
    header_bar()
    print()


