{
  "hub": {
    "name": "My Dev Hub",
    "local_host": "local"
  },
  "hosts": {
    "local": {
      "name": "Hub", "ip": "127.0.0.1", "user": "myuser",
      "roles": ["local", "ollama"]
    }
  },
  "ollama": {
    "host": "local",
    "port": 11434,
    "default_model": "llama3.2:3b"
  },
  "code_assistant": { "host": "local", "port": 5002 },
  "backup": { "destination": "~/hub-backup" },
  "git": { "github_username": "myuser", "email": "me@example.com" }
}
