# Core functions
# ─────────────────────────────────────────────────────────────────────────────

def send_wol(mac_address):
    """Send Wake-on-LAN magic packet to the given MAC address."""
    try:
        subprocess.run(['wakeonlan', mac_address], capture_output=True, timeout=5)
        return True
    except Exception:
        return False


def poll_until_ssh(host_alias, max_wait=120, interval=5):
    """Poll SSH until host responds. Returns True if reachable within max_wait."""
    elapsed = 0
    while elapsed < max_wait:
        sys.stderr.write(f"\r{CYAN}⠼{RESET} Waiting for {host_alias}... {elapsed}s/{max_wait}s")
        sys.stderr.flush()
        if check_host_reachable(host_alias):
            sys.stderr.write(f"\r{' ' * 60}\r")
            sys.stderr.flush()
            return True
        time.sleep(interval)
        elapsed += interval
    sys.stderr.write(f"\r{' ' * 60}\r")
    sys.stderr.flush()
    return False


def warmup_llm_bg():
    """Fire-and-forget LLM warmup. For Ollama, sends a request to load the model.
    For vLLM, the model is always loaded — just verify connectivity."""
    if LLM_BACKEND == 'vllm':
        # vLLM keeps the model in memory permanently — just ping to verify
        llm_ip = HOSTS.get(LLM_HOST, {}).get('ip', '127.0.0.1')
        cmd = f"curl -s --max-time 5 http://{llm_ip}:{LLM_PORT}/v1/models > /dev/null 2>&1"
        try:
            subprocess.Popen(
                ['bash', '-c', cmd],
                stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL
            )
        except Exception:
            pass
    else:
        cmd = (
            f"curl -s --max-time 30 http://localhost:{OLLAMA_PORT}/api/chat "
            f"-d '{{\"model\":\"{DEFAULT_MODEL}\",\"messages\":[{{\"role\":\"user\",\"content\":\"hi\"}}],\"stream\":false}}' "
            "> /dev/null 2>&1"
        )
        if OLLAMA_HOST == LOCAL_HOST:
            try:
                subprocess.Popen(
                    ['bash', '-c', cmd],
                    stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL
                )
            except Exception:
                pass
        else:
            try:
                subprocess.Popen(
                    ['ssh', '-o', 'ConnectTimeout=3', '-o', 'BatchMode=yes',
                     '-o', 'StrictHostKeyChecking=no', OLLAMA_HOST, cmd],
                    stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL
                )
            except Exception:
                pass


def refresh_cache(project_key):
    """Run overview --refresh for a project. Returns True on success."""
    return refresh_overview_cache(project_key)


MAX_CACHE_AGE = 6 * 3600  # 6 hours


def probe_project_state(host_alias, proj):
    """Probe git HEAD, CLAUDE.md mtime, and transcript mtime in one SSH call.

    Returns dict with keys: git_head, claude_md_mtime, transcript_mtime.
    Values are strings or None.
    """
    proj_path = proj['path']
    claude_md_name = proj.get('claude_md', 'CLAUDE.md')
    claude_dir = proj.get('claude_dir', '')

    # Build a script that outputs tagged lines — avoids nested $() escaping issues
    script_lines = [
        f'cd {proj_path} 2>/dev/null',
        'echo "GIT:$(git rev-parse --short HEAD 2>/dev/null)"',
        f'echo "CMD:$(stat -c %Y {proj_path}/{claude_md_name} 2>/dev/null)"',
    ]
    if claude_dir:
        script_lines.append(
            f'TXN=$(find ~/.claude/projects/{claude_dir}/ -maxdepth 1 '
            f'-name "*.jsonl" -printf "%T@\\n" 2>/dev/null | sort -rn | head -1) && '
            f'echo "TXN:$TXN"'
        )
    else:
        script_lines.append('echo "TXN:"')

    cmd = ' && '.join(script_lines)
    ok, output = ssh_cmd(host_alias, cmd, timeout=10)

    result = {'git_head': None, 'claude_md_mtime': None, 'transcript_mtime': None}
    if not ok or not output:
        return result

    for line in output.strip().split('\n'):
        if line.startswith('GIT:') and line[4:].strip():
            result['git_head'] = line[4:].strip()
        elif line.startswith('CMD:') and line[4:].strip():
            result['claude_md_mtime'] = line[4:].strip()
        elif line.startswith('TXN:') and line[4:].strip():
            # Truncate to integer seconds (matches overview's format)
            val = line[4:].strip()
            result['transcript_mtime'] = val.split('.')[0] if '.' in val else val

    return result


def check_prepare_staleness(project_key, host_alias, proj):
    """Check if project state has changed since last prepare.

    Returns (is_stale: bool, reason: str, current_state: dict).
    current_state is returned so save_prepare_state can reuse it.
    """
    cache_file = OVERVIEW_CACHE_DIR / f"{project_key}.json"
    state_file = OVERVIEW_CACHE_DIR / f"{project_key}.prepare_state"

    # Probe current state (single SSH call)
    current = probe_project_state(host_alias, proj)

    # No cache at all
    if not cache_file.exists():
        return True, "no cache", current

    # No previous state saved
    if not state_file.exists():
        return True, "first run", current

    # Load stored state
    try:
        stored = json.loads(state_file.read_text())
    except (json.JSONDecodeError, OSError):
        return True, "corrupt state", current

    # Max age check
    cache_age = time.time() - stored.get('ts', 0)
    if cache_age > MAX_CACHE_AGE:
        hours = int(cache_age / 3600)
        return True, f"cache {hours}h old", current

    # Compare indicators
    if current['git_head'] and current['git_head'] != stored.get('git_head'):
        return True, "git HEAD changed", current

    if current['claude_md_mtime'] and current['claude_md_mtime'] != stored.get('claude_md_mtime'):
        return True, "CLAUDE.md changed", current

    if current['transcript_mtime'] and current['transcript_mtime'] != stored.get('transcript_mtime'):
        return True, "transcript changed", current

    # All match — cache is fresh
    age_secs = time.time() - cache_file.stat().st_mtime
    if age_secs < 60:
        age_str = f"{int(age_secs)}s ago"
    elif age_secs < 3600:
        age_str = f"{int(age_secs / 60)}m ago"
    else:
        age_str = f"{int(age_secs / 3600)}h ago"

    return False, age_str, current


def save_prepare_state(project_key, state):
    """Save current state indicators after a successful prepare."""
    state_file = OVERVIEW_CACHE_DIR / f"{project_key}.prepare_state"
    ensure_dir(OVERVIEW_CACHE_DIR)
    try:
        data = {
            'git_head': state.get('git_head'),
            'claude_md_mtime': state.get('claude_md_mtime'),
            'transcript_mtime': state.get('transcript_mtime'),
            'ts': time.time(),
        }
        state_file.write_text(json.dumps(data))
    except OSError:
        pass


