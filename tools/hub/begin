def begin_from_node(project_key, continue_session=False, dry_run=False, use_oi=False):
    """Node-side begin: delegate context to hub, launch OI locally.

    The hub owns all state (caches, journals, overview). The node asks
    the hub to build the preamble via `begin --preamble-only`, then
    launches OI locally with native file access.
    """
    proj = PROJECTS[project_key]

    print()
    header_bar()
    mode = "OI" if use_oi else "NEW SESSION"
    print(f"{BRIGHT_GREEN}  BEGIN — {proj['name']} ({mode}) on {HOSTS.get(LOCAL_HOST, {}).get('name', LOCAL_HOST)}{RESET}")
    header_bar()
    print()

    # Check hub reachability
    print(f"  {WHITE}[1/3]{RESET} Checking hub ({HUB_HOST})...")
    if not check_host_reachable(HUB_HOST):
        print(f"  {RED}● Hub ({HUB_HOST}) unreachable — cannot build context{RESET}")
        sys.exit(1)
    print(f"  {GREEN}● Hub is online{RESET}")

    # Ask hub to build preamble + record session start
    print(f"  {WHITE}[2/3]{RESET} Building context via hub...")
    oi_flag = ' --oi' if use_oi else ''
    ok, preamble = ssh_cmd(HUB_HOST,
        f'~/begin {project_key} --preamble-only{oi_flag}',
        timeout=30)
    if not ok or not preamble:
        print(f"  {YELLOW}● Hub preamble failed — launching without context{RESET}")
        preamble = f"SESSION: {proj['name']} (no hub context available)"

    if dry_run:
        print()
        label = "COMPRESSED PREAMBLE" if use_oi else "PREAMBLE PREVIEW"
        print(f"  {WHITE}--- {label} ({len(preamble)} chars) ---{RESET}")
        print()
        for line in preamble.split('\n'):
            print(f"  {GRAY}{line}{RESET}")
        print()
        header_bar()
        print(f"{GRAY}  Dry run — no session launched{RESET}")
        header_bar()
        return

    # Launch
    print(f"  {WHITE}[3/3]{RESET} Launching...")
    launch_oi(project_key, preamble, continue_session)


def begin(project_key, continue_session=False, dry_run=False, use_oi=False,
          preamble_only=False):
    """Bootstrap a Claude Code (or OI) session with context.

    On a node, delegates to begin_from_node() which calls back to hub.
    The --preamble-only flag outputs raw preamble text to stdout (for nodes
    to capture) and records the session start event, but doesn't launch.
    """
    # Node: use the node-specific flow
    if is_node() and HUB_HOST and not preamble_only:
        begin_from_node(project_key, continue_session, dry_run, use_oi)
        return

    proj = PROJECTS[project_key]
    host_key = proj['host']
    host = HOSTS[host_key]
    host_alias = host['alias']

    if not preamble_only:
        print()
        header_bar()
        mode = "OI" if use_oi else "CONTINUE" if continue_session else "NEW SESSION"
        print(f"{BRIGHT_GREEN}  BEGIN — {proj['name']} ({mode}){RESET}")
        header_bar()
        print()

    # Step 1: Check host
    if not preamble_only:
        print(f"  {WHITE}[1/5]{RESET} Checking {host['name']}...")
    if not check_host_reachable(host_alias):
        if preamble_only:
            sys.exit(1)
        print(f"  {host_offline_msg(host_key, project_key)}")
        sys.exit(1)
    if not preamble_only:
        print(f"  {GREEN}● {host['name']} is online{RESET}")

    # Step 2: Gather context
    if not preamble_only:
        print(f"  {WHITE}[2/5]{RESET} Gathering context...")

    notes_str = fetch_notes(project_key)
    git_str = fetch_git_log(host_alias, proj['path'])

    # Step 3: Load overview cache (local file)
    if not preamble_only:
        print(f"  {WHITE}[3/5]{RESET} Loading overview cache...")
    cache_data = load_overview_cache(project_key)
    if not preamble_only:
        if cache_data:
            print(f"  {GREEN}● Cache loaded{RESET}")
        else:
            print(f"  {YELLOW}● No cache — run {WHITE}prepare {project_key}{YELLOW} for richer context{RESET}")

    # Step 4: Quick environment probe
    if not preamble_only:
        print(f"  {WHITE}[4/5]{RESET} Checking environment...")
    env_status = None
    services = load_services(project_key)
    if services:
        running = sum(1 for svc in services if probe_service(host_alias, svc['port'], timeout=3))
        env_status = f"{running}/{len(services)} services running"
        if not preamble_only:
            color = GREEN if running == len(services) else YELLOW
            print(f"  {color}● {env_status}{RESET}")
    elif not preamble_only:
        print(f"  {GRAY}● No services configured{RESET}")

    # Probe dev services
    dev_svcs = load_dev_services(project_key, enabled_only=True)
    if dev_svcs and not preamble_only:
        dev_running = sum(1 for ds in dev_svcs if probe_service(host_alias, ds['port'], timeout=3))
        dev_color = GREEN if dev_running == len(dev_svcs) else YELLOW
        print(f"  {dev_color}● {dev_running}/{len(dev_svcs)} dev services running{RESET}")

    # Step 5: Build preamble
    if not preamble_only:
        print(f"  {WHITE}[5/5]{RESET} Building preamble...")
    if use_oi:
        preamble = build_compressed_preamble(project_key, cache_data, notes_str, git_str, env_status=env_status)
    else:
        preamble = build_preamble(project_key, cache_data, notes_str, git_str, env_status=env_status)

    # --preamble-only: output preamble to stdout, record session, exit
    if preamble_only:
        # Record session start on hub
        git_head = fetch_git_head(host_alias, proj['path'])
        session_start_event = {
            'ts': time.time(),
            'type': 'session_start',
            'project': project_key,
            'git_head': git_head,
            'mode': 'oi' if use_oi else 'claude',
        }
        if cache_data:
            session_start_event['cache_snapshot'] = {
                'phase': cache_data.get('phase', ''),
                'blockers': cache_data.get('blockers', []),
                'focus': cache_data.get('current_focus', []),
            }
        close_previous_session(project_key)
        append_journal(project_key, [session_start_event])
        # Output raw preamble to stdout (node captures this)
        sys.stdout.write(preamble)
        return

    if dry_run:
        print()
        label = "COMPRESSED PREAMBLE" if use_oi else "PREAMBLE PREVIEW"
        print(f"  {WHITE}--- {label} ({len(preamble)} chars) ---{RESET}")
        print()
        for line in preamble.split('\n'):
            print(f"  {GRAY}{line}{RESET}")
        print()
        header_bar()
        print(f"{GRAY}  Dry run — no session launched{RESET}")
        header_bar()
        return

    # Close previous session (safety net if prepare was skipped)
    closed = close_previous_session(project_key)
    if closed:
        print(f"  {GREEN}● Previous session closed{RESET}")

    # Write session_start event to journal
    git_head = fetch_git_head(host_alias, proj['path'])
    session_start_event = {
        'ts': time.time(),
        'type': 'session_start',
        'project': project_key,
        'git_head': git_head,
        'mode': 'oi' if use_oi else 'claude',
    }
    if cache_data:
        session_start_event['cache_snapshot'] = {
            'phase': cache_data.get('phase', ''),
            'blockers': cache_data.get('blockers', []),
            'focus': cache_data.get('current_focus', []),
        }
    append_journal(project_key, [session_start_event])
    print(f"  {GREEN}● Session start recorded{RESET}")

    if use_oi:
        launch_oi(project_key, preamble, continue_session)
    else:
        # Sanitize preamble for shell (replace double quotes with single quotes)
        safe_preamble = preamble.replace('"', "'")

        # Write preamble to local temp file, SCP to remote
        tmp_local = None
        try:
            with tempfile.NamedTemporaryFile(mode='w', suffix='.txt', delete=False) as f:
                f.write(safe_preamble)
                tmp_local = f.name

            tmp_remote = '/tmp/_begin_ctx.txt'
            scp_result = subprocess.run(
                ['scp', '-o', 'ConnectTimeout=3', '-o', 'BatchMode=yes',
                 tmp_local, f'{host_alias}:{tmp_remote}'],
                capture_output=True, text=True, timeout=10
            )

            if scp_result.returncode != 0:
                print(f"  {RED}● Failed to copy context to {host['name']}{RESET}")
                sys.exit(1)

            print(f"  {GREEN}● Context delivered to {host['name']}{RESET}")

        finally:
            if tmp_local and os.path.exists(tmp_local):
                os.unlink(tmp_local)

        launch_claude(project_key, proj, host, host_alias, continue_session)


