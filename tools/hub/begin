# CLI
# ─────────────────────────────────────────────────────────────────────────────

def print_usage():
    print(f"""
{WHITE}begin{RESET} — Session bootstrap tool

{WHITE}Usage:{RESET}
  begin <project>              New session with context injection
  begin <project> --continue   Continue last session with context
  begin <project> --dry-run    Print preamble only, don't launch
  begin <project> --oi         Launch Open Interpreter instead of Claude Code

{WHITE}What it does:{RESET}
  1. Checks host reachability
  2. Gathers notes + git log
  3. Loads overview cache (from prepare)
  4. Checks environment (service status from registry)
  5. Builds context preamble and launches Claude Code (or OI with --oi)

{WHITE}OI mode:{RESET}
  Uses a compressed preamble (~1500-2000 chars) optimized for OI's smaller context.
  Sets OI_PROJECT, OI_PROJECT_HOST, OI_PROJECT_PATH env vars.
  On a hub: SSHes into the project host and runs OI there (native file access).
  On a node: launches OI locally, fetches context from hub via --preamble-only.

{WHITE}Projects:{RESET}
  {', '.join(PROJECT_ORDER) if PROJECT_ORDER else '(none — run hub --scan first)'}
""")


def main():
    args = sys.argv[1:]

    if '-h' in args or '--help' in args or not args:
        print_usage()
        sys.exit(0)

    continue_session = '--continue' in args or '-c' in args
    dry_run = '--dry-run' in args
    use_oi = '--oi' in args
    preamble_only = '--preamble-only' in args

    clean_args = [a for a in args if a not in ('--continue', '-c', '--dry-run', '--oi', '--preamble-only')]

    if not clean_args:
        print_usage()
        sys.exit(1)

    project_key = resolve_project(clean_args[0])
    if not project_key:
        sys.exit(1)

    begin(project_key, continue_session=continue_session, dry_run=dry_run,
          use_oi=use_oi, preamble_only=preamble_only)


if __name__ == '__main__':
    main()
