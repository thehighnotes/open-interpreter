def launch_claude(project_key, proj, host, host_alias, continue_session):
    """Launch Claude Code on the remote host via SSH."""
    claude_flags = '--append-system-prompt "$(cat /tmp/_begin_ctx.txt)"'
    if continue_session:
        claude_flags = f'-c {claude_flags}'

    ssh_command = f'cd {proj["path"]} && claude {claude_flags}'

    print()
    print(f"  {CYAN}Launching Claude Code on {host['name']}...{RESET}")
    print()

    os.execvp('ssh', [
        'ssh', '-t',
        '-o', 'ConnectTimeout=3',
        '-o', 'StrictHostKeyChecking=no',
        host_alias,
        ssh_command
    ])


def launch_oi(project_key, preamble, continue_session):
    """Launch Open Interpreter with project context.

    Hub role: if the project host IS this machine, launch locally.
              Otherwise SSH into the project host and launch there.
    Node role: always launch locally (we are the project host).
    """
    proj = PROJECTS[project_key]
    host_key = proj['host']
    host_alias = HOSTS[host_key]['alias']

    if continue_session:
        print(f"  {YELLOW}Note: --continue ignored with --oi (OI has no session persistence){RESET}")

    # Write compressed preamble to temp file
    preamble_path = '/tmp/_oi_preamble.txt'
    with open(preamble_path, 'w') as f:
        f.write(preamble)

    # Determine whether to launch locally or remotely
    launch_remote = is_hub() and host_key != LOCAL_HOST

    if launch_remote:
        # Hub launching OI on a remote node — SCP preamble, then SSH in
        print()
        print(f"  {CYAN}Launching Open Interpreter on {HOSTS[host_key]['name']}...{RESET}")
        print()

        # Copy preamble to remote host
        scp_result = subprocess.run(
            ['scp', '-o', 'ConnectTimeout=3', '-o', 'BatchMode=yes',
             preamble_path, f'{host_alias}:/tmp/_oi_preamble.txt'],
            capture_output=True, text=True, timeout=10
        )
        if scp_result.returncode != 0:
            print(f"  {RED}● Failed to copy preamble to {HOSTS[host_key]['name']}{RESET}")
            sys.exit(1)

        # SSH into remote host and launch interpreter there
        # OI_PROJECT_HOST="" signals local file mode (no SSH prefix needed)
        remote_cmd = (
            f'cd {proj["path"]} && '
            f'OI_PROJECT={project_key} '
            f'OI_PROJECT_HOST= '
            f'OI_PROJECT_PATH={proj["path"]} '
            f'OI_HUB_HOST={LOCAL_HOST} '
            f'interpreter --profile linux-admin'
        )
        os.execvp('ssh', [
            'ssh', '-t',
            '-o', 'ConnectTimeout=3',
            '-o', 'StrictHostKeyChecking=no',
            host_alias,
            remote_cmd
        ])
    else:
        # Launch locally — files are local
        os.environ['OI_PROJECT'] = project_key
        os.environ['OI_PROJECT_HOST'] = ''  # empty = files are local
        os.environ['OI_PROJECT_PATH'] = proj['path']
        os.environ['OI_HUB_HOST'] = HUB_HOST or ''

        print()
        print(f"  {CYAN}Launching Open Interpreter (project mode)...{RESET}")
        print()

        os.execvp('interpreter', ['interpreter', '--profile', 'linux-admin'])


