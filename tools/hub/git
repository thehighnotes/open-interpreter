def do_push(key):
    """Push to remote."""
    proj = PROJECTS[key]
    host = proj['host']
    host_alias = HOSTS[host]['alias']
    path = proj['path']

    if not check_host_reachable(host_alias):
        print(f"\n  {RED}● {HOSTS[host]['name']} is offline{RESET}")
        return

    # Check remote
    ok, remote = ssh_cmd(host_alias, f'cd {path} && git remote get-url origin 2>/dev/null', timeout=8)
    if not ok or not remote.strip():
        print(f"\n  {YELLOW}●{RESET} {WHITE}{key}{RESET} has no remote configured")
        print(f"  {GRAY}Run {CYAN}repo create {key}{GRAY} to create a GitHub repo{RESET}")
        return

    # Pre-flight: PAT check
    if not _check_remote_auth(host_alias, path, remote.strip()):
        return

    # Check for upstream tracking
    ok_up, upstream = ssh_cmd(host_alias, f'cd {path} && git rev-parse --abbrev-ref @{{upstream}} 2>/dev/null', timeout=8)
    if not ok_up or not upstream.strip():
        # Need to set upstream
        ok_br, branch = ssh_cmd(host_alias, f'cd {path} && git symbolic-ref --short HEAD 2>/dev/null', timeout=8)
        branch_name = branch.strip() if ok_br and branch.strip() else 'main'
        push_cmd = f'cd {path} && git push -u origin {branch_name}'
    else:
        push_cmd = f'cd {path} && git push'

    with Spinner('Pushing...'):
        ok, stdout, stderr = _ssh_cmd_with_stderr(host_alias, push_cmd, timeout=60)

    output = (stdout + '\n' + stderr).strip()
    if ok:
        print(f"\n  {GREEN}✓{RESET} {WHITE}{key}{RESET} — pushed successfully")
        if output:
            for line in output.split('\n'):
                if line.strip() and ('→' in line or '->' in line or 'branch' in line.lower()):
                    print(f"  {GRAY}{line.strip()}{RESET}")
    else:
        print(f"\n  {RED}✗ Push failed{RESET}")
        if stderr:
            for line in stderr.split('\n')[-5:]:
                if line.strip():
                    print(f"    {RED}{line}{RESET}")
        elif output:
            for line in output.split('\n')[-5:]:
                if line.strip():
                    print(f"    {GRAY}{line}{RESET}")
        print(f"\n  {GRAY}Check SSH/HTTPS auth on {HOSTS[host]['name']}{RESET}")


