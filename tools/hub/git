# CLI
# ─────────────────────────────────────────────────────────────────────────────

USAGE = f"""
{WHITE}repo{RESET} — Unified git management for hub projects

{WHITE}Usage:{RESET}
  repo                           Unified status dashboard
  repo status                    Unified status dashboard (same as bare repo)
  repo status <project>          Detailed status for one project
  repo init <project>            git init + .gitignore + first commit
  repo commit <project> ["msg"]  Stage all + commit (LLM message if omitted)
  repo push <project>            Push to remote
  repo pull <project>            Pull from remote
  repo log <project>             Recent commit log
  repo create <project>          Create GitHub repo + configure remote
  repo checkpoint ["msg"]        Batch commit+push dirty projects (LLM messages)
  repo deploy <project>          Commit + push + restart services + health check
  repo fix <project>             Audit/fix issues (PAT, user config, .gitignore)

{WHITE}Options:{RESET}
  --yes                          Skip confirmation (for checkpoint)
  --help, -h                     This help

{GRAY}Projects: {', '.join(PROJECT_ORDER)}{RESET}
"""


def main():
    args = sys.argv[1:]

    if not args:
        render_dashboard()
        return

    if args[0] in ('-h', '--help'):
        print(USAGE)
        return

    subcmd = args[0]

    if subcmd == 'status':
        if len(args) < 2:
            render_dashboard()
            return
        key = resolve_project(args[1])
        if key:
            render_project_status(key)

    elif subcmd == 'init':
        if len(args) < 2:
            print(f"{RED}Usage: repo init <project>{RESET}")
            return
        key = resolve_project(args[1])
        if key:
            do_init(key)

    elif subcmd == 'commit':
        if len(args) < 2:
            print(f"{RED}Usage: repo commit <project> [\"message\"]{RESET}")
            return
        key = resolve_project(args[1])
        if key:
            message = ' '.join(args[2:]) if len(args) > 2 else None
            do_commit(key, message)

    elif subcmd == 'push':
        if len(args) < 2:
            print(f"{RED}Usage: repo push <project>{RESET}")
            return
        key = resolve_project(args[1])
        if key:
            do_push(key)

    elif subcmd == 'pull':
        if len(args) < 2:
            print(f"{RED}Usage: repo pull <project>{RESET}")
            return
        key = resolve_project(args[1])
        if key:
            do_pull(key)

    elif subcmd == 'log':
        if len(args) < 2:
            print(f"{RED}Usage: repo log <project>{RESET}")
            return
        key = resolve_project(args[1])
        if key:
            do_log(key)

    elif subcmd == 'create':
        if len(args) < 2:
            print(f"{RED}Usage: repo create <project>{RESET}")
            return
        key = resolve_project(args[1])
        if key:
            do_create(key)

    elif subcmd == 'checkpoint':
        message = None
        auto_yes = '--yes' in args
        remaining = [a for a in args[1:] if a != '--yes']
        if remaining:
            message = ' '.join(remaining)
        do_checkpoint(message, auto_yes)

    elif subcmd == 'deploy':
        if len(args) < 2:
            print(f"{RED}Usage: repo deploy <project>{RESET}")
            return
        key = resolve_project(args[1])
        if key:
            do_deploy(key)

    elif subcmd == 'fix':
        if len(args) < 2:
            print(f"{RED}Usage: repo fix <project>{RESET}")
            return
        key = resolve_project(args[1])
        if key:
            do_fix(key)

    else:
        # Maybe it's a project name for quick status
        key = resolve_project(subcmd)
        if key:
            render_project_status(key)
        else:
            print(USAGE)


if __name__ == '__main__':
    main()
