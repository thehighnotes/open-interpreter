def _probe_all_hosts():
    """Probe reachability of all unique hosts. Returns {host_key: bool}."""
    hosts = set()
    for pk in PROJECT_ORDER:
        hosts.add(PROJECTS[pk]['host'])
    return run_parallel({h: (lambda h=h: check_host_reachable(h)) for h in hosts})


def _fetch_all_status(host_reachable):
    """Fetch git status for all projects, one SSH call per host.

    Returns {project_key: status_dict}.
    """
    # Group projects by host
    by_host = {}
    for pk in PROJECT_ORDER:
        proj = PROJECTS[pk]
        host = proj['host']
        by_host.setdefault(host, []).append((pk, proj))

    # Fetch in parallel per host
    tasks = {}
    for host, entries in by_host.items():
        if host_reachable.get(host, False):
            tasks[host] = (lambda h=host, e=entries: fetch_git_status_batch(h, e))

    results = run_parallel(tasks) if tasks else {}

    # Flatten into per-project dict
    all_status = {}
    for host, host_results in results.items():
        if isinstance(host_results, dict):
            all_status.update(host_results)
    return all_status


def render_dashboard():
    """Render unified git status dashboard."""
    now = datetime.now().strftime('%a %d %b %H:%M')

    with Spinner('Probing hosts...'):
        host_reachable = _probe_all_hosts()

    with Spinner('Fetching git status...'):
        all_status = _fetch_all_status(host_reachable)

    print()
    header_bar()
    print_right(f"{BRIGHT_GREEN}  GIT STATUS{RESET}", f"{BRIGHT_GREEN}{now}{RESET}")
    header_bar()
    print()

    # Table header
    print(f"  {GRAY}{'Project':<14s}{'Branch':<10s}{'Dirty':>6s}{'Commits':>9s}  {'Remote':<28s}{'Host':<5s}{RESET}")
    print(f"  {GRAY}{'─' * 74}{RESET}")

    warnings = []

    for pk in PROJECT_ORDER:
        proj = PROJECTS[pk]
        host_name = HOSTS[proj['host']]['alias'].upper()
        st = all_status.get(pk)

        if not host_reachable.get(proj['host'], False):
            print(f"  {DIM}{pk:<14s}{'—':<10s}{'—':>6s}{'—':>9s}  {'—':<28s}{host_name:<5s}{RESET}  {YELLOW}offline{RESET}")
            continue

        if not st or not st.get('is_git'):
            print(f"  {DIM}{pk:<14s}{'—':<10s}{'—':>6s}{'—':>9s}  {'—':<28s}{host_name:<5s}{RESET}")
            if st is not None:
                # Directory exists but not a git repo
                warnings.append(f"  {GRAY}●{RESET} {WHITE}{pk}{RESET}: not a git repo — run {CYAN}repo init {pk}{RESET}")
            continue

        branch = st.get('branch', '—') or '—'
        dirty = st.get('dirty', 0) + st.get('untracked', 0)
        commits = st.get('commits', 0)
        remote_url = st.get('remote_url', '')
        has_pat = st.get('has_pat', False)
        ahead = st.get('ahead', 0)
        behind = st.get('behind', 0)

        # Format remote display
        if remote_url:
            repo_short = extract_github_repo(remote_url)
            if repo_short:
                # Truncate if too long
                if len(repo_short) > 26:
                    repo_short = '...' + repo_short[-(26 - 3):]
                remote_display = repo_short
            else:
                remote_display = sanitize_remote_url(remote_url)[:26]
        else:
            remote_display = '—'

        # Color coding
        branch_str = f"{WHITE}{branch:<10s}{RESET}" if branch != '—' else f"{DIM}{'—':<10s}{RESET}"
        dirty_str = f"{YELLOW}{dirty:>6d}{RESET}" if dirty > 0 else f"{GREEN}{'0':>6s}{RESET}"
        commits_str = f"{WHITE}{commits:>9d}{RESET}" if commits > 0 else f"{DIM}{'0':>9s}{RESET}"
        remote_str = f"{GRAY}{remote_display:<28s}{RESET}" if remote_display != '—' else f"{DIM}{'—':<28s}{RESET}"

        # Suffix indicators
        suffix_parts = []
        if has_pat:
            suffix_parts.append(f"{RED}PAT{RESET}")
        if isinstance(ahead, int) and ahead > 0:
            suffix_parts.append(f"{CYAN}↑{ahead}{RESET}")
        if isinstance(behind, int) and behind > 0:
            suffix_parts.append(f"{YELLOW}↓{behind}{RESET}")
        deploy_state = read_deploy_state(pk)
        if deploy_state and st.get('head') and deploy_state.get('head') != st.get('head'):
            suffix_parts.append(f"{YELLOW}stale{RESET}")
        suffix = '  ' + ' '.join(suffix_parts) if suffix_parts else ''

        print(f"  {WHITE}{pk:<14s}{RESET}{branch_str}{dirty_str}{commits_str}  {remote_str}{host_name:<5s}{suffix}")

        # Collect warnings
        if has_pat:
            warnings.append(f"  {RED}!{RESET} {WHITE}{pk}{RESET}: PAT token in remote URL — run {CYAN}repo fix {pk}{RESET}")
        if commits == 0 and st['is_git']:
            warnings.append(f"  {GRAY}●{RESET} {WHITE}{pk}{RESET}: initialized but no commits — run {CYAN}repo init {pk}{RESET}")
        if not remote_url and commits > 0:
            warnings.append(f"  {GRAY}●{RESET} {WHITE}{pk}{RESET}: no remote — run {CYAN}repo create {pk}{RESET}")

    if warnings:
        print()
        print(f"  {WHITE}Warnings:{RESET}")
        for w in warnings:
            print(w)

    print()
    header_bar()


