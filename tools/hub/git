def _guess_languages(host_alias, path):
    """Detect project language(s) by file presence. Returns set of strings."""
    cmd = (
        f'cd {path} 2>/dev/null && '
        f'echo "PY:$(find . -maxdepth 3 -name "*.py" 2>/dev/null | head -1)" && '
        f'echo "JS:$(find . -maxdepth 3 \\( -name "*.js" -o -name "*.ts" -o -name "*.tsx" \\) 2>/dev/null | head -1)" && '
        f'echo "PKG:$([ -f package.json ] && echo yes || echo no)" && '
        f'echo "REQ:$([ -f requirements.txt ] && echo yes || echo no)"'
    )
    ok, output = ssh_cmd(host_alias, cmd, timeout=10)
    langs = set()
    if ok:
        for line in output.split('\n'):
            if line.startswith('PY:') and line[3:].strip():
                langs.add('python')
            elif line.startswith('JS:') and line[3:].strip():
                langs.add('js')
            elif line.startswith('PKG:yes'):
                langs.add('js')
            elif line.startswith('REQ:yes'):
                langs.add('python')
    return langs if langs else {'python'}  # default


def _build_gitignore(languages):
    """Build .gitignore content from detected languages."""
    parts = [GITIGNORE_COMMON.strip()]
    if 'python' in languages:
        parts.append(GITIGNORE_PYTHON.strip())
    if 'js' in languages:
        parts.append(GITIGNORE_JS.strip())
    parts.append(GITIGNORE_DATA.strip())
    return '\n\n'.join(parts) + '\n'


