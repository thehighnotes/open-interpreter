def render_project_status(key):
    """Detailed git status for a single project."""
    proj = PROJECTS[key]
    host = proj['host']
    host_alias = HOSTS[host]['alias']

    if not check_host_reachable(host_alias):
        print(f"\n  {RED}● {HOSTS[host]['name']} is offline{RESET}")
        return

    # Get detailed status with a richer SSH command
    cmd = f'''cd {proj['path']} 2>/dev/null || {{ echo "NO_DIR"; exit 1; }}
if [ ! -d .git ]; then echo "NOT_GIT"; exit 0; fi
echo "===BASIC==="
echo "BRANCH:$(git symbolic-ref --short HEAD 2>/dev/null || echo 'detached')"
echo "HEAD:$(git rev-parse --short HEAD 2>/dev/null)"
echo "COMMITS:$(git rev-list --count HEAD 2>/dev/null || echo '0')"
echo "REMOTE:$(git remote get-url origin 2>/dev/null || echo '')"
echo "===USER==="
echo "NAME:$(git config user.name 2>/dev/null)"
echo "EMAIL:$(git config user.email 2>/dev/null)"
echo "===STATUS==="
git status --porcelain 2>/dev/null | head -30
echo "===LOG==="
git log --oneline -5 2>/dev/null
echo "===GITIGNORE==="
[ -f .gitignore ] && echo "EXISTS" || echo "MISSING"
echo "===STASH==="
git stash list 2>/dev/null | wc -l | tr -d ' '
'''
    ok, output = ssh_cmd(host_alias, cmd, timeout=15)
    if not ok:
        print(f"\n  {RED}Failed to query {HOSTS[host]['name']}{RESET}")
        return

    if 'NO_DIR' in output:
        print(f"\n  {RED}Directory not found: {proj['path']}{RESET}")
        return

    if 'NOT_GIT' in output:
        print(f"\n  {YELLOW}{proj['name']}{RESET} ({key}) — {DIM}not a git repository{RESET}")
        print(f"  {GRAY}Run {CYAN}repo init {key}{GRAY} to initialize{RESET}")
        return

    # Parse sections
    sections = {}
    current_section = None
    for line in output.split('\n'):
        if line.startswith('===') and line.endswith('==='):
            current_section = line.strip('= ')
            sections[current_section] = []
        elif current_section:
            sections.setdefault(current_section, []).append(line)

    # Extract fields
    basic = {}
    for line in sections.get('BASIC', []):
        if ':' in line:
            k, v = line.split(':', 1)
            basic[k] = v.strip()

    user = {}
    for line in sections.get('USER', []):
        if ':' in line:
            k, v = line.split(':', 1)
            user[k] = v.strip()

    status_lines = [l for l in sections.get('STATUS', []) if l.strip()]
    log_lines = [l for l in sections.get('LOG', []) if l.strip()]
    gitignore = 'EXISTS' in '\n'.join(sections.get('GITIGNORE', []))
    stash_count = 0
    for line in sections.get('STASH', []):
        if line.strip().isdigit():
            stash_count = int(line.strip())

    remote_url = basic.get('REMOTE', '')
    has_pat = bool(remote_url and 'ghp_' in remote_url)

    print()
    header_bar()
    print(f"  {BRIGHT_GREEN}{proj['name']}{RESET}  {GRAY}({key}){RESET}")
    print(f"  {GRAY}{HOSTS[host]['name']}:{proj['path']}{RESET}")
    header_bar()

    # Branch & head
    branch = basic.get('BRANCH', '?')
    head = basic.get('HEAD', '?')
    commits = basic.get('COMMITS', '?')
    print(f"\n  {WHITE}Branch{RESET}     {CYAN}{branch}{RESET}  @{head}  ({commits} commits)")

    # Remote
    if remote_url:
        display_url = sanitize_remote_url(remote_url)
        repo = extract_github_repo(remote_url)
        if has_pat:
            print(f"  {WHITE}Remote{RESET}     {display_url}  {RED}! PAT token{RESET}")
        else:
            print(f"  {WHITE}Remote{RESET}     {display_url}")
        if repo:
            print(f"  {WHITE}GitHub{RESET}     {repo}")
    else:
        print(f"  {WHITE}Remote{RESET}     {DIM}none{RESET}")

    # User config
    uname = user.get('NAME', '')
    uemail = user.get('EMAIL', '')
    if uname or uemail:
        print(f"  {WHITE}User{RESET}       {uname} <{uemail}>")

    # Gitignore
    print(f"  {WHITE}.gitignore{RESET} {GREEN}present{RESET}" if gitignore else f"  {WHITE}.gitignore{RESET} {YELLOW}missing{RESET}")

    # Stash
    if stash_count > 0:
        print(f"  {WHITE}Stash{RESET}      {stash_count} entries")

    # Dirty files
    modified = [l for l in status_lines if l and not l.startswith('?')]
    untracked = [l for l in status_lines if l and l.startswith('?')]
    total_dirty = len(modified) + len(untracked)
    if total_dirty > 0:
        print(f"\n  {WHITE}Working tree{RESET}  {YELLOW}{total_dirty} dirty{RESET} ({len(modified)} modified, {len(untracked)} untracked)")
        for line in status_lines[:15]:
            print(f"    {GRAY}{line}{RESET}")
        if len(status_lines) > 15:
            print(f"    {DIM}... and {len(status_lines) - 15} more{RESET}")
    else:
        print(f"\n  {WHITE}Working tree{RESET}  {GREEN}clean{RESET}")

    # Recent log
    if log_lines:
        print(f"\n  {WHITE}Recent commits{RESET}")
        for line in log_lines:
            print(f"    {GRAY}{line}{RESET}")

    # Suggestions
    suggestions = []
    if has_pat:
        suggestions.append(f"repo fix {key}     — remove PAT from remote URL")
    if not gitignore:
        suggestions.append(f"repo fix {key}     — generate .gitignore")
    if not remote_url and int(basic.get('COMMITS', '0')) > 0:
        suggestions.append(f"repo create {key}  — create GitHub repo + remote")
    if total_dirty > 0:
        suggestions.append(f"repo commit {key}  — commit changes")

    if suggestions:
        print(f"\n  {WHITE}Suggestions{RESET}")
        for s in suggestions:
            print(f"    {CYAN}{s}{RESET}")

    print()
    header_bar()


