# ─────────────────────────────────────────────────────────────────────────────

def do_log(key):
    """Show recent commit log with subject + body."""
    proj = PROJECTS[key]
    host = proj['host']
    host_alias = HOSTS[host]['alias']
    path = proj['path']

    if not check_host_reachable(host_alias):
        print(f"\n  {RED}● {HOSTS[host]['name']} is offline{RESET}")
        return

    # Format: hash, relative date, subject, body (separated by markers)
    fmt = '===COMMIT===%n%C(auto)%h %C(dim)%ar%C(reset)%n%s%n%b'
    ok, output = ssh_cmd(host_alias,
        f'cd {path} && git log --reverse --format="{fmt}" -15 2>/dev/null',
        timeout=10)

    if not ok or not output.strip():
        print(f"\n  {YELLOW}●{RESET} {WHITE}{key}{RESET} — no git log available")
        return

    print(f"\n  {WHITE}{proj['name']}{RESET}  {GRAY}({key}){RESET}")

    commits = output.split('===COMMIT===')
    for block in commits:
        block = block.strip()
        if not block:
            continue
        lines = block.split('\n')
        if len(lines) < 2:
            continue
        # Line 0: hash + relative date, Line 1: subject, Line 2+: body
        header = lines[0].strip()
        subject = lines[1].strip() if len(lines) > 1 else ''
        body_lines = [l.strip() for l in lines[2:] if l.strip()]

        print(f"\n  {CYAN}{header}{RESET}")
        print(f"  {WHITE}{subject}{RESET}")
        for bl in body_lines:
            print(f"    {GRAY}{bl}{RESET}")

    print()


