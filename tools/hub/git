# ─────────────────────────────────────────────────────────────────────────────

def do_create(key):
    """Create GitHub repo via WS gh CLI and configure remote on project host."""
    proj = PROJECTS[key]
    host = proj['host']
    host_alias = HOSTS[host]['alias']
    path = proj['path']

    if not check_host_reachable(host_alias):
        print(f"\n  {RED}● {HOSTS[host]['name']} is offline{RESET}")
        return

    # Check WS is reachable (needed for gh CLI)
    if not check_host_reachable('ws'):
        print(f"\n  {RED}● Workstation is offline — needed for GitHub CLI{RESET}")
        print(f"  {GRAY}Wake it with {WHITE}wake-ws{RESET}")
        return

    # Check current state
    ok, remote = ssh_cmd(host_alias, f'cd {path} && git remote get-url origin 2>/dev/null', timeout=8)
    if ok and remote.strip():
        repo = extract_github_repo(remote.strip())
        print(f"\n  {YELLOW}●{RESET} {WHITE}{key}{RESET} already has a remote: {repo or remote.strip()}")
        return

    # Check it's a git repo
    ok, git_check = ssh_cmd(host_alias, f'cd {path} && [ -d .git ] && echo GIT || echo NOGIT', timeout=8)
    if 'NOGIT' in (git_check or ''):
        print(f"\n  {RED}{key} is not a git repo — run {CYAN}repo init {key}{RED} first{RESET}")
        return

    # Derive repo name
    default_name = key
    try:
        name = input(f"\n  GitHub repo name [{WHITE}{default_name}{RESET}]: ").strip() or default_name
    except (EOFError, KeyboardInterrupt):
        print()
        return

    tagline = proj.get('tagline', '')
    safe_tagline = tagline.replace('"', '\\"') if tagline else ''

    # Confirm
    print(f"\n  {WHITE}Will create:{RESET}")
    print(f"    Repository: {CYAN}{GITHUB_USERNAME}/{name}{RESET}")
    print(f"    Visibility: {WHITE}private{RESET}")
    if tagline:
        print(f"    Description: {GRAY}{tagline}{RESET}")
    print(f"    Remote on:  {HOSTS[host]['name']} ({path})")

    try:
        confirm = input(f"\n  Proceed? (Y/n): ").strip().lower() or 'y'
    except (EOFError, KeyboardInterrupt):
        print()
        return

    if confirm not in ('y', 'yes'):
        print(f"  {GRAY}Cancelled{RESET}")
        return

    # Create repo via WS
    desc_flag = f' -d "{safe_tagline}"' if tagline else ''
    gh_cmd = f'gh repo create {GITHUB_USERNAME}/{name} --private{desc_flag} --confirm 2>&1'

    with Spinner('Creating GitHub repo via WS...'):
        ok, output = ssh_cmd('ws', gh_cmd, timeout=30)

    if not ok:
        # gh might not have --confirm flag in older versions, try without
        gh_cmd_alt = f'gh repo create {GITHUB_USERNAME}/{name} --private{desc_flag} 2>&1'
        ok, output = ssh_cmd('ws', gh_cmd_alt, timeout=30)

    if not ok:
        print(f"\n  {RED}✗ Failed to create GitHub repo{RESET}")
        if output:
            for line in output.split('\n')[-3:]:
                if line.strip():
                    print(f"    {GRAY}{line}{RESET}")
        return

    # Check if repo was created or already exists
    if 'already exists' in output.lower():
        print(f"\n  {YELLOW}●{RESET} Repository {GITHUB_USERNAME}/{name} already exists")
    else:
        print(f"\n  {GREEN}✓{RESET} Created {GITHUB_USERNAME}/{name}")

    # Configure remote on the project's host
    # First check if SSH auth works on that host
    ok_ssh, ssh_out = ssh_cmd(host_alias, 'ssh -T -o BatchMode=yes -o ConnectTimeout=5 git@github.com 2>&1 || true', timeout=15)
    github_ssh_ok = 'successfully authenticated' in (ssh_out or '').lower()

    if github_ssh_ok:
        remote_url = f'git@github.com:{GITHUB_USERNAME}/{name}.git'
        print(f"  {GREEN}✓{RESET} SSH auth works on {HOSTS[host]['name']} — using SSH URL")
    else:
        remote_url = f'https://github.com/{GITHUB_USERNAME}/{name}.git'
        print(f"  {YELLOW}●{RESET} No SSH auth on {HOSTS[host]['name']} — using HTTPS URL")
        print(f"  {GRAY}Set up SSH key on {HOSTS[host]['name']} for push access:{RESET}")
        print(f"    {DIM}ssh-keygen -t ed25519 && cat ~/.ssh/id_ed25519.pub{RESET}")
        print(f"    {DIM}Then add to github.com/settings/keys{RESET}")

    # Add remote
    ok, output = ssh_cmd(host_alias, f'cd {path} && git remote add origin {remote_url}', timeout=10)
    if not ok:
        # Maybe origin already exists with different URL
        ssh_cmd(host_alias, f'cd {path} && git remote set-url origin {remote_url}', timeout=10)

    # Push
    ok_br, branch = ssh_cmd(host_alias, f'cd {path} && git symbolic-ref --short HEAD 2>/dev/null', timeout=8)
    branch_name = branch.strip() if ok_br and branch.strip() else 'main'

    with Spinner('Pushing to GitHub...'):
        ok, stdout, stderr = _ssh_cmd_with_stderr(host_alias, f'cd {path} && git push -u origin {branch_name}', timeout=60)

    if ok:
        print(f"  {GREEN}✓{RESET} Pushed to {GITHUB_USERNAME}/{name}")
    else:
        print(f"  {YELLOW}●{RESET} Push may require auth setup — try manually:")
        print(f"    {DIM}cd {path} && git push -u origin {branch_name}{RESET}")
        if stderr:
            for line in stderr.split('\n')[-3:]:
                if line.strip():
                    print(f"    {RED}{line.strip()}{RESET}")

    # Update projects.json
    projects, order, ignored = load_projects()
    if key in projects:
        projects[key]['git_remote'] = f'{GITHUB_USERNAME}/{name}'
        projects[key]['git_branch'] = branch_name
        save_projects(projects, order, ignored)
        reload_projects()
        print(f"  {GREEN}✓{RESET} Updated projects.json")

    print()


# ─────────────────────────────────────────────────────────────────────────────
# repo checkpoint ["msg"]
# ─────────────────────────────────────────────────────────────────────────────

def do_checkpoint(message=None, auto_yes=False):
    """Batch commit+push all dirty projects that have remotes."""
    now = datetime.now().strftime('%Y-%m-%d %H:%M')
    user_message = message  # Explicit message from CLI

    with Spinner('Probing hosts...'):
        host_reachable = _probe_all_hosts()

    with Spinner('Fetching git status...'):
        all_status = _fetch_all_status(host_reachable)

    # Filter: is_git + dirty > 0
    candidates = []
    for pk in PROJECT_ORDER:
        st = all_status.get(pk)
        if not st:
            continue
        if not st.get('is_git'):
            continue
        dirty = st.get('dirty', 0) + st.get('untracked', 0)
        if dirty == 0:
            continue
        has_remote = bool(st.get('remote_url'))
        candidates.append((pk, st, dirty, has_remote))

    if not candidates:
        print(f"\n  {GREEN}✓{RESET} All projects clean — nothing to checkpoint")
        return

    # Batch pre-flight: check index.lock + large files (one SSH call per host)
    blocked = set()
    by_host = {}
    for pk, st, dirty, has_remote in candidates:
        proj = PROJECTS[pk]
        host = proj['host']
        by_host.setdefault(host, []).append((pk, proj))

    for host, entries in by_host.items():
        host_alias = HOSTS[host]['alias']
        # Build combined check command
        check_parts = []
        for pk, proj in entries:
            p = proj['path']
            check_parts.append(
                f'echo "===PREFLIGHT:{pk}===" && '
                f'cd {p} 2>/dev/null && '
                f'{{ [ -f .git/index.lock ] && echo "LOCK:$(stat -c %Y .git/index.lock 2>/dev/null)" || echo "LOCK:NONE"; }} && '
                f'{{ git status --porcelain 2>/dev/null | sed "s/^...//" | '
                f'while IFS= read -r f; do '
                f'[ -f "$f" ] && s=$(stat -c %s "$f" 2>/dev/null) && '
                f'[ "$s" -gt 99614720 ] && echo "LARGE:$s $f"; '
                f'done; echo "LARGE_DONE"; }}'
            )
        combined = ' && '.join(check_parts)
        ok, output = ssh_cmd(host_alias, combined, timeout=20)
        if not ok:
            continue

        # Parse results per project
        current_pk = None
        for line in (output or '').split('\n'):
            if line.startswith('===PREFLIGHT:') and line.endswith('==='):
                current_pk = line[len('===PREFLIGHT:'):-len('===')]
            elif current_pk and line.startswith('LOCK:') and line != 'LOCK:NONE':
                try:
                    import time as _time
                    lock_mtime = int(line.split(':')[1])
                    age = int(_time.time()) - lock_mtime
                    if auto_yes:
                        if age >= 10:
                            # Auto-remove stale locks in --yes mode
                            proj = PROJECTS[current_pk]
                            ssh_cmd(host_alias, f'rm -f {proj["path"]}/.git/index.lock', timeout=5)
                            print(f"  {YELLOW}●{RESET} {current_pk}: removed stale index.lock (age {age}s)")
                        else:
                            blocked.add(current_pk)
                            print(f"  {YELLOW}●{RESET} {current_pk}: index.lock (age {age}s) — skipped")
                    else:
                        blocked.add(current_pk)
                        print(f"  {YELLOW}●{RESET} {current_pk}: index.lock found (age {age}s) — skipped")
                except (ValueError, IndexError):
                    pass
            elif current_pk and line.startswith('LARGE:'):
                parts = line[6:].strip().split(' ', 1)
                if len(parts) == 2:
                    try:
                        size_mb = int(parts[0]) / (1024 * 1024)
                        blocked.add(current_pk)
                        print(f"  {RED}!{RESET} {current_pk}: large file {parts[1]} ({size_mb:.0f}MB) — skipped")
                    except ValueError:
                        pass

    # Also check for HTTPS remotes without credentials (will fail on push)
    for pk, st, dirty, has_remote in candidates:
        if pk in blocked or not has_remote:
            continue
        remote_url = st.get('remote_url', '')
        if remote_url.startswith('https://') and not remote_url.startswith('git@'):
            repo = extract_github_repo(remote_url)
            if repo:
                proj = PROJECTS[pk]
                host_alias = HOSTS[proj['host']]['alias']
                # Quick check: does this host have SSH auth?
                ok_ssh, ssh_out = ssh_cmd(host_alias,
                    'ssh -T -o BatchMode=yes -o ConnectTimeout=5 git@github.com 2>&1 || true',
                    timeout=15)
                if 'successfully authenticated' in (ssh_out or '').lower():
                    # Auto-fix: switch to SSH
                    new_url = f'git@github.com:{repo}.git'
                    ssh_cmd(host_alias, f'cd {proj["path"]} && git remote set-url origin {new_url}', timeout=10)
                    print(f"  {GREEN}✓{RESET} {pk}: switched remote to SSH ({new_url})")
                else:
                    blocked.add(pk)
                    print(f"  {YELLOW}●{RESET} {pk}: HTTPS remote without credentials — skipped")

    targets = [(pk, st, dirty, hr) for pk, st, dirty, hr in candidates if pk not in blocked]

    if not targets:
        if blocked:
            print(f"\n  {YELLOW}●{RESET} All dirty projects blocked by pre-flight checks")
        else:
            print(f"\n  {GREEN}✓{RESET} All projects clean — nothing to checkpoint")
        return

    # Generate LLM commit messages (unless user provided one)
    commit_msgs = {}
    if not user_message:
        with Spinner('Generating commit messages...'):
            for pk, st, dirty, has_remote in targets:
                proj = PROJECTS[pk]
                host_alias = HOSTS[proj['host']]['alias']
                path = proj['path']
                generated = _generate_commit_msg(host_alias, path)
                commit_msgs[pk] = generated or f'checkpoint: {now}'
    else:
        for pk, st, dirty, has_remote in targets:
            commit_msgs[pk] = user_message

    # Display
    print(f"\n  {WHITE}Checkpoint:{RESET} {CYAN}{now}{RESET}\n")
    for pk, st, dirty, has_remote in targets:
        proj = PROJECTS[pk]
        msg_preview = commit_msgs[pk].split('\n')[0]
        if len(msg_preview) > 50:
            msg_preview = msg_preview[:47] + '...'
        suffix = '' if has_remote else f'  {GRAY}(no remote — commit only){RESET}'
        print(f"  {YELLOW}●{RESET} {WHITE}{pk:<14s}{RESET} {dirty:>4d} dirty  {DIM}→ {msg_preview}{RESET}{suffix}")

    if not auto_yes:
        print(f"\n    {CYAN}[a]{RESET}ll  {CYAN}[s]{RESET}elect  {CYAN}[e]{RESET}dit messages  {CYAN}[q]{RESET}uit")
        try:
            choice = input(f"    Choice [a]: ").strip().lower() or 'a'
        except (EOFError, KeyboardInterrupt):
            print()
            return

        if choice in ('q', 'quit'):
            print(f"  {GRAY}Cancelled{RESET}")
            return

        if choice in ('s', 'select'):
            # Per-project toggle — all start included, space to exclude
            toggle_items = [{'pk': pk, 'dirty': dirty, 'included': True}
                            for pk, st, dirty, has_remote in targets]

            def _cp_render(item, idx, highlighted):
                inc = f"{GREEN}[+]{RESET}" if item['included'] else f"{GRAY}[ ]{RESET}"
                hl_start = HIGHLIGHT_BG if highlighted else ''
                hl_end = HIGHLIGHT_OFF if highlighted else ''
                return f"    {inc} {hl_start}{item['pk']:<14s} {item['dirty']:>4d} dirty{hl_end}"

            print()
            saved = interactive_toggle(
                toggle_items, _cp_render,
                get_state=lambda item: item['included'],
                set_state=lambda item, v: item.__setitem__('included', v),
                title=f"    {WHITE}Select projects{RESET}  {GRAY}— space=toggle  enter=confirm  q=cancel{RESET}",
            )
            if not saved:
                print(f"  {GRAY}Cancelled{RESET}")
                return
            included = {item['pk'] for item in toggle_items if item['included']}
            targets = [t for t in targets if t[0] in included]
            if not targets:
                print(f"  {GRAY}All excluded — cancelled{RESET}")
                return

        elif choice in ('e', 'edit'):
            # Edit messages per-project
            print()
            for pk, st, dirty, has_remote in targets:
                current = commit_msgs[pk].split('\n')[0]
                try:
                    edited = input(f"    {WHITE}{pk}{RESET} [{current}]: ").strip()
                except (EOFError, KeyboardInterrupt):
                    print()
                    return
                if edited:
                    commit_msgs[pk] = edited

        elif choice not in ('a', 'all', 'y', 'yes'):
            print(f"  {GRAY}Cancelled{RESET}")
            return

    print()
    success = 0
    failed = 0

    for pk, st, dirty, has_remote in targets:
        proj = PROJECTS[pk]
        host_alias = HOSTS[proj['host']]['alias']
        path = proj['path']
        msg = commit_msgs[pk]

        sys.stderr.write(f"\r  {CYAN}●{RESET} {pk}...")
        sys.stderr.flush()

        ok, output = _ssh_commit(host_alias, path, msg, timeout=60)

        if ok and has_remote:
            remote_url = st.get('remote_url', '')
            ok_push, stdout_push, stderr_push = _ssh_cmd_with_stderr(
                host_alias, f'cd {path} && git push', timeout=60)
            if not ok_push:
                ok = False
                output = stderr_push or stdout_push or 'Push failed'

        action = 'committed + pushed' if has_remote else 'committed'
        if ok:
            sys.stderr.write(f"\r  {GREEN}✓{RESET} {WHITE}{pk:<14s}{RESET} {action} ({dirty} files)\n")
            success += 1
        else:
            sys.stderr.write(f"\r  {RED}✗{RESET} {WHITE}{pk:<14s}{RESET} failed\n")
            if output:
                last_line = [l for l in output.split('\n') if l.strip()]
                if last_line:
                    sys.stderr.write(f"    {GRAY}{last_line[-1].strip()}{RESET}\n")
            failed += 1

    print(f"\n  {GREEN}{success}/{len(targets)} projects checkpointed{RESET}" + (f"  {RED}{failed} failed{RESET}" if failed else ''))


# ─────────────────────────────────────────────────────────────────────────────
# repo fix <project>
# ─────────────────────────────────────────────────────────────────────────────

def do_fix(key):
    """Audit and fix common git issues."""
    proj = PROJECTS[key]
    host = proj['host']
    host_alias = HOSTS[host]['alias']
    path = proj['path']

    if not check_host_reachable(host_alias):
        print(f"\n  {RED}● {HOSTS[host]['name']} is offline{RESET}")
        return

    # Gather info
    cmd = f'''cd {path} 2>/dev/null || {{ echo "NO_DIR"; exit 1; }}
[ -d .git ] || {{ echo "NOT_GIT"; exit 0; }}
echo "REMOTE:$(git remote get-url origin 2>/dev/null || echo '')"
echo "NAME:$(git config user.name 2>/dev/null || echo '')"
echo "EMAIL:$(git config user.email 2>/dev/null || echo '')"
echo "GITIGNORE:$([ -f .gitignore ] && echo EXISTS || echo MISSING)"
'''
    ok, output = ssh_cmd(host_alias, cmd, timeout=10)
    if not ok or 'NO_DIR' in (output or ''):
        print(f"\n  {RED}Cannot access {key}{RESET}")
        return
    if 'NOT_GIT' in (output or ''):
        print(f"\n  {YELLOW}{key} is not a git repo{RESET}")
        return

    info = {}
    for line in output.split('\n'):
        if ':' in line:
            k, v = line.split(':', 1)
            info[k.strip()] = v.strip()

    remote = info.get('REMOTE', '')
    user_name = info.get('NAME', '')
    user_email = info.get('EMAIL', '')
    has_gitignore = info.get('GITIGNORE', '') == 'EXISTS'

    issues = []
    fixes_applied = 0

    print(f"\n  {WHITE}Auditing {proj['name']}{RESET}  {GRAY}({key}){RESET}\n")

    # Issue 1: Remote URL issues (PAT token or bare HTTPS without credentials)
    has_pat = remote and any(tok in remote for tok in ('ghp_', 'gho_', 'github_pat_'))
    is_bare_https = remote and remote.startswith('https://') and not has_pat
    repo = extract_github_repo(remote) if remote else None

    if has_pat:
        print(f"  {RED}!{RESET} PAT token in remote URL")
        print(f"    {GRAY}Current: {sanitize_remote_url(remote)}{RESET}")
    elif is_bare_https and repo:
        # Check if credential helper exists
        ok_cred, cred_out = ssh_cmd(host_alias, 'git config --global credential.helper 2>/dev/null', timeout=5)
        if not (ok_cred and cred_out.strip()):
            print(f"  {YELLOW}●{RESET} HTTPS remote without credentials (push will fail)")
            print(f"    {GRAY}Current: {remote}{RESET}")
        else:
            is_bare_https = False  # has credential helper, it's fine

    if (has_pat or is_bare_https) and repo:
        ok_ssh, ssh_out = ssh_cmd(host_alias, 'ssh -T -o BatchMode=yes -o ConnectTimeout=5 git@github.com 2>&1 || true', timeout=15)
        github_ssh_ok = 'successfully authenticated' in (ssh_out or '').lower()

        if github_ssh_ok:
            new_url = f'git@github.com:{repo}.git'
            label = 'SSH'
        elif has_pat:
            new_url = f'https://github.com/{repo}.git'
            label = 'HTTPS (no PAT)'
        else:
            new_url = None

        if new_url:
            try:
                fix = input(f"    Switch to {label}? ({new_url}) (Y/n): ").strip().lower() or 'y'
            except (EOFError, KeyboardInterrupt):
                fix = 'n'
                print()

            if fix in ('y', 'yes'):
                ok_fix, _ = ssh_cmd(host_alias, f"cd {path} && git remote set-url origin {new_url}", timeout=10)
                if ok_fix:
                    print(f"    {GREEN}✓{RESET} Remote updated to {new_url}")
                    fixes_applied += 1
                else:
                    print(f"    {RED}✗ Failed to update remote{RESET}")
        elif not github_ssh_ok:
            print(f"    {GRAY}Set up SSH key on {HOSTS[host]['name']} for push access:{RESET}")
            print(f"      {DIM}ssh-keygen -t ed25519 && cat ~/.ssh/id_ed25519.pub{RESET}")
    elif remote and not has_pat and not is_bare_https:
        print(f"  {GREEN}✓{RESET} Remote URL clean")
    elif not remote:
        print(f"  {YELLOW}●{RESET} No remote configured")
        print(f"    {GRAY}Run {CYAN}repo create {key}{GRAY} to set up GitHub{RESET}")

    # Issue 2: Git user config
    expected_name = GITHUB_USERNAME
    expected_email = GIT_EMAIL
    if user_name != expected_name or user_email != expected_email:
        print(f"\n  {YELLOW}●{RESET} Git user: {user_name or '(not set)'} <{user_email or '(not set)'}>" )
        print(f"    {GRAY}Expected: {expected_name} <{expected_email}>{RESET}")
        try:
            fix = input(f"    Fix? (Y/n): ").strip().lower() or 'y'
        except (EOFError, KeyboardInterrupt):
            fix = 'n'
            print()

        if fix in ('y', 'yes'):
            ssh_cmd(host_alias, f'cd {path} && git config user.name "{expected_name}" && git config user.email "{expected_email}"', timeout=10)
            print(f"    {GREEN}✓{RESET} User config updated")
            fixes_applied += 1
    else:
        print(f"  {GREEN}✓{RESET} Git user: {user_name} <{user_email}>")

    # Issue 3: Missing .gitignore
    if not has_gitignore:
        print(f"\n  {YELLOW}●{RESET} No .gitignore")
        try:
            fix = input(f"    Generate .gitignore? (Y/n): ").strip().lower() or 'y'
        except (EOFError, KeyboardInterrupt):
            fix = 'n'
            print()

        if fix in ('y', 'yes'):
            langs = _guess_languages(host_alias, path)
            content = _build_gitignore(langs)
            safe_content = content.replace("'", "'\\''")
            ok_gi, _ = ssh_cmd(host_alias,
                f"cd {path} && cat > .gitignore << 'GITIGNORE_EOF'\n{content}GITIGNORE_EOF",
                timeout=10)
            if ok_gi:
                print(f"    {GREEN}✓{RESET} .gitignore created ({', '.join(sorted(langs))})")
                fixes_applied += 1
            else:
                print(f"    {RED}✗ Failed to create .gitignore{RESET}")
    else:
        print(f"  {GREEN}✓{RESET} .gitignore present")

    # Summary
    if fixes_applied > 0:
        print(f"\n  {GREEN}✓ {fixes_applied} fix(es) applied{RESET}")
    else:
        print(f"\n  {GRAY}No fixes applied{RESET}")
    print()


# ─────────────────────────────────────────────────────────────────────────────
# repo deploy <project>
# ─────────────────────────────────────────────────────────────────────────────

def do_deploy(key):
    """Deploy: commit + push + restart services + health check."""
    proj = PROJECTS[key]
    host = proj['host']
    host_alias = HOSTS[host]['alias']
    path = proj['path']

    if not check_host_reachable(host_alias):
        print(f"\n  {RED}● {HOSTS[host]['name']} is offline{RESET}")
        return

    print()
    header_bar()
    print(f"  {BRIGHT_GREEN}DEPLOY — {proj['name']}{RESET}")
    header_bar()

    # [1/4] Check git state
    print(f"\n  {WHITE}[1/4]{RESET} Checking git state...")
    ok, check = ssh_cmd(host_alias,
        f'cd {path} && [ -d .git ] && echo GIT || echo NOGIT',
        timeout=8)
    if not ok or 'NOGIT' in (check or ''):
        print(f"  {RED}Not a git repository{RESET}")
        return

    ok, status = ssh_cmd(host_alias,
        f'cd {path} && git status --porcelain 2>/dev/null | wc -l | tr -d " "',
        timeout=10)
    dirty = int(status.strip()) if ok and status.strip().isdigit() else 0

    if dirty > 0:
        # Pre-flight checks before commit
        if not _check_index_lock(host_alias, path):
            return
        if not _check_large_files(host_alias, path):
            return

        print(f"  {YELLOW}● {dirty} uncommitted changes{RESET}")
        with Spinner('Generating commit message...'):
            generated = _generate_commit_msg(host_alias, path)
        msg = None
        if generated:
            msg = _prompt_commit_msg(generated)
        if not msg:
            if not generated:
                print(f"\n  {YELLOW}●{RESET} Could not generate message")
            try:
                msg = input(f"  Commit message (or q to cancel): ").strip()
            except (EOFError, KeyboardInterrupt):
                print()
                return
            if msg.lower() in ('q', 'quit', ''):
                print(f"  {GRAY}Cancelled{RESET}")
                return
        ok, output = _ssh_commit(host_alias, path, msg)
        if ok:
            print(f"  {GREEN}✓{RESET} Committed")
        else:
            print(f"  {RED}✗ Commit failed{RESET}")
            return
    else:
        print(f"  {GREEN}✓{RESET} Working tree clean")

    # [2/4] Check remote
    print(f"\n  {WHITE}[2/4]{RESET} Checking remote...")
    ok, remote = ssh_cmd(host_alias,
        f'cd {path} && git remote get-url origin 2>/dev/null',
        timeout=8)
    if not ok or not remote.strip():
        print(f"  {YELLOW}● No remote configured — skipping push{RESET}")
    else:
        # Pre-flight: PAT check
        if not _check_remote_auth(host_alias, path, remote.strip()):
            return

        # Check if ahead
        ok, ahead = ssh_cmd(host_alias,
            f'cd {path} && git rev-list --count @{{upstream}}..HEAD 2>/dev/null || echo "0"',
            timeout=10)
        ahead_count = int(ahead.strip()) if ok and ahead.strip().isdigit() else 0
        if ahead_count > 0:
            print(f"  {CYAN}● {ahead_count} commit(s) ahead — pushing...{RESET}")
            ok, stdout, stderr = _ssh_cmd_with_stderr(host_alias, f'cd {path} && git push', timeout=60)
            if ok:
                print(f"  {GREEN}✓{RESET} Pushed")
            else:
                print(f"  {RED}✗ Push failed{RESET}")
                err_output = stderr or stdout
                if err_output:
                    for line in err_output.split('\n')[-3:]:
                        if line.strip():
                            print(f"    {RED}{line.strip()}{RESET}")
                return
        else:
            print(f"  {GREEN}✓{RESET} Up to date with remote")

    # [3/4] Restart services
    print(f"\n  {WHITE}[3/4]{RESET} Restarting services...")
    env_services = load_services(key)

    restarted = []
    if not env_services:
        print(f"  {GRAY}● No services to restart{RESET}")
    else:
        for svc in env_services:
            svc_name = svc.get('name', '?')
            port = svc.get('port')
            print(f"  {CYAN}●{RESET} Restarting {svc_name} (:{port})...", end='', flush=True)

            success = restart_service(host_alias, path, svc, ready_timeout=30)
            if success:
                print(f"\r  {GREEN}✓{RESET} {svc_name} (:{port}) — healthy")
                restarted.append(svc_name)
            else:
                print(f"\r  {RED}✗{RESET} {svc_name} (:{port}) — failed health check")

    # [4/4] Record deploy state
    print(f"\n  {WHITE}[4/4]{RESET} Recording deploy state...")
    head = fetch_git_head(host_alias, path)
    if head:
        write_deploy_state(key, head, restarted if restarted else None)
        print(f"  {GREEN}✓{RESET} Deployed at {WHITE}{head}{RESET}")
    else:
        print(f"  {YELLOW}● Could not read HEAD{RESET}")

    # Summary
    print()
    header_bar()
    parts = []
    if dirty > 0:
        parts.append('committed')
    if remote and remote.strip():
        parts.append('pushed')
    if restarted:
        parts.append(f"{len(restarted)} service(s) restarted")
    print(f"  {GREEN}✓ Deploy complete: {', '.join(parts) if parts else 'recorded'}{RESET}")
    header_bar()
    print()


