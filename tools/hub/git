def do_init(key):
    """Initialize a git repo for a project."""
    proj = PROJECTS[key]
    host = proj['host']
    host_alias = HOSTS[host]['alias']
    path = proj['path']

    if not check_host_reachable(host_alias):
        print(f"\n  {RED}● {HOSTS[host]['name']} is offline{RESET}")
        return

    # Check current state
    ok, output = ssh_cmd(host_alias, f'cd {path} 2>/dev/null && [ -d .git ] && echo GIT || echo NOGIT', timeout=8)
    if not ok:
        print(f"\n  {RED}Cannot access {path} on {HOSTS[host]['name']}{RESET}")
        return

    has_git = 'GIT' in output.strip()

    if has_git:
        # Check if there are commits
        ok, commits_out = ssh_cmd(host_alias, f'cd {path} && git rev-list --count HEAD 2>/dev/null || echo 0', timeout=8)
        commit_count = 0
        if ok:
            try:
                commit_count = int(commits_out.strip())
            except ValueError:
                pass

        if commit_count > 0:
            print(f"\n  {GREEN}✓{RESET} {WHITE}{key}{RESET} is already a git repo with {commit_count} commits")
            print(f"  {GRAY}Use {CYAN}repo status {key}{GRAY} for details{RESET}")
            return
        else:
            print(f"\n  {YELLOW}●{RESET} {WHITE}{key}{RESET} has a .git directory but no commits (incomplete init)")
            wipe = input(f"  {WHITE}Remove .git and start fresh? (y/N): {RESET}").strip().lower()
            if wipe in ('y', 'yes'):
                ok_rm, _ = ssh_cmd(host_alias, f'cd {path} && rm -rf .git', timeout=10)
                if ok_rm:
                    print(f"  {GREEN}✓{RESET} Removed stale .git — continuing with fresh init")
                    has_git = False
                else:
                    print(f"  {RED}✗ Failed to remove .git{RESET}")
                    return
    else:
        print(f"\n  {CYAN}Initializing git repo for {WHITE}{proj['name']}{CYAN}...{RESET}")

    # Detect languages
    with Spinner('Detecting project type...'):
        langs = _guess_languages(host_alias, path)
    lang_str = ', '.join(sorted(langs))
    print(f"  {GRAY}Detected: {lang_str}{RESET}")

    # Generate .gitignore
    gitignore_content = _build_gitignore(langs)

    # Build init command
    init_parts = []
    if not has_git:
        init_parts.append(f'cd {path} && git init')
    else:
        init_parts.append(f'cd {path}')

    # Write .gitignore (check if one already exists)
    ok_gi, gi_out = ssh_cmd(host_alias, f'[ -f {path}/.gitignore ] && echo EXISTS || echo MISSING', timeout=5)
    if 'MISSING' in gi_out:
        # Use heredoc to write gitignore
        init_parts.append(f"cat > .gitignore << 'GITIGNORE_EOF'\n{gitignore_content}GITIGNORE_EOF")
        print(f"  {GREEN}+{RESET} Creating .gitignore ({lang_str})")

    # Set user config if not set
    init_parts.append(f'git config user.name "{GITHUB_USERNAME}" 2>/dev/null')
    init_parts.append(f'git config user.email "{GIT_EMAIL}" 2>/dev/null')

    # Pre-flight: check for large files/heavy dirs before staging
    if not _check_large_files(host_alias, path, pre_init=True):
        return

    # Stage and commit
    init_parts.append('git add -A')
    init_parts.append('git commit -m "Initial commit"')

    full_cmd = ' && '.join(init_parts)

    with Spinner('Initializing...'):
        ok, stdout, stderr = _ssh_cmd_with_stderr(host_alias, full_cmd, timeout=30)

    output = (stdout + '\n' + stderr).strip()
    if ok:
        print(f"  {GREEN}✓{RESET} Repository initialized and first commit created")
        # Show summary
        ok2, summary = ssh_cmd(host_alias, f'cd {path} && git log --oneline -1 && echo "FILES:$(git ls-files | wc -l | tr -d " ")"', timeout=8)
        if ok2:
            for line in summary.split('\n'):
                if line.startswith('FILES:'):
                    print(f"  {GRAY}{line[6:]} files tracked{RESET}")
                elif line.strip():
                    print(f"  {GRAY}{line}{RESET}")
        print(f"\n  {GRAY}Next: {CYAN}repo create {key}{GRAY} to push to GitHub{RESET}")
    else:
        print(f"  {RED}✗ Init failed{RESET}")
        if output:
            for line in output.split('\n'):
                if line.strip():
                    print(f"    {GRAY}{line}{RESET}")
        # Run diagnostics to help the user understand the state
        diag_cmd = f'cd {path} && echo "=== git status ===" && git status 2>&1 && echo "=== git log ===" && git log --oneline -1 2>&1'
        ok_diag, diag_out = ssh_cmd(host_alias, diag_cmd, timeout=8)
        if ok_diag and diag_out:
            print(f"\n  {YELLOW}Diagnostics:{RESET}")
            for line in diag_out.strip().split('\n'):
                print(f"    {GRAY}{line}{RESET}")


# ─────────────────────────────────────────────────────────────────────────────
# repo commit <project> "msg"
# ─────────────────────────────────────────────────────────────────────────────

def do_commit(key, message=None):
    """Stage all changes and commit. If no message, generate via LLM."""
    proj = PROJECTS[key]
    host = proj['host']
    host_alias = HOSTS[host]['alias']
    path = proj['path']

    if not check_host_reachable(host_alias):
        print(f"\n  {RED}● {HOSTS[host]['name']} is offline{RESET}")
        return

    # Check it's a git repo with changes
    ok, check = ssh_cmd(host_alias,
        f'cd {path} && [ -d .git ] && echo GIT || echo NOGIT && git status --porcelain 2>/dev/null | wc -l | tr -d " "',
        timeout=10)
    if not ok or 'NOGIT' in check:
        print(f"\n  {RED}{key} is not a git repository{RESET}")
        return

    lines = check.strip().split('\n')
    dirty_count = 0
    for line in lines:
        if line.strip().isdigit():
            dirty_count = int(line.strip())

    if dirty_count == 0:
        print(f"\n  {GREEN}✓{RESET} {WHITE}{key}{RESET} — nothing to commit (working tree clean)")
        return

    # Pre-flight checks
    if not _check_index_lock(host_alias, path):
        return
    if not _check_large_files(host_alias, path):
        return

    # Get or generate commit message
    if not message:
        with Spinner('Generating commit message...'):
            generated = _generate_commit_msg(host_alias, path)
        if generated:
            message = _prompt_commit_msg(generated)
        if not message:
            # LLM failed or user cancelled — ask for manual input
            if not generated:
                print(f"\n  {YELLOW}●{RESET} Could not generate message (AGX offline?)")
            try:
                message = input(f"  Commit message: ").strip()
            except (EOFError, KeyboardInterrupt):
                print()
                return
            if not message:
                print(f"  {GRAY}Cancelled{RESET}")
                return

    with Spinner(f'Committing {dirty_count} changes...'):
        ok, output = _ssh_commit(host_alias, path, message)

    if ok:
        print(f"\n  {GREEN}✓{RESET} {WHITE}{key}{RESET} — committed")
        # Parse commit output for stats
        for line in output.split('\n'):
            line = line.strip()
            if 'file' in line and ('changed' in line or 'insertion' in line or 'deletion' in line):
                print(f"  {GRAY}{line}{RESET}")
            elif line.startswith('['):
                print(f"  {GRAY}{line}{RESET}")
    else:
        print(f"\n  {RED}✗ Commit failed{RESET}")
        if output:
            for line in output.split('\n')[-5:]:
                if line.strip():
                    print(f"    {GRAY}{line}{RESET}")


