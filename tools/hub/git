_COMMIT_MSG_SYSTEM = """/no_think
Write a concise git commit message for these changes. One subject line (max 72 chars), imperative mood. If the changes are substantial, add a blank line and 1-3 bullet points. Output ONLY the commit message, nothing else."""


def _generate_commit_msg(host_alias, path, model=None):
    """Generate a commit message from git diff via Ollama. Returns message string or None."""
    # Get diff stat, truncated diff, and recent log
    cmd = (
        f'cd {path} && '
        f'echo "===STAT===" && git diff --cached --stat 2>/dev/null && git diff --stat 2>/dev/null && '
        f'echo "===DIFF===" && {{ git diff --cached 2>/dev/null; git diff 2>/dev/null; }} | head -150 && '
        f'echo "===LOG===" && git log --oneline -3 2>/dev/null'
    )
    ok, output = ssh_cmd(host_alias, cmd, timeout=15)
    if not ok or not output.strip():
        return None

    # Truncate to ~3000 chars for the LLM prompt
    if len(output) > 3000:
        output = output[:3000] + '\n... (truncated)'

    user_msg = f"Changes in this commit:\n\n{output}"

    result = ollama_query_text(
        model=model or DEFAULT_MODEL,
        system_msg=_COMMIT_MSG_SYSTEM,
        user_msg=user_msg,
        timeout=60,
        temperature=0.3,
        num_predict=256,
    )

    if result:
        # Strip any markdown fences or extra formatting
        result = result.strip()
        if result.startswith('```'):
            lines = result.split('\n')
            lines = [l for l in lines if not l.strip().startswith('```')]
            result = '\n'.join(lines).strip()
    return result or None


def _ssh_commit(host_alias, path, message, timeout=30):
    """Stage all + commit via temp file (handles multi-line messages safely).

    Returns (success, output). Captures both stdout and stderr for error reporting.
    For local hosts, skips SCP/SSH and runs git directly.
    """
    import os as _os
    import tempfile as _tf
    import subprocess as _sp
    import uuid as _uuid

    is_local = (host_alias == LOCAL_HOST)
    uid = _uuid.uuid4().hex[:8]
    with _tf.NamedTemporaryFile(mode='w', suffix='.txt', delete=False) as f:
        f.write(message)
        tmp_local = f.name

    tmp_remote = f'/tmp/_hub_commit_msg_{uid}.txt'
    try:
        if is_local:
            # Local: use the temp file directly
            import shutil as _sh
            _sh.copy2(tmp_local, tmp_remote)
        else:
            scp = _sp.run(
                ['scp', '-o', 'ConnectTimeout=3', '-o', 'BatchMode=yes',
                 tmp_local, f'{host_alias}:{tmp_remote}'],
                capture_output=True, text=True, timeout=10
            )
            if scp.returncode != 0:
                return False, f'SCP failed: {scp.stderr.strip()}'

        cmd = f"cd {path} && git add -A && git commit -F {tmp_remote}"
        try:
            if is_local:
                result = _sp.run(
                    ['bash', '-c', cmd],
                    capture_output=True, text=True, timeout=timeout
                )
            else:
                result = _sp.run(
                    ['ssh', '-o', 'ConnectTimeout=3', '-o', 'BatchMode=yes',
                     '-o', 'StrictHostKeyChecking=no', host_alias, cmd],
                    capture_output=True, text=True, timeout=timeout
                )
            output = (result.stdout.strip() + '\n' + result.stderr.strip()).strip()
            return result.returncode == 0, output
        except _sp.TimeoutExpired:
            return False, 'timeout'
    finally:
        _os.unlink(tmp_local)
        try:
            _os.unlink(tmp_remote)
        except OSError:
            pass
        if not is_local:
            ssh_cmd(host_alias, f'rm -f {tmp_remote}', timeout=5)


def _ssh_cmd_with_stderr(host_alias, cmd, timeout=30):
    """SSH command that captures both stdout and stderr separately.

    Returns (success, stdout, stderr). Unlike ssh_cmd() which drops stderr,
    this gives callers access to git's error output for better diagnostics.
    For local hosts, runs via bash directly.
    """
    import subprocess as _sp
    try:
        if host_alias == LOCAL_HOST:
            result = _sp.run(
                ['bash', '-c', cmd],
                capture_output=True, text=True, timeout=timeout
            )
        else:
            result = _sp.run(
                ['ssh', '-o', 'ConnectTimeout=3', '-o', 'BatchMode=yes',
                 '-o', 'StrictHostKeyChecking=no', host_alias, cmd],
                capture_output=True, text=True, timeout=timeout
            )
        return result.returncode == 0, result.stdout.strip(), result.stderr.strip()
    except _sp.TimeoutExpired:
        return False, '', 'timeout'
    except Exception as e:
        return False, '', str(e)


def _check_index_lock(host_alias, path):
    """Check for stale .git/index.lock. Returns True if clear to proceed."""
    ok, output = ssh_cmd(host_alias,
        f'cd {path} && [ -f .git/index.lock ] && stat -c %Y .git/index.lock || echo NONE',
        timeout=10)
    if not ok or 'NONE' in (output or ''):
        return True  # No lock file — clear

    try:
        lock_mtime = int(output.strip())
    except ValueError:
        return True  # Can't parse — assume clear

    import time as _time
    age = int(_time.time()) - lock_mtime

    if age < 10:
        print(f"  {YELLOW}●{RESET} index.lock found (age {age}s) — git operation may be in progress")
        return False

    print(f"  {YELLOW}●{RESET} Stale index.lock found (age {age}s)")
    try:
        choice = input(f"    Remove it? (Y/n): ").strip().lower() or 'y'
    except (EOFError, KeyboardInterrupt):
        print()
        return False

    if choice in ('y', 'yes'):
        ssh_cmd(host_alias, f'rm -f {path}/.git/index.lock', timeout=5)
        print(f"    {GREEN}✓{RESET} Removed index.lock")
        return True
    return False


def _check_large_files(host_alias, path, threshold_mb=95, pre_init=False):
    """Check for large files and heavy directories. Returns True if clear.

    Uses git status --porcelain for existing repos, or find for pre-init scans.
    Also scans top-level directories by total size (>500MB threshold).
    When adding to .gitignore, groups files by parent directory when 3+ share one.
    """
    threshold_bytes = threshold_mb * 1024 * 1024

    # Two-part scan: large individual files + heavy directories
    if pre_init or not _has_git_repo(host_alias, path):
        # Pre-init: use find for large files (no git available)
        file_cmd = (
            f'cd {path} && '
            f'find . -maxdepth 4 -type f -size +{threshold_mb}M 2>/dev/null | head -50 | '
            f'while IFS= read -r f; do '
            f'  s=$(stat -c %s "$f" 2>/dev/null) && echo "$s $f"; '
            f'done'
        )
    else:
        # Existing repo: scan dirty/untracked files
        file_cmd = (
            f'cd {path} && '
            f'git status --porcelain 2>/dev/null | sed "s/^...//" | '
            f'while IFS= read -r f; do '
            f'  [ -f "$f" ] && s=$(stat -c %s "$f" 2>/dev/null) && '
            f'  [ "$s" -gt {threshold_bytes} ] && echo "$s $f"; '
            f'done'
        )

    # Heavy directories: top-level dirs >500MB (always runs, fast du scan)
    dir_cmd = (
        f'cd {path} && '
        f'for d in */; do '
        f'  [ -d "$d" ] && s=$(du -sb "$d" 2>/dev/null | cut -f1) && '
        f'  [ "$s" -gt 524288000 ] && echo "$s $d"; '
        f'done'
    )

    ok1, file_output = ssh_cmd(host_alias, file_cmd, timeout=20)
    ok2, dir_output = ssh_cmd(host_alias, dir_cmd, timeout=20)

    # Parse large files
    large_files = []
    if ok1 and file_output.strip():
        for line in file_output.strip().split('\n'):
            parts = line.strip().split(' ', 1)
            if len(parts) == 2:
                try:
                    large_files.append((parts[1], int(parts[0])))
                except ValueError:
                    pass

    # Parse heavy directories
    heavy_dirs = []
    if ok2 and dir_output.strip():
        for line in dir_output.strip().split('\n'):
            parts = line.strip().split('\t') if '\t' in line else line.strip().split(' ', 1)
            if len(parts) == 2:
                try:
                    heavy_dirs.append((parts[1].rstrip('/'), int(parts[0])))
                except ValueError:
                    pass

    # Remove large files that are inside heavy dirs (avoid double-listing)
    heavy_prefixes = [d + '/' for d, _ in heavy_dirs]
    large_files = [(f, s) for f, s in large_files
                   if not any(f.lstrip('./').startswith(p) for p in heavy_prefixes)]

    if not large_files and not heavy_dirs:
        return True

    # Display findings
    if heavy_dirs:
        print(f"\n  {RED}!{RESET} {WHITE}Heavy directories:{RESET}")
        for dname, size in sorted(heavy_dirs, key=lambda x: -x[1]):
            gb = size / (1024 * 1024 * 1024)
            if gb >= 1:
                print(f"    {YELLOW}{gb:>8.1f}GB{RESET}  {dname}/")
            else:
                mb = size / (1024 * 1024)
                print(f"    {YELLOW}{mb:>8.0f}MB{RESET}  {dname}/")

    if large_files:
        print(f"\n  {RED}!{RESET} {WHITE}Large files (>{threshold_mb}MB):{RESET}")
        for fname, size in sorted(large_files, key=lambda x: -x[1])[:15]:
            mb = size / (1024 * 1024)
            print(f"    {YELLOW}{mb:>8.1f}MB{RESET}  {fname}")
        if len(large_files) > 15:
            print(f"    {DIM}... and {len(large_files) - 15} more{RESET}")

    print(f"\n    {CYAN}[a]{RESET}dd to .gitignore (default)  {CYAN}[s]{RESET}kip  {CYAN}[q]{RESET}uit")
    try:
        choice = input(f"    Choice [a]: ").strip().lower() or 'a'
    except (EOFError, KeyboardInterrupt):
        print()
        return False

    if choice in ('q', 'quit'):
        return False
    elif choice in ('a', 'add'):
        # Build gitignore entries: use directory/ when 3+ files share a parent
        entries = set()
        # Add heavy dirs directly
        for dname, _ in heavy_dirs:
            entries.add(dname.lstrip('./') + '/')

        # Group remaining large files by parent dir
        from collections import Counter
        parents = Counter()
        for fname, _ in large_files:
            clean = fname.lstrip('./')
            parent = '/'.join(clean.split('/')[:-1])
            if parent:
                parents[parent] += 1

        for fname, _ in large_files:
            clean = fname.lstrip('./')
            parent = '/'.join(clean.split('/')[:-1])
            if parent and parents[parent] >= 3:
                entries.add(parent + '/')
            else:
                entries.add(clean)

        sorted_entries = '\n'.join(sorted(entries))
        append_cmd = (
            f"cd {path} && cat >> .gitignore << 'LARGE_EOF'\n\n"
            f"# Heavy content (auto-excluded by repo tool)\n"
            f"{sorted_entries}\n"
            f"LARGE_EOF"
        )
        ssh_cmd(host_alias, append_cmd, timeout=10)

        # Summary
        dir_count = sum(1 for e in entries if e.endswith('/'))
        file_count = len(entries) - dir_count
        total_size = sum(s for _, s in heavy_dirs) + sum(s for _, s in large_files)
        total_gb = total_size / (1024 * 1024 * 1024)
        parts = []
        if dir_count:
            parts.append(f"{dir_count} dir(s)")
        if file_count:
            parts.append(f"{file_count} file(s)")
        print(f"    {GREEN}✓{RESET} Added {' + '.join(parts)} to .gitignore ({total_gb:.1f}GB excluded)")
        return True
    else:
        # skip — proceed anyway
        return True


def _has_git_repo(host_alias, path):
    """Quick check if path has a .git directory."""
    ok, out = ssh_cmd(host_alias, f'[ -d {path}/.git ] && echo Y || echo N', timeout=5)
    return ok and 'Y' in (out or '')


def _check_remote_auth(host_alias, path, remote_url):
    """Check remote URL for auth issues: PAT tokens or bare HTTPS without credentials.

    Returns True if clear to proceed.
    """
    if not remote_url:
        return True

    repo = extract_github_repo(remote_url)
    has_pat = any(tok in remote_url for tok in ('ghp_', 'gho_', 'github_pat_'))
    is_https = remote_url.startswith('https://')
    is_ssh = remote_url.startswith('git@')

    # SSH remotes are fine
    if is_ssh:
        return True

    # No issue detected for non-GitHub remotes
    if not repo:
        return True

    if has_pat:
        print(f"\n  {RED}!{RESET} PAT token detected in remote URL")
        print(f"    {GRAY}{sanitize_remote_url(remote_url)}{RESET}")
    elif is_https:
        # Check if HTTPS will actually work (credential helper or token)
        ok_cred, cred_out = ssh_cmd(host_alias,
            'git config --global credential.helper 2>/dev/null', timeout=5)
        has_cred_helper = ok_cred and cred_out.strip()
        if has_cred_helper:
            return True  # Credential helper configured — HTTPS should work
        print(f"\n  {YELLOW}●{RESET} HTTPS remote without credentials (push will fail)")
        print(f"    {GRAY}{remote_url}{RESET}")
    else:
        return True

    print(f"\n    {CYAN}[f]{RESET}ix now (default)  {CYAN}[c]{RESET}ontinue  {CYAN}[q]{RESET}uit")
    try:
        choice = input(f"    Choice [f]: ").strip().lower() or 'f'
    except (EOFError, KeyboardInterrupt):
        print()
        return False

    if choice in ('q', 'quit'):
        return False
    elif choice in ('c', 'continue'):
        return True
    elif choice in ('f', 'fix') and repo:
        # Check SSH auth on the host
        ok_ssh, ssh_out = ssh_cmd(host_alias,
            'ssh -T -o BatchMode=yes -o ConnectTimeout=5 git@github.com 2>&1 || true',
            timeout=15)
        github_ssh_ok = 'successfully authenticated' in (ssh_out or '').lower()

        if github_ssh_ok:
            new_url = f'git@github.com:{repo}.git'
            ok_fix, _ = ssh_cmd(host_alias, f'cd {path} && git remote set-url origin {new_url}', timeout=10)
            if ok_fix:
                print(f"    {GREEN}✓{RESET} Switched to SSH: {new_url}")
                return True
            else:
                print(f"    {RED}✗ Failed to update remote{RESET}")
                return False
        else:
            if has_pat:
                # At least strip the PAT
                new_url = f'https://github.com/{repo}.git'
                ssh_cmd(host_alias, f'cd {path} && git remote set-url origin {new_url}', timeout=10)
                print(f"    {GREEN}✓{RESET} Stripped PAT (still HTTPS — set up SSH key for push)")
            else:
                print(f"    {YELLOW}●{RESET} No SSH key on this host — set one up:")
                print(f"      {DIM}ssh-keygen -t ed25519 && cat ~/.ssh/id_ed25519.pub{RESET}")
                print(f"      {DIM}Then add to github.com/settings/keys{RESET}")
            return True
    else:
        return True


def _prompt_commit_msg(generated_msg):
    """Show generated message and prompt user to accept/edit/type/quit.

    Returns commit message string, or None if user cancels.
    """
    print(f"\n    {WHITE}Generated:{RESET} {generated_msg.split(chr(10))[0]}")
    if '\n' in generated_msg:
        for line in generated_msg.split('\n')[1:]:
            print(f"               {line}")

    print(f"\n    {CYAN}[a]{RESET}ccept  {CYAN}[e]{RESET}dit  {CYAN}[t]{RESET}ype own  {CYAN}[q]{RESET}uit")
    try:
        choice = input(f"    Choice [a]: ").strip().lower() or 'a'
    except (EOFError, KeyboardInterrupt):
        print()
        return None

    if choice in ('a', 'accept'):
        return generated_msg
    elif choice in ('e', 'edit'):
        # Show first line as editable default
        first_line = generated_msg.split('\n')[0]
        try:
            edited = input(f"    Message [{first_line}]: ").strip()
        except (EOFError, KeyboardInterrupt):
            print()
            return None
        return edited if edited else first_line
    elif choice in ('t', 'type'):
        try:
            typed = input(f"    Message: ").strip()
        except (EOFError, KeyboardInterrupt):
            print()
            return None
        return typed if typed else None
    else:
        return None


