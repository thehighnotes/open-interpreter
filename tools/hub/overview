def collect_project_data(project_key, force_refresh=False, model=DEFAULT_MODEL):
    """Collect all data for a project. Returns a data dict."""
    proj = PROJECTS[project_key]
    host = proj['host']
    host_alias = HOSTS[host]['alias']
    data = {
        'key': project_key,
        'project': proj,
        'host_online': False,
        'claude_md': None,
        'claude_md_mtime': None,
        'recent_files': [],
        'git_log': [],
        'services': {},
        'llm_analysis': None,
        'llm_cache_age': None,
        'llm_error': None,
    }

    # Check host reachability
    if not check_host_reachable(host_alias):
        data['host_online'] = False
        return data

    data['host_online'] = True

    # Parallel probes (including transcript)
    tasks = {
        'claude_md': lambda: probe_claude_md(host_alias, proj['path'], proj['claude_md']),
        'recent_files': lambda: probe_recent_files(host_alias, proj['path']),
        'git_log': lambda: probe_git_log(host_alias, proj['path']),
    }

    # Add transcript probe if claude_dir is configured
    claude_dir = proj.get('claude_dir')
    if claude_dir:
        tasks['transcript'] = lambda: probe_transcript(host_alias, claude_dir)

    # Load services from registry (projects.json)
    service_list = load_services(project_key)

    # Add service probes
    for svc in service_list:
        port = svc['port']
        svc_key = f"svc_{port}"
        tasks[svc_key] = lambda p=port: probe_service(host_alias, p)

    results = run_parallel(tasks)

    # Unpack results
    if results.get('claude_md'):
        data['claude_md'], data['claude_md_mtime'] = results['claude_md']

    data['recent_files'] = results.get('recent_files', [])
    data['git_log'] = results.get('git_log', [])
    transcript = results.get('transcript', '')

    # Get transcript file mtime for cache key
    transcript_mtime = None
    if transcript and claude_dir:
        cmd = (f'find ~/.claude/projects/{claude_dir}/ -maxdepth 1 -name "*.jsonl" '
               f'-printf "%T@\\n" 2>/dev/null | sort -rn | head -1')
        ok, ts = ssh_cmd(host_alias, cmd, timeout=5)
        if ok and ts.strip():
            transcript_mtime = ts.strip().split('.')[0]  # integer seconds

    # Store service list for rendering
    data['service_list'] = service_list

    for svc in service_list:
        port = svc['port']
        svc_key = f"svc_{port}"
        data['services'][port] = results.get(svc_key, False)

    # LLM analysis — run if ANY source material is available
    has_sources = data['claude_md'] or data['recent_files'] or data['git_log'] or transcript
    if has_sources:
        # Fallback cache key when CLAUDE.md is absent: use git HEAD hash or timestamp
        cache_mtime = data['claude_md_mtime']
        if cache_mtime is None:
            host_alias_for_cache = HOSTS[host]['alias']
            ok, head = ssh_cmd(host_alias_for_cache,
                               f'cd {proj["path"]} 2>/dev/null && git rev-parse HEAD 2>/dev/null',
                               timeout=5)
            cache_mtime = f"nogit-{int(time.time())}" if not ok or not head.strip() else f"git-{head.strip()}"

        if not force_refresh:
            cached, age = get_cached_analysis(project_key, cache_mtime,
                                              transcript_mtime)
            if cached:
                data['llm_analysis'] = cached
                data['llm_cache_age'] = age
                return data

        # Load research context if available
        research_context = None
        research_cache = RESEARCH_CACHE_DIR / f'{project_key}.json'
        if research_cache.exists():
            try:
                rdata = json.loads(research_cache.read_text())
                rlines = []
                for item in rdata.get('high_relevance', [])[:3]:
                    rlines.append(f"Paper [{item.get('score',0)}]: {item.get('title','')} — {item.get('reason','')}")
                for item in rdata.get('releases', [])[:2]:
                    rlines.append(f"Release [{item.get('score',0)}]: {item.get('title','')} — {item.get('reason','')}")
                if rlines:
                    research_context = '\n'.join(rlines)
            except (json.JSONDecodeError, OSError):
                pass

        # Need fresh analysis — pass all sources (claude_md may be None)
        with Spinner(f"Analyzing {proj['name']} with {model}..."):
            analysis = query_ollama(
                data['claude_md'],
                recent_files=data['recent_files'],
                git_log=data['git_log'],
                transcript=transcript,
                research_context=research_context,
                model=model,
            )

        if analysis and validate_overview_analysis(analysis):
            # RAG enrichment pass: use first-pass results to query doc RAG
            # for richer context from indexed project documentation
            ca_key = resolve_code_project(project_key)
            ca_host = HUB_CONFIG['code_assistant']['host']
            if ca_key and (ca_host == LOCAL_HOST or check_host_reachable(ca_host)):
                first_pass = analysis  # save in case second pass fails
                focus = analysis.get('current_focus', [])
                phase = analysis.get('phase', '')
                query_parts = [phase] + focus[:3]
                rag_query = ' '.join(query_parts).strip()
                if rag_query:
                    rag_results = code_assistant_get('search', {
                        'query': rag_query,
                        'project': ca_key,
                        'source_type': 'doc',
                        'limit': 3,
                    }, timeout=10)
                    if rag_results and rag_results.get('results'):
                        snippets = []
                        for r in rag_results['results']:
                            if r.get('score', 0) > 0.3:
                                snippets.append(r.get('snippet', ''))
                        if snippets:
                            doc_context = '\n---\n'.join(snippets)
                            with Spinner(f"Enriching {proj['name']} with indexed docs..."):
                                enriched = query_ollama(
                                    data['claude_md'],
                                    recent_files=data['recent_files'],
                                    git_log=data['git_log'],
                                    transcript=transcript,
                                    research_context=research_context,
                                    doc_context=doc_context,
                                    model=model,
                                )
                            if enriched and validate_overview_analysis(enriched):
                                analysis = enriched
                            # else: keep first_pass (already in analysis)

            data['llm_analysis'] = analysis
            data['llm_cache_age'] = 'just now'
            save_cache(project_key, analysis, cache_mtime,
                       transcript_mtime)
        elif analysis:
            data['llm_error'] = 'LLM returned malformed data (missing required keys)'
        else:
            data['llm_error'] = 'LLM analysis failed (timeout or parse error)'

    return data


