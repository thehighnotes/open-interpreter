# Ollama LLM Integration
# ─────────────────────────────────────────────────────────────────────────────

OLLAMA_SYSTEM = """/no_think
You are a JSON extraction tool. Output ONLY a JSON object. No other text."""

OLLAMA_USER = """Return a JSON object from this project context. Use ALL sources — CLAUDE.md for background, recent files for activity, and the conversation transcript for what is ACTIVELY happening.

Keys:
- "phase": string — current project phase (short label)
- "status_summary": string — 1-2 sentence status reflecting where things stand right now
- "current_focus": list of strings — what is actively being worked on RIGHT NOW, with enough context to understand WHY (from transcript + recent files, max 5)
- "blockers": list of strings — known issues, failed attempts, constraints — include what was tried and what went wrong (max 5)
- "key_metrics": object — key numbers mentioned, use descriptive keys
- "recent_breakthroughs": list of strings — discoveries or achievements, explain the significance not just the name (max 3)
- "architecture_summary": string — 3-4 sentences on current architecture state and what is active
- "tech_stack": list of strings (max 8)
- "connections": list of strings — how this project relates to other projects in the ecosystem AND relevant recent research, be specific (max 4)
- "entry_points": object — key files with a brief note on what each does

Rules:
- The transcript shows what JUST happened — prioritize it for current_focus, breakthroughs, blockers
- Recent files confirm what areas are active
- CLAUDE.md provides background context and architecture
- Write entries that give enough context to pick up work — not just labels, but not paragraphs either. Aim for 1 clear sentence per entry.
- Extract only stated facts
- If research context is provided, mention highly relevant papers/releases in connections where appropriate

"""


def query_ollama(claude_md_content=None, recent_files=None, git_log=None,
                 transcript=None, research_context=None, doc_context=None,
                 model=DEFAULT_MODEL):
    """Build overview prompt from all sources and query Ollama. Returns parsed JSON or None."""
    # Build enriched content from all sources
    parts = []

    if claude_md_content:
        claude_truncated = claude_md_content[:8000]
        parts.append(f'=== CLAUDE.md (project reference) ===\n{claude_truncated}')
    else:
        parts.append('=== NOTE: No CLAUDE.md found. Analysis based on code files, git history, and transcript only. ===')

    if recent_files:
        files_str = '\n'.join(recent_files[:25])
        parts.append(f'=== RECENTLY MODIFIED FILES (last work session) ===\n{files_str}')

    if git_log:
        log_str = '\n'.join(git_log[:5]) if isinstance(git_log, list) else git_log
        parts.append(f'=== RECENT GIT COMMITS ===\n{log_str}')

    if transcript:
        parts.append(f'=== LAST DEVELOPMENT SESSION (conversation transcript) ===\n{transcript}')

    if research_context:
        parts.append(f'=== RECENT RESEARCH (auto-discovered) ===\n{research_context}')

    if doc_context:
        parts.append(f'=== PROJECT DOCUMENTATION (from indexed docs) ===\n{doc_context}')

    enriched_content = '\n\n'.join(parts)

    return ollama_query(
        model=model,
        system_msg=OLLAMA_SYSTEM,
        user_msg=OLLAMA_USER + enriched_content,
        timeout=120,
        temperature=0.3,
        num_predict=2048,
    )


