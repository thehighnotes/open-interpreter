def ensure_cache_dir():
    ensure_dir(CACHE_DIR)


def get_cached_analysis(project_key, current_mtime, transcript_mtime=None):
    """Return cached LLM analysis if source mtimes haven't changed. Returns (data, age_str) or (None, None)."""
    cache_file = CACHE_DIR / f"{project_key}.json"
    mtime_file = CACHE_DIR / f"{project_key}.mtime"

    if not cache_file.exists() or not mtime_file.exists():
        return None, None

    try:
        stored_mtime = mtime_file.read_text().strip()
        # Cache key is "claude_mtime:transcript_mtime"
        current_key = f"{current_mtime}:{transcript_mtime or ''}"
        if stored_mtime != current_key:
            return None, None

        data = json.loads(cache_file.read_text())
        # Calculate cache age
        cache_age = time.time() - cache_file.stat().st_mtime
        if cache_age < 60:
            age_str = f"{int(cache_age)}s ago"
        elif cache_age < 3600:
            age_str = f"{int(cache_age / 60)}m ago"
        elif cache_age < 86400:
            age_str = f"{int(cache_age / 3600)}h ago"
        else:
            age_str = f"{int(cache_age / 86400)}d ago"
        return data, age_str
    except (json.JSONDecodeError, OSError):
        return None, None


def save_cache(project_key, data, mtime, transcript_mtime=None):
    """Save LLM analysis and combined mtime key to cache."""
    ensure_cache_dir()
    cache_file = CACHE_DIR / f"{project_key}.json"
    mtime_file = CACHE_DIR / f"{project_key}.mtime"
    try:
        cache_file.write_text(json.dumps(data, indent=2))
        mtime_file.write_text(f"{mtime}:{transcript_mtime or ''}")
        append_overview_history(project_key, data)
    except OSError:
        pass


