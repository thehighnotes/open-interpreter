def get_change_fingerprint(host_reachable):
    """Lightweight SSH probes to detect changes. Returns a fingerprint string.

    Checks git HEAD hash + newest transcript mtime per project, all in parallel.
    """
    parts = []

    def probe_project(key):
        proj = PROJECTS[key]
        host = proj['host']
        if not host_reachable.get(host):
            return f"{key}:offline"
        alias = HOSTS[host]['alias']
        claude_dir = proj.get('claude_dir', '')
        cmd = (
            f'cd {proj["path"]} 2>/dev/null && git rev-parse --short HEAD 2>/dev/null; '
            f'find ~/.claude/projects/{claude_dir}/ -maxdepth 1 -name "*.jsonl" '
            f'-printf "%T@\\n" 2>/dev/null | sort -rn | head -1'
        )
        ok, output = ssh_cmd(alias, cmd, timeout=8)
        return f"{key}:{output}" if ok else f"{key}:err"

    tasks = {k: lambda pk=k: probe_project(pk) for k in PROJECT_ORDER}
    results = run_parallel(tasks)

    for k in PROJECT_ORDER:
        parts.append(results.get(k, f'{k}:none'))

    return '|'.join(parts)


def watch_loop(interval_minutes, force_refresh, model):
    """Continuous refresh loop. Clears screen and re-renders on changes."""
    import signal

    interval_secs = max(60, interval_minutes * 60)
    last_fingerprint = None

    # Restore cursor on exit
    def cleanup(*_):
        sys.stderr.write('\033[?25h')  # Show cursor
        sys.stderr.flush()
        print(f"\n{GRAY}Watch stopped.{RESET}")
        sys.exit(0)

    signal.signal(signal.SIGINT, cleanup)
    signal.signal(signal.SIGTERM, cleanup)

    try:
        while True:
            # Check host reachability
            host_reachable = run_parallel({
                h: lambda a=HOSTS[h]['alias']: check_host_reachable(a)
                for h in HOSTS
            })

            # Get fingerprint
            fingerprint = get_change_fingerprint(host_reachable)

            if fingerprint != last_fingerprint or force_refresh:
                # Clear screen and render
                sys.stdout.write('\033[2J\033[H')
                sys.stdout.flush()
                render_summary_view(force_refresh=force_refresh, model=model)
                print(f"\n{GRAY}  Watch mode — refreshing every {interval_minutes}m | Ctrl+C to stop{RESET}")
                last_fingerprint = fingerprint
                # Only force refresh on first run
                force_refresh = False

            # Countdown timer
            sys.stderr.write('\033[?25l')  # Hide cursor
            remaining = interval_secs
            while remaining > 0:
                mins, secs = divmod(remaining, 60)
                sys.stderr.write(f"\r{GRAY}  Next check in {mins:02d}:{secs:02d}{RESET} ")
                sys.stderr.flush()
                time.sleep(1)
                remaining -= 1
            sys.stderr.write(f"\r{' ' * 30}\r")
            sys.stderr.flush()
            sys.stderr.write('\033[?25h')  # Show cursor

    except KeyboardInterrupt:
        cleanup()


