DIAGRAMS_JSON = Path.home() / '.config' / 'hub' / 'diagrams.json'


def _load_diagrams():
    """Load project architecture diagrams from JSON. Returns dict or empty.

    Diagram strings can contain ANSI placeholders like {WHITE}, {DIM}, etc.
    which are interpolated at load time.
    """
    if not DIAGRAMS_JSON.exists():
        return {}
    try:
        with open(DIAGRAMS_JSON) as f:
            raw = json.load(f)
        colors = {
            'WHITE': WHITE, 'DIM': DIM, 'RESET': RESET, 'GREEN': GREEN,
            'GRAY': GRAY, 'CYAN': CYAN, 'YELLOW': YELLOW, 'RED': RED,
            'BRIGHT_GREEN': BRIGHT_GREEN, 'BOLD': BOLD,
        }
        return {k: v.format(**colors) for k, v in raw.items()}
    except (json.JSONDecodeError, OSError, KeyError):
        return {}


DIAGRAMS = _load_diagrams()


