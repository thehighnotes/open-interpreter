def probe_claude_md(host_alias, project_path, claude_md_name):
    """Read CLAUDE.md content and its mtime. Returns (content, mtime_str) or (None, None)."""
    filepath = f"{project_path}/{claude_md_name}"
    cmd = f'cat {filepath} 2>/dev/null && echo "===MTIME===" && stat -c %Y {filepath} 2>/dev/null'
    ok, output = ssh_cmd(host_alias, cmd, timeout=10)
    if ok and '===MTIME===' in output:
        parts = output.rsplit('===MTIME===', 1)
        content = parts[0].strip()
        mtime = parts[1].strip()
        return content, mtime
    return None, None


def probe_recent_files(host_alias, project_path, gap_hours=8):
    """Find files from the most recent work session.

    Gets file timestamps sorted newest-first, then collects files until
    a gap exceeding gap_hours is found. This captures the last concentrated
    work session regardless of how long ago it was.
    """
    # Get timestamps + paths, filtered for source files only
    cmd = (f'cd {project_path} 2>/dev/null && '
           f'find . -type f '
           f'-not -path "./.git/*" -not -path "./node_modules/*" '
           f'-not -path "./__pycache__/*" -not -path "./venv/*" '
           f'-not -path "./.venv/*" -not -path "./target/*" '
           f'-not -path "*/build/*" -not -path "./audio/*" '
           f'-not -path "*/samples/*" -not -path "*/results/*" '
           f'-not -path "*/outputs/*" '
           f'-not -name "*.pyc" -not -name "*.log" '
           f'-not -name "*.wav" -not -name "*.mp3" -not -name "*.flac" '
           f'-not -name "*.png" -not -name "*.jpg" -not -name "*.jpeg" '
           f'-not -name "*.npy" -not -name "*.npz" '
           f'-not -name "*.pt" -not -name "*.bin" -not -name "*.onnx" '
           f'-not -name "*.so" -not -name "*.o" '
           f'-printf "%T@ %p\\n" | sort -rn | head -60')
    ok, output = ssh_cmd(host_alias, cmd, timeout=10)
    if not ok or not output:
        return []

    lines = output.strip().split('\n')
    if not lines:
        return []

    # Parse timestamps and paths
    files = []
    gap_sec = gap_hours * 3600
    prev_ts = None
    for line in lines:
        parts = line.split(' ', 1)
        if len(parts) != 2:
            continue
        try:
            ts = float(parts[0])
        except ValueError:
            continue
        path = parts[1].lstrip('./')

        if prev_ts is not None and (prev_ts - ts) > gap_sec:
            break  # Session boundary found
        files.append(path)
        prev_ts = ts

    return files


def probe_git_log(host_alias, project_path, count=5):
    """Get recent git commits. Returns list of one-line strings."""
    cmd = (f'cd {project_path} 2>/dev/null && '
           f'git log --oneline -{count} 2>/dev/null')
    ok, output = ssh_cmd(host_alias, cmd, timeout=10)
    if ok and output:
        return output.strip().split('\n')
    return []


def probe_last_commit_ts(host_alias, project_path):
    """Get unix timestamp of the most recent git commit. Returns float or None."""
    cmd = (f'cd {project_path} 2>/dev/null && '
           f'git log -1 --format="%at" 2>/dev/null')
    ok, output = ssh_cmd(host_alias, cmd, timeout=5)
    if ok and output.strip():
        try:
            return float(output.strip())
        except ValueError:
            pass
    return None


def format_activity_age(ts):
    """Format a unix timestamp as a human-readable activity age string."""
    age = time.time() - ts
    if age < 3600:
        return f"{GREEN}active {int(age / 60)}m ago{RESET}"
    elif age < 86400:
        hours = int(age / 3600)
        return f"{GREEN}active {hours}h ago{RESET}"
    elif age < 172800:
        return f"{GRAY}active yesterday{RESET}"
    elif age < 604800:
        return f"{GRAY}active {int(age / 86400)}d ago{RESET}"
    else:
        return f"{YELLOW}inactive {int(age / 86400)}d{RESET}"


def probe_transcript(host_alias, claude_dir):
    """Extract condensed conversation transcript from the most recent Claude Code session.

    Finds the newest .jsonl in the project's Claude dir, extracts user messages
    and substantive assistant responses, filters out tool chatter.
    Returns condensed transcript string or empty string.
    """
    # Find the most recent top-level .jsonl (not subagent files)
    cmd = (f'find ~/.claude/projects/{claude_dir}/ -maxdepth 1 -name "*.jsonl" '
           f'-printf "%T@ %p\\n" 2>/dev/null | sort -rn | head -1')
    ok, output = ssh_cmd(host_alias, cmd, timeout=5)
    if not ok or not output.strip():
        return ''

    parts = output.strip().split(' ', 1)
    if len(parts) != 2:
        return ''
    jsonl_path = parts[1]

    # Read the file
    ok, raw = ssh_cmd(host_alias, f'cat {jsonl_path}', timeout=15)
    if not ok or not raw:
        return ''

    # Parse and condense
    lines = []
    for jline in raw.split('\n'):
        jline = jline.strip()
        if not jline:
            continue
        try:
            obj = json.loads(jline)
        except json.JSONDecodeError:
            continue

        typ = obj.get('type', '')
        if typ not in ('user', 'assistant'):
            continue

        msg = obj.get('message', {})
        role = msg.get('role', typ)
        content = msg.get('content', '')

        texts = []
        if isinstance(content, str):
            texts.append(content)
        elif isinstance(content, list):
            for block in content:
                if block.get('type') == 'text' and block.get('text', '').strip():
                    texts.append(block['text'])

        for t in texts:
            t = t.strip()
            if not t:
                continue
            # Skip system/command noise
            if '<command-name>' in t or '<local-command' in t:
                continue
            if '<task-notification>' in t:
                continue
            if t.startswith('[Request interrupted'):
                continue
            # Skip tool-calling chatter from assistant
            if role == 'assistant':
                low = t.lower()
                if any(low.startswith(p) for p in [
                    'let me read', 'let me check', 'let me find',
                    'now let me', 'now add', 'now update', 'now i',
                    'i need to update',
                ]):
                    continue
                if len(t) < 60:
                    continue
            # Truncate long blocks
            if len(t) > 300:
                t = t[:300] + '...'
            prefix = 'U:' if role == 'user' else 'A:'
            lines.append(f'{prefix} {t}')

    return '\n'.join(lines)


def probe_machine_health(host_alias):
    """Get machine health info. Returns dict with uptime, ram, disk, temp, etc."""
    cmd = (
        'echo "===UPTIME===" && uptime -p 2>/dev/null && '
        'echo "===MEM===" && free -m 2>/dev/null | grep Mem && '
        'echo "===DISK===" && df -h / 2>/dev/null | tail -1 && '
        'echo "===TEMP===" && cat /sys/devices/virtual/thermal/thermal_zone*/temp 2>/dev/null | head -1'
    )
    ok, output = ssh_cmd(host_alias, cmd, timeout=10)
    info = {}
    if ok:
        sections = output.split('===')
        for i in range(1, len(sections), 2):
            key = sections[i].strip()
            val = sections[i + 1].strip() if i + 1 < len(sections) else ''
            if key == 'UPTIME':
                info['uptime'] = val
            elif key == 'MEM':
                parts = val.split()
                if len(parts) >= 3:
                    info['ram_used'] = parts[2]
                    info['ram_total'] = parts[1]
            elif key == 'DISK':
                parts = val.split()
                if len(parts) >= 4:
                    info['disk_used'] = parts[2]
                    info['disk_total'] = parts[1]
            elif key == 'TEMP':
                try:
                    temp_c = int(val) // 1000
                    info['temp'] = f"{temp_c}C"
                except (ValueError, TypeError):
                    pass
    return info


def probe_ollama_status(host_alias):
    """Check if Ollama is running and what model is loaded."""
    cmd = f'curl -s http://localhost:{OLLAMA_PORT}/api/ps 2>/dev/null'
    ok, output = ssh_cmd(host_alias, cmd, timeout=5)
    if ok and output:
        try:
            data = json.loads(output)
            models = data.get('models', [])
            if models:
                names = [m.get('name', '?') for m in models]
                return True, names
            return True, []
        except json.JSONDecodeError:
            return True, []
    return False, []


