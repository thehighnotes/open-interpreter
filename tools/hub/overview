def render_summary_view(force_refresh=False, model=DEFAULT_MODEL):
    """Render compact all-projects summary view."""
    from datetime import datetime

    # Check host reachability first (parallel)
    host_status = {}
    host_health = {}

    def check_host(alias):
        reachable = check_host_reachable(alias)
        health = probe_machine_health(alias) if reachable else {}
        return reachable, health

    with Spinner("Probing infrastructure..."):
        host_tasks = {}
        for hkey, hinfo in HOSTS.items():
            host_tasks[hkey] = lambda a=hinfo['alias']: check_host(a)
        host_results = run_parallel(host_tasks)

    for hkey, (reachable, health) in host_results.items():
        host_status[hkey] = reachable
        host_health[hkey] = health

    # Probe last commit timestamps for all projects on online hosts (parallel)
    activity_ts = {}
    activity_tasks = {}
    for pk in PROJECT_ORDER:
        proj = PROJECTS[pk]
        host = proj['host']
        if host_status.get(host):
            alias = HOSTS[host]['alias']
            activity_tasks[pk] = lambda a=alias, p=proj['path']: probe_last_commit_ts(a, p)
    if activity_tasks:
        activity_ts = run_parallel(activity_tasks)

    # Check Ollama on its configured host
    ollama_up, ollama_models = False, []
    if OLLAMA_HOST == LOCAL_HOST or host_status.get(OLLAMA_HOST):
        ollama_up, ollama_models = probe_ollama_status(OLLAMA_HOST)

    print()
    header_bar()
    now = datetime.now().strftime('%a %d %b %H:%M')
    print_right(f"{BRIGHT_GREEN}  OPERATIONS OVERVIEW{RESET}", f"{BRIGHT_GREEN}{now}{RESET}")
    header_bar()
    print()

    # Infrastructure
    print(f"  {WHITE}INFRASTRUCTURE{RESET}")
    divider()

    # Local host
    local_health = {}
    try:
        result = subprocess.run(['free', '-m'], capture_output=True, text=True, timeout=5)
        if result.returncode == 0:
            for line in result.stdout.split('\n'):
                if 'Mem:' in line:
                    parts = line.split()
                    local_health['ram_total'] = parts[1]
                    local_health['ram_used'] = parts[2]
        result = subprocess.run(['df', '-h', '/'], capture_output=True, text=True, timeout=5)
        if result.returncode == 0:
            parts = result.stdout.strip().split('\n')[-1].split()
            local_health['disk_used'] = parts[2]
            local_health['disk_total'] = parts[1]
    except Exception:
        pass

    local_info_parts = []
    if local_health.get('ram_used'):
        local_info_parts.append(f"{local_health['ram_used']}M/{local_health['ram_total']}M RAM")
