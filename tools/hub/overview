def print_usage():
    print(f"""
{WHITE}overview{RESET} — Context-aware project overview tool

{WHITE}Usage:{RESET}
  overview                        All projects summary (compact view)
  overview <project>              Deep view of a specific project
  overview <project> --refresh    Force re-analysis (bypass cache)
  overview <project> --raw        Show raw LLM JSON (debug)
  overview --refresh              Force re-analysis for all
  overview --model <name>         Use specific Ollama model
  overview --watch               Continuous refresh (every 5 minutes)
  overview --watch --interval 2  Custom interval in minutes

{WHITE}Projects:{RESET}
  (Listed from config — use hub project keys as arguments)
""")


def main():
    args = sys.argv[1:]

    if '-h' in args or '--help' in args:
        print_usage()
        sys.exit(0)

    # Parse flags
    force_refresh = '--refresh' in args
    show_raw = '--raw' in args
    watch_mode = '--watch' in args
    model = DEFAULT_MODEL
    watch_interval = 5  # default minutes

    # Remove flags from args
    clean_args = []
    skip_next = False
    for i, arg in enumerate(args):
        if skip_next:
            skip_next = False
            continue
        if arg in ('--refresh', '--raw', '--watch'):
            continue
        if arg == '--model':
            if i + 1 < len(args):
                model = args[i + 1]
                skip_next = True
            continue
        if arg == '--interval':
            if i + 1 < len(args):
                try:
                    watch_interval = int(args[i + 1])
                except ValueError:
                    pass
                skip_next = True
            continue
        clean_args.append(arg)

    ensure_cache_dir()

    if watch_mode:
        watch_loop(watch_interval, force_refresh, model)
        return

    if not clean_args:
        # Summary view
        render_summary_view(force_refresh=force_refresh, model=model)
    else:
        project_key = resolve_project(clean_args[0])
        if not project_key:
            sys.exit(1)
        render_deep_view(project_key, force_refresh=force_refresh,
                         show_raw=show_raw, model=model)


if __name__ == '__main__':
    main()
