def _prompt(msg, default=''):
    """Prompt for input with a default. Returns default on empty/EOF/Ctrl-C."""
    try:
        val = input(msg).strip()
        return val if val else default
    except (EOFError, KeyboardInterrupt):
        print()
        return default


def _count_code_files(host_alias, project_path):
    """Count code files in a remote project via SSH. Returns int."""
    cmd = (
        f'find {project_path} -type f '
        r'\( -name "*.py" -o -name "*.js" -o -name "*.ts" -o -name "*.tsx" '
        r'-o -name "*.jsx" -o -name "*.java" -o -name "*.go" -o -name "*.rs" '
        r'-o -name "*.c" -o -name "*.cpp" -o -name "*.h" -o -name "*.rb" '
        r'-o -name "*.html" -o -name "*.css" -o -name "*.vue" -o -name "*.svelte" '
        r'-o -name "*.md" -o -name "*.json" -o -name "*.yaml" -o -name "*.yml" \) '
        r'-not -path "*/.git/*" -not -path "*/node_modules/*" '
        r'-not -path "*/__pycache__/*" -not -path "*/.venv/*" '
        r'-not -path "*/dist/*" -not -path "*/build/*" '
        f'2>/dev/null | wc -l'
    )
    ok, output = ssh_cmd(host_alias, cmd, timeout=15)
    if ok and output.strip():
        try:
            return int(output.strip())
        except ValueError:
            pass
    return 0


def _guess_language(host_alias, project_path):
    """Guess primary language of a project. Returns short string."""
    cmd = (
        f'cd {project_path} 2>/dev/null && '
        r'py=$(find . -name "*.py" -not -path "*/.git/*" -not -path "*/__pycache__/*" 2>/dev/null | wc -l) && '
        r'js=$(find . -name "*.js" -o -name "*.ts" -o -name "*.tsx" -o -name "*.jsx" 2>/dev/null | grep -v node_modules | grep -v ".git" | wc -l) && '
        r'go=$(find . -name "*.go" -not -path "*/.git/*" 2>/dev/null | wc -l) && '
        r'rs=$(find . -name "*.rs" -not -path "*/.git/*" 2>/dev/null | wc -l) && '
        r'web=$(find . \( -name "*.html" -o -name "*.css" -o -name "*.vue" -o -name "*.svelte" \) -not -path "*/.git/*" -not -path "*/node_modules/*" 2>/dev/null | wc -l) && '
        'echo "$py $js $go $rs $web"'
    )
    ok, output = ssh_cmd(host_alias, cmd, timeout=10)
    if ok and output.strip():
        parts = output.strip().split()
        if len(parts) == 5:
            py, js, go, rs, web = [int(x) for x in parts]
            counts = {'python': py, 'js/ts': js, 'go': go, 'rust': rs, 'html/css': web}
            best = max(counts, key=counts.get)
            if counts[best] > 0:
                return best
    return ''


def _ws_setup_instructions():
    """Print SSH setup instructions for cross-host project syncing."""
    # Find the WS-like host (the one that needs syncing)
    ws_host = HOSTS.get('ws', {})
    ws_ip = ws_host.get('ip', '<WS_IP>')
    ws_user = ws_host.get('user', '<WS_USER>')
    ca_host_name = _CA_HOST_NAME

    print()
    print(f"  {YELLOW}{ca_host_name} cannot SSH to WS — setup required for syncing WS projects{RESET}")
    print()
    print(f"  Run these commands manually:")
