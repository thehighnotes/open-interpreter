def _basename(path):
    """Get filename from a full path."""
    return path.rsplit('/', 1)[-1] if '/' in path else path


def _truncate(text, max_chars=2000):
    """Truncate text with ellipsis if over limit."""
    if len(text) <= max_chars:
        return text
    return text[:max_chars - 3] + '...'


