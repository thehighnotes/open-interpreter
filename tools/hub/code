def _render_manage_dashboard():
    """Fetch and display the management dashboard. Returns project list."""
    projects_result = code_assistant_get('projects', timeout=5)
    stats_result = code_assistant_get('stats', timeout=5)

    if not projects_result or 'projects' not in projects_result:
        print(f"  {RED}Failed to fetch projects{RESET}")
        return []

    projects = projects_result['projects']

    # Watcher status
    watcher = code_assistant_get('watcher/status', timeout=3)

    print()
    header_bar()
    print(f"{BRIGHT_GREEN}  CODE INDEX MANAGER{RESET}")
    header_bar()
    print()

    # Stats summary
    if stats_result:
        total = stats_result.get('total_files', 0)
        db_size = stats_result.get('database_size_mb', 0)
        deps = stats_result.get('total_dependencies', 0)
        print(f"  {WHITE}{len(projects)} projects{RESET}  |  {total} files  |  {deps} deps  |  {db_size:.0f}MB DB")
        print()

    # Project table
    print(f"  {WHITE}{'#':<4}{'Project':<16}{'Files':>8}{'Code':>8}{'Docs':>8}  {'Hub Key':<18}{'Host'}{RESET}")
    divider()

    for i, p in enumerate(projects, 1):
        total = p.get('code_count', 0) + p.get('doc_count', 0)
        hub_keys = [k for k, v in CODE_ASSISTANT_PROJECTS.items() if v == p['name']]
        hub_label = hub_keys[0] if hub_keys else f'{GRAY}--{RESET}'

        # Determine host from hub registry
        ca_host = HUB_CONFIG['code_assistant']['host']
        hub_key = hub_keys[0] if hub_keys else None
        hub_host = PROJECTS[hub_key]['host'] if hub_key and hub_key in PROJECTS else None
        needs_sync = hub_host is not None and hub_host != ca_host
        if needs_sync:
            host_label = f'{CYAN}{hub_host}{RESET}'
        elif hub_host:
            host_label = hub_host
        else:
            host_label = ca_host

        # Build compact status tags
        tags = []

        # Sync status for remote-hosted projects (synced to CA host)
        if needs_sync:
            sync_file = CODE_CACHE_DIR / f'{p["name"]}_sync.json'
            if sync_file.exists():
                try:
                    sync_data = json.loads(sync_file.read_text())
                    sync_age = time.time() - sync_data.get('ts', 0)
                    if sync_age < 3600:
                        tags.append(f"{GRAY}sync:{int(sync_age/60)}m{RESET}")
                    elif sync_age < 86400:
                        tags.append(f"{GRAY}sync:{int(sync_age/3600)}h{RESET}")
                    else:
                        tags.append(f"{YELLOW}sync:{int(sync_age/86400)}d{RESET}")
                except (json.JSONDecodeError, OSError):
                    pass

        # Last indexed timestamp from CA API
        idx_ts = p.get('last_indexed_at')
        if idx_ts:
            idx_age = time.time() - idx_ts
            if idx_age < 3600:
                tags.append(f"{GRAY}idx:{int(idx_age/60)}m{RESET}")
            elif idx_age < 86400:
                tags.append(f"{GRAY}idx:{int(idx_age/3600)}h{RESET}")
            else:
                tags.append(f"{YELLOW}idx:{int(idx_age/86400)}d{RESET}")

        # Last worked on — from overview cache mtime
        if hub_key:
            ov_cache = OVERVIEW_CACHE_DIR / f'{hub_key}.json'
            if ov_cache.exists():
                try:
                    ov_age = time.time() - ov_cache.stat().st_mtime
                    if ov_age < 3600:
                        tags.append(f"{GREEN}act:{int(ov_age/60)}m{RESET}")
                    elif ov_age < 86400:
                        tags.append(f"{GREEN}act:{int(ov_age/3600)}h{RESET}")
                    elif ov_age < 604800:
                        tags.append(f"{GRAY}act:{int(ov_age/86400)}d{RESET}")
                    else:
                        tags.append(f"{YELLOW}act:{int(ov_age/86400)}d{RESET}")
                except OSError:
                    pass

        status_str = '  '.join(tags)
        tag_suffix = f"  {status_str}" if tags else ""
        print(f"  {WHITE}{i:<4}{RESET}{GREEN}{p['name']:<16}{RESET}{total:>8d}{p.get('code_count',0):>8d}"
              f"{p.get('doc_count',0):>8d}  {hub_label:<18}{host_label}{tag_suffix}")

    # Watcher status
    print()
    if watcher and watcher.get('running'):
        watched = list(watcher.get('projects', {}).keys())
        print(f"  {GREEN}●{RESET} File watcher: {WHITE}running{RESET}  watching: {', '.join(watched)}")
    else:
        avail = watcher.get('available', False) if watcher else False
        if avail:
            print(f"  {YELLOW}●{RESET} File watcher: {YELLOW}stopped{RESET}")
        else:
            print(f"  {GRAY}●{RESET} File watcher: {GRAY}unavailable{RESET}")

    return projects


def cmd_manage():
    """Interactive dashboard for managing Code Assistant indexes."""
    if not check_code_assistant():
        print(f"{RED}Code Assistant offline{RESET} ({_CA_LABEL})")
        sys.exit(1)

    while True:
        reload_projects()
        projects = _render_manage_dashboard()
        if not projects:
            sys.exit(1)

        def _code_render(item, idx, highlighted):
            p = item
            total = p.get('code_count', 0) + p.get('doc_count', 0)
            hub_keys = [k for k, v in CODE_ASSISTANT_PROJECTS.items() if v == p['name']]
            hub_label = hub_keys[0] if hub_keys else '--'
            hub_key = hub_keys[0] if hub_keys else None
            ca_host = HUB_CONFIG['code_assistant']['host']
            hub_host = PROJECTS[hub_key]['host'] if hub_key and hub_key in PROJECTS else ca_host
            host_label = hub_host
            if highlighted:
                return f"  {HIGHLIGHT_BG}{p['name']:<16}{total:>8d}  {hub_label:<18}{host_label}{HIGHLIGHT_OFF}"
            return f"  {GREEN}{p['name']:<16}{RESET}{total:>8d}  {hub_label:<18}{host_label}"

        action_keys = {
            'r': ('reindex', 'Reindex project'),
            's': ('sync', 'Sync+reindex (WS projects)'),
            'w': ('watcher', 'Toggle file watcher'),
        }
        footer = f"  {GRAY}r=reindex  s=sync+reindex  w=toggle watcher  q=quit{RESET}"

        action, idx = interactive_select(
            projects, _code_render, actions=action_keys, footer=footer,
        )

        if action is None:
            break

        proj = projects[idx]

        if action in ('r', KEY_ENTER):
            # Reindex
            print(f"\n  {CYAN}Reindexing {proj['name']}...{RESET}")
            with Spinner(f"Reindexing {proj['name']}"):
                result = code_assistant_post(f"projects/{proj['name']}/reindex", {}, timeout=300)
            if result and result.get('success'):
                code_info = result.get('code', {})
                processed = code_info.get('processed_files', 0)
                total = code_info.get('total_files', 0)
                elapsed = code_info.get('elapsed_time', 0)
                print(f"  {GREEN}✓{RESET} {proj['name']}: {processed} updated ({total} total, {elapsed:.1f}s)")
            else:
                err = result.get('error', 'unknown') if result else 'no response'
                print(f"  {RED}✗{RESET} Failed: {err}")

        elif action == 's':
            # Sync + reindex (WS projects)
            ca_name = proj['name']
            proj_hub_key = None
            for hk, ck in CODE_ASSISTANT_PROJECTS.items():
                if ck == ca_name:
                    proj_hub_key = hk
                    break
            ca_host = HUB_CONFIG['code_assistant']['host']
            proj_host = PROJECTS[proj_hub_key]['host'] if proj_hub_key and proj_hub_key in PROJECTS else ca_host
            if proj_host == ca_host:
                print(f"  {YELLOW}{ca_name} is a {proj_host} project — use 'r' to reindex{RESET}")
                continue

            ws_path = _find_ws_source(proj)
            if not ws_path:
                print(f"  {YELLOW}Cannot determine WS source path for {proj['name']}{RESET}")
                print(f"  {GRAY}Root path: {proj.get('root_path', '?')}{RESET}")
                continue

            if not check_agx_ws_ssh():
                _ws_setup_instructions()
                continue

            ca_host = HUB_CONFIG['code_assistant']['host']
            ca_host_name = HOSTS.get(ca_host, {}).get('name', ca_host)
            ca_mirror = proj.get('root_path', '').replace(f'/home/{HOSTS[ca_host]["user"]}', '~')

            print(f"\n  {CYAN}Syncing {ws_path} → {ca_host_name}...{RESET}")
            with Spinner(f"rsync {proj['name']}"):
                ok, output = rsync_to_ca_host(proj_host, ws_path, ca_mirror)
            if not ok:
                print(f"  {RED}rsync failed{RESET}")
                if output:
                    print(f"  {GRAY}{output[:200]}{RESET}")
                continue
            print(f"  {GREEN}✓{RESET} Synced")

            ensure_dir(CODE_CACHE_DIR)
            sync_file = CODE_CACHE_DIR / f'{proj["name"]}_sync.json'
            sync_file.write_text(json.dumps({'ts': time.time(), 'source': ws_path}))

            print(f"  {CYAN}Reindexing {proj['name']}...{RESET}")
            with Spinner(f"Reindexing {proj['name']}"):
                result = code_assistant_post(f"projects/{proj['name']}/reindex", {}, timeout=300)
            if result and result.get('success'):
                code_info = result.get('code', {})
                processed = code_info.get('processed_files', 0)
                total = code_info.get('total_files', 0)
                elapsed = code_info.get('elapsed_time', 0)
                print(f"  {GREEN}✓{RESET} {proj['name']}: {processed} updated ({total} total, {elapsed:.1f}s)")
            else:
                err = result.get('error', 'unknown') if result else 'no response'
                print(f"  {RED}✗{RESET} Failed: {err}")

        elif action == 'w':
            # Toggle watcher (global, not per-project)
            watcher = code_assistant_get('watcher/status', timeout=3)
            if watcher and watcher.get('running'):
                with Spinner("Stopping watcher"):
                    result = code_assistant_post('watcher/stop', {}, timeout=10)
                if result and result.get('success'):
                    print(f"  {GREEN}✓{RESET} Watcher stopped")
                else:
                    print(f"  {RED}✗{RESET} Failed to stop watcher")
            else:
                with Spinner("Starting watcher"):
                    result = code_assistant_post('watcher/start', {}, timeout=10)
                if result and result.get('success'):
                    watched = result.get('projects', [])
                    print(f"  {GREEN}✓{RESET} Watcher started ({', '.join(watched)})")
                else:
                    print(f"  {RED}✗{RESET} Failed to start watcher")


def _resolve_manage_project(projects, arg):
    """Resolve a project from # index or name. Returns project dict or None."""
    # Try as number first
    try:
        idx = int(arg) - 1
        if 0 <= idx < len(projects):
            return projects[idx]
        print(f"  {YELLOW}Invalid #. Use 1-{len(projects)}{RESET}")
        return None
    except ValueError:
        pass

    # Try by name
    for p in projects:
        if p['name'].lower() == arg.lower():
            return p

    # Fuzzy
    for p in projects:
        if arg.lower() in p['name'].lower():
            return p

    print(f"  {YELLOW}Unknown project '{arg}'{RESET}")
    return None


def _find_ws_source(ca_project):
    """Find the WS source path for a CA project that was synced from WS.

    Looks up the hub PROJECTS registry to find the WS path.
    """
    ca_name = ca_project['name']

    # Find hub key for this CA project
    hub_key = None
    for hk, ck in CODE_ASSISTANT_PROJECTS.items():
        if ck == ca_name:
            hub_key = hk
            break

    if hub_key and hub_key in PROJECTS:
        proj = PROJECTS[hub_key]
        ca_host = HUB_CONFIG['code_assistant']['host']
        if proj['host'] != ca_host:
            return proj['path']

    # Fallback: check sync cache for previous source
    sync_file = CODE_CACHE_DIR / f'{ca_name}_sync.json'
    if sync_file.exists():
        try:
            sync_data = json.loads(sync_file.read_text())
            return sync_data.get('source')
        except (json.JSONDecodeError, OSError):
            pass

    return None


