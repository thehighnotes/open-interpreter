def cmd_scan(host_key):
    """Discover projects on a host and offer to index them in Code Assistant."""
    if host_key not in HOSTS:
        print(f"{RED}Unknown host '{host_key}'. Available: {', '.join(HOSTS.keys())}{RESET}")
        sys.exit(1)

    host = HOSTS[host_key]
    host_alias = host['alias']
    host_name = host['name']

    print()
    print(f"  {CYAN}Scanning {host_name} ({host['ip']}) for indexable projects...{RESET}")

    # Check host reachability
    if not check_host_reachable(host_alias):
        print(f"\n  {RED}● {host_name} is offline{RESET}")
        sys.exit(1)

    # Check Code Assistant
    if not check_code_assistant():
        print(f"\n  {RED}Code Assistant offline{RESET} ({_CA_LABEL}) — cannot index")
        sys.exit(1)

    # For projects on a different host than CA, check CA→source SSH
    ca_host = HUB_CONFIG['code_assistant']['host']
    if host_key != ca_host and not check_agx_ws_ssh():
        _ws_setup_instructions()
        retry = _prompt(f"  {WHITE}Retry after setup? (y/N): {RESET}", 'n').lower()
        if retry in ('y', 'yes') and check_agx_ws_ssh():
            print(f"  {GREEN}✓{RESET} SSH working")
        elif retry in ('y', 'yes'):
            print(f"  {RED}Still can't connect. Check setup and try again.{RESET}")
            sys.exit(1)
        else:
            sys.exit(0)

    # Get currently indexed projects from CA
    ca_result = code_assistant_get('projects', timeout=5)
    indexed_projects = {}
    if ca_result and 'projects' in ca_result:
        for p in ca_result['projects']:
            indexed_projects[p['name']] = p

    # SSH scan for projects
    scan_cmd = r'''
for d in ~/projects/*/; do
    [ -d "$d" ] || continue
    dirname=$(basename "$d")
    git=no; [ -d "$d/.git" ] && git=yes
    claude_md=none
    [ -f "$d/CLAUDE.md" ] && claude_md=CLAUDE.md
    [ -f "$d/claude.md" ] && claude_md=claude.md
    hub_env=no; [ -f "$d/.hub-env" ] && hub_env=yes
    has_py=no; ls "$d"/*.py "$d"/**/*.py 2>/dev/null | head -1 | grep -q . && has_py=yes
    has_code=no; ls "$d"/*.py "$d"/*.js "$d"/*.ts "$d"/*.go "$d"/*.rs "$d"/*.html "$d"/*.css "$d"/*.vue "$d"/*.svelte 2>/dev/null | head -1 | grep -q . && has_code=yes
    if [ "$has_code" = "no" ]; then
        find "$d" -maxdepth 3 -type f \( -name "*.py" -o -name "*.js" -o -name "*.ts" -o -name "*.rs" -o -name "*.go" -o -name "*.html" -o -name "*.css" -o -name "*.vue" -o -name "*.svelte" -o -name "*.jsx" -o -name "*.tsx" \) 2>/dev/null | head -1 | grep -q . && has_code=yes
    fi
    echo "${dirname}|${git}|${claude_md}|${hub_env}|${has_py}|${has_code}"
done
'''
    ok, output = ssh_cmd(host_alias, scan_cmd, timeout=15)
    if not ok or not output.strip():
        print(f"\n  {GRAY}No ~/projects/ directory found or empty{RESET}")
        sys.exit(0)

    # Build candidate list
    # Determine which dirname maps to which CA project by matching root_path
    indexed_by_path = {}
    for name, p in indexed_projects.items():
        root = p.get('root_path', '')
        if root:
            indexed_by_path[root.rstrip('/').rsplit('/', 1)[-1].lower()] = name

    # Also track hub project → CA name mappings
    hub_ca_map = {}
    for hub_key, ca_key in CODE_ASSISTANT_PROJECTS.items():
        hub_ca_map[ca_key] = hub_key

    host_ignored = set(IGNORED.get(host_key, []))
    candidates = []
    already_indexed = []
    ignored_dirs = []

    for line in output.strip().split('\n'):
        parts = line.split('|', 5)
        if len(parts) < 6:
            continue
        dirname, git, claude_md, hub_env, has_py, has_code = parts

        entry = {
            'dirname': dirname,
            'path': f'~/projects/{dirname}',
            'git': git == 'yes',
            'claude_md': claude_md if claude_md != 'none' else None,
            'hub_env': hub_env == 'yes',
            'has_code': has_code == 'yes' or has_py == 'yes',
        }

        # Check if already indexed in CA
        ca_name = indexed_by_path.get(dirname.lower())
        if not ca_name:
            # Check by iterating indexed projects for path match
            user = host['user']
            full_path = f'/home/{user}/projects/{dirname}'
            for name, p in indexed_projects.items():
                if p.get('root_path', '').rstrip('/') == full_path:
                    ca_name = name
                    break
        if not ca_name:
            # Check hub registry — WS projects are mirrored to AGX with
            # a different name, so path matching against CA root_path fails.
            # Use the code_index field from projects.json instead.
            for pk, proj in PROJECTS.items():
                if proj['host'] == host_key and proj['path'].rstrip('/').endswith(dirname):
                    ci = proj.get('code_index')
                    if ci and ci in indexed_projects:
                        ca_name = ci
                        break

        if ca_name:
            entry['ca_name'] = ca_name
            entry['ca_info'] = indexed_projects[ca_name]
            entry['hub_key'] = hub_ca_map.get(ca_name, '')
            already_indexed.append(entry)
        elif dirname in host_ignored:
            ignored_dirs.append(dirname)
        elif entry['has_code']:
            candidates.append(entry)

    # Display
    if candidates:
        # Get file counts and language for candidates
        print(f"\n  {WHITE}Indexable projects (not yet in Code Assistant):{RESET}\n")

        max_dir = max(len(c['dirname']) for c in candidates) if candidates else 20
        dir_width = max(max_dir + 2, 20)

        print(f"  {GRAY}{'#':<4}{'Directory':<{dir_width}}{'Git':<6}{'CLAUDE.md':<12}{'Lang'}{RESET}")
        print(f"  {GRAY}{'─' * (dir_width + 30)}{RESET}")

        for i, c in enumerate(candidates, 1):
            git_str = f"{GREEN}git{RESET}" if c['git'] else f"{GRAY}-{RESET}"
            claude_str = f"{GREEN}{c['claude_md']}{RESET}" if c['claude_md'] else f"{GRAY}-{RESET}"
            git_vis = 'git' if c['git'] else '-'
            claude_vis = c['claude_md'] or '-'
            dirname_padded = c['dirname'] + ' ' * max(0, dir_width - len(c['dirname']))
            git_padded = git_str + ' ' * max(0, 6 - len(git_vis))
            claude_padded = claude_str + ' ' * max(0, 12 - len(claude_vis))

            lang = _guess_language(host_alias, f"~/projects/{c['dirname']}")
            lang_str = f"{GRAY}{lang}{RESET}" if lang else ''
            print(f"  {WHITE}{i:<4}{RESET}{dirname_padded}{git_padded}{claude_padded}{lang_str}")
    else:
        print(f"\n  {GREEN}✓{RESET} All projects on {host_name} are already indexed")

    # Show already indexed
    if already_indexed:
        print(f"\n  {GRAY}Already indexed:{RESET}")
        for a in already_indexed:
            ca_info = a['ca_info']
            total = ca_info.get('code_count', 0) + ca_info.get('doc_count', 0)
            hub_label = f" → hub:{a['hub_key']}" if a.get('hub_key') else ''
            print(f"  {GRAY}  ·  {a['dirname']:<20s} {a['ca_name']} ({total} files){hub_label}{RESET}")

    # Display ignored dirs (dimmed)
    if ignored_dirs:
        print(f"\n  {DIM}Ignored: {', '.join(sorted(ignored_dirs))}  (hub --scan --ignore {host_key} to manage){RESET}")

    if not candidates:
        print()
        sys.exit(0)

    # Interactive selection
    print()
    nums = ','.join(str(i) for i in range(1, len(candidates) + 1))
    try:
        choice = input(f"  {WHITE}Index which? ({nums} / all / q): {RESET}").strip().lower()
    except (EOFError, KeyboardInterrupt):
        print()
        sys.exit(0)

    if choice in ('q', 'quit', ''):
        sys.exit(0)

    if choice == 'all':
        selected = list(range(len(candidates)))
    else:
        selected = []
        for part in choice.split(','):
            part = part.strip()
            try:
                idx = int(part) - 1
                if 0 <= idx < len(candidates):
                    selected.append(idx)
            except ValueError:
                print(f"  {RED}Invalid: {part}{RESET}")
                sys.exit(1)

    if not selected:
        sys.exit(0)

    # Configure each selected project
    # If a project is already in the hub registry, use that key as the index name
    # automatically. Only prompt for projects not in the hub.
    needs_naming = False
    for idx in selected:
        c = candidates[idx]
        found = False
        for pk, proj in PROJECTS.items():
            if proj['host'] == host_key and proj['path'].endswith(c['dirname']):
                found = True
                break
        if not found:
            needs_naming = True

    if needs_naming:
        print()
        print(f"  {WHITE}Name each project for the index:{RESET}")
        print(f"  {GRAY}This name is used everywhere: code search <name> \"query\"{RESET}")
        divider()

    entries = []
    for idx in selected:
        c = candidates[idx]

        # Auto-detect hub key if project is already registered
        existing_hub_key = None
        for pk, proj in PROJECTS.items():
            if proj['host'] == host_key and proj['path'].endswith(c['dirname']):
                existing_hub_key = pk
                break

        if existing_hub_key:
            # Hub project exists — use its key, no prompt needed
            index_name = existing_hub_key
            print(f"\n  {CYAN}{c['dirname']}{RESET} → {WHITE}{index_name}{RESET}  {GRAY}(matches hub project){RESET}")
        else:
            # New project — ask for a name
            default_name = c['dirname'].lower().replace(' ', '-').replace('_', '-')
            print(f"\n  {CYAN}{c['dirname']}{RESET}  {GRAY}(not in hub registry){RESET}")
            index_name = _prompt(f"    Name [{WHITE}{default_name}{RESET}]: ", default_name)

        entries.append({
            'dirname': c['dirname'],
            'path': c['path'],
            'ca_name': index_name,
            'hub_key': existing_hub_key or index_name,
            'host': host_key,
        })

    # Review
    print()
    divider()
    print(f"\n  {WHITE}Review:{RESET}\n")
    for e in entries:
        ca_host = HUB_CONFIG['code_assistant']['host']
        sync_note = f"  {GRAY}(rsync → {HOSTS.get(ca_host, {}).get('name', ca_host)} then index){RESET}" if e['host'] != ca_host else ''
        print(f"  {GREEN}+{RESET} {WHITE}{e['ca_name']}{RESET}  ← {e['dirname']}  (hub: {e['hub_key']}){sync_note}")

    print()
    confirm = _prompt(f"  {WHITE}Confirm? (Y/n): {RESET}", 'y').lower()
    if confirm not in ('y', 'yes'):
        print(f"  {GRAY}Cancelled{RESET}")
        sys.exit(0)

    # Index each project
    print()
    for e in entries:
        user = HOSTS[e['host']]['user']
        full_path = f"/home/{user}/projects/{e['dirname']}"

        ca_host = HUB_CONFIG['code_assistant']['host']
        if e['host'] != ca_host:
            # Rsync from source host to CA host mirror
            ca_mirror = f"~/projects/{e['ca_name']}"
            ca_host_name = HOSTS.get(ca_host, {}).get('name', ca_host)
            src_host_name = HOSTS.get(e['host'], {}).get('name', e['host'])
            print(f"  {CYAN}Syncing {e['dirname']} from {src_host_name} to {ca_host_name}...{RESET}")
            with Spinner(f"rsync {e['dirname']} → {ca_host_name}"):
                ok, output = rsync_to_ca_host(e['host'], f"~/projects/{e['dirname']}", ca_mirror)
            if not ok:
                print(f"  {RED}rsync failed for {e['dirname']}{RESET}")
                if output:
                    print(f"  {GRAY}{output[:200]}{RESET}")
                continue
            print(f"  {GREEN}✓{RESET} Synced to {ca_host_name}")
            # Use the CA host mirror path for indexing
            ca_user = HOSTS[ca_host]['user']
            full_path = f"/home/{ca_user}/projects/{e['ca_name']}"

        # POST /index to Code Assistant
        print(f"  {CYAN}Indexing {e['ca_name']}...{RESET}")
        with Spinner(f"Indexing {e['ca_name']}"):
            result = code_assistant_post('index', {
                'project': e['ca_name'],
                'code_paths': [full_path],
                'doc_paths': [full_path],
            }, timeout=300)

        if result and result.get('success'):
            code_info = result.get('code', {})
            doc_info = result.get('doc', {})
            code_processed = code_info.get('processed_files', 0) if code_info else 0
            code_total = code_info.get('total_files', 0) if code_info else 0
            doc_processed = doc_info.get('processed_files', 0) if doc_info else 0
            doc_total = doc_info.get('total_files', 0) if doc_info else 0
            elapsed = code_info.get('elapsed_time', 0) if code_info else 0
            print(f"  {GREEN}✓{RESET} {e['ca_name']}: {code_processed} code + {doc_processed} docs indexed ({code_total + doc_total} total, {elapsed:.1f}s)")

            # Persist code_index to projects.json if hub project exists
            # Reload from disk in case hub --scan added it since we started
            hub_key = e['hub_key']
            fresh_projects, fresh_order, fresh_ignored = load_projects()
            if hub_key in fresh_projects:
                fresh_projects[hub_key]['code_index'] = e['ca_name']
                save_projects(fresh_projects, fresh_order, fresh_ignored)
                reload_projects()
                print(f"  {GRAY}Persisted hub:{hub_key} → CA:{e['ca_name']} in projects.json{RESET}")
            elif hub_key not in CODE_ASSISTANT_PROJECTS:
                CODE_ASSISTANT_PROJECTS[hub_key] = e['ca_name']
                print(f"  {YELLOW}⚠{RESET}  {GRAY}Mapped hub:{hub_key} → CA:{e['ca_name']} (in-memory only — run {CYAN}hub --scan{GRAY} to register){RESET}")
        else:
            err = result.get('error', 'unknown error') if result else 'no response'
            print(f"  {RED}✗{RESET} Failed to index {e['ca_name']}: {err}")

    print()


