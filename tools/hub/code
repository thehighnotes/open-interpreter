def main():
    args = sys.argv[1:]

    if '-h' in args or '--help' in args:
        print_usage()
        sys.exit(0)

    if not args:
        cmd_list()
        sys.exit(0)

    subcmd = args[0]

    if subcmd == 'search':
        if len(args) < 3:
            print(f"Usage: code search <project> \"query\"")
            sys.exit(1)
        hub_key = resolve_project(args[1])
        if not hub_key:
            sys.exit(1)
        query = ' '.join(args[2:])
        cmd_search(hub_key, query)

    elif subcmd == 'ask':
        if len(args) < 3:
            print(f"Usage: code ask <project> \"question\"")
            sys.exit(1)
        hub_key = resolve_project(args[1])
        if not hub_key:
            sys.exit(1)
        question = ' '.join(args[2:])
        cmd_ask(hub_key, question)

    elif subcmd == 'impact':
        if len(args) < 3:
            print(f"Usage: code impact <project> \"file_path\"")
            sys.exit(1)
        hub_key = resolve_project(args[1])
        if not hub_key:
            sys.exit(1)
        file_path = args[2]
        cmd_impact(hub_key, file_path)

    elif subcmd == 'graph':
        if len(args) < 2:
            print(f"Usage: code graph <project>")
            sys.exit(1)
        hub_key = resolve_project(args[1])
        if not hub_key:
            sys.exit(1)
        cmd_graph(hub_key)

    elif subcmd == 'scan':
        if len(args) < 2:
            print(f"Usage: code scan <host>  (agx, ws)")
            sys.exit(1)
        cmd_scan(args[1])

    elif subcmd == 'reindex':
        if len(args) < 2:
            print(f"Usage: code reindex <project>")
            sys.exit(1)
        hub_key = resolve_project(args[1])
        if not hub_key:
            sys.exit(1)
        cmd_reindex(hub_key)

    elif subcmd == 'manage':
        cmd_manage()

    else:
        # Maybe they passed a project key directly — treat as list
        hub_key = resolve_project(subcmd)
        if hub_key and resolve_code_project(hub_key):
            cmd_graph(hub_key)
        elif hub_key:
            print(f"Project '{hub_key}' is not indexed in Code Assistant")
            print(f"Indexed: {', '.join(CODE_ASSISTANT_PROJECTS.keys())}")
        else:
            print_usage()
            sys.exit(1)


if __name__ == '__main__':
    main()
