def cmd_reindex(hub_key):
    """Trigger reindex on an existing indexed project."""
    ca_key = resolve_code_project(hub_key)
    if not ca_key:
        print(f"Project '{hub_key}' is not indexed in Code Assistant")
        print(f"Indexed: {', '.join(CODE_ASSISTANT_PROJECTS.keys())}")
        sys.exit(1)

    if not check_code_assistant():
        print(f"{RED}Code Assistant offline{RESET} ({_CA_LABEL})")
        sys.exit(1)

    print(f"\n  {CYAN}Reindexing {ca_key}...{RESET}")
    with Spinner(f"Reindexing {ca_key}"):
        result = code_assistant_post(f'projects/{ca_key}/reindex', {}, timeout=300)

    # Clear stale caches after reindex
    import glob as _glob
    for f in _glob.glob(str(CODE_CACHE_DIR / f'{ca_key}_*.json')):
        os.remove(f)

    if result and result.get('success'):
        code_info = result.get('code', {}) or {}
        doc_info = result.get('doc', {}) or {}
        c_proc = code_info.get('processed_files', 0)
        c_skip = code_info.get('skipped_files', 0)
        c_total = code_info.get('total_files', 0)
        d_proc = doc_info.get('processed_files', 0)
        d_skip = doc_info.get('skipped_files', 0)
        d_total = doc_info.get('total_files', 0)
        elapsed = code_info.get('elapsed_time', 0) + doc_info.get('elapsed_time', 0)
        errors = code_info.get('errors', 0) + doc_info.get('errors', 0)
        print(f"  {GREEN}✓{RESET} {ca_key}: {c_proc} code + {d_proc} docs updated, "
              f"{c_skip + d_skip} unchanged ({c_total + d_total} total, {elapsed:.1f}s)")
        if errors:
            print(f"  {YELLOW}{errors} errors{RESET}")
        warnings = result.get('warnings', [])
        if warnings:
            for w in warnings[:5]:
                print(f"  {YELLOW}⚠ {w}{RESET}")
    else:
        err = result.get('error', 'unknown') if result else 'no response'
        print(f"  {RED}✗{RESET} Reindex failed: {err}")
    print()


