def _stream_ask_with_tools(ca_key, question, timeout=180, model=None, use_tools=True):
    """Stream ask/stream endpoint. Yields (event_type, data) tuples.

    Event types: 'meta', 'tool_call', 'tool_result', 'chunk', 'done'
    """
    url = f'{CODE_ASSISTANT_URL}/ask/stream'
    payload = {
        'question': question,
        'project': ca_key,
        'use_tools': use_tools,
    }
    if model:
        payload['settings'] = {'model': model}
    body = json.dumps(payload).encode()

    req = urllib.request.Request(url, data=body,
        headers={'Content-Type': 'application/json', 'Accept': 'text/event-stream'})

    with urllib.request.urlopen(req, timeout=timeout) as resp:
        buf = b''
        for raw in resp:
            buf += raw
            # SSE lines end with \n\n — process complete events
            while b'\n\n' in buf:
                event_data, buf = buf.split(b'\n\n', 1)
                for line in event_data.decode('utf-8', errors='replace').split('\n'):
                    line = line.strip()
                    if line.startswith('data: '):
                        try:
                            obj = json.loads(line[6:])
                            yield (obj.get('type', ''), obj)
                        except json.JSONDecodeError:
                            pass


def cmd_search(hub_key, query):
    """Search codebase using tools-enabled agent (reads files, chains searches, answers)."""
    ca_key = resolve_code_project(hub_key)
    if not ca_key:
        print(f"Project '{hub_key}' is not indexed in Code Assistant")
        print(f"Indexed: {', '.join(CODE_ASSISTANT_PROJECTS.keys())}")
        sys.exit(1)

    # Check cache — cached results contain the full answer
    cached = _read_cache(hub_key, 'search', query, TTL_SEARCH)
    if cached:
        result = cached['data']
        answer = result.get('answer', '')
        files_used = result.get('files_used', [])

        if IN_OI:
            meta_parts = [hub_key]
            if files_used:
                meta_parts.append(f"{len(files_used)} files")
            meta_parts.append('cached')
            print(f"[Code Search — {', '.join(meta_parts)}]")
            print(_truncate(answer, 1800))
            if files_used:
                fnames = [_basename(f) for f in files_used[:6]]
                print(f"Files: {', '.join(fnames)}")
        else:
            print()
            meta_parts = [hub_key]
            if files_used:
                meta_parts.append(f"{len(files_used)} files")
            meta_parts.append('cached')
            print_right(f"  {WHITE}Search: \"{query}\" in {hub_key}{RESET}",
                         f"{GRAY}{', '.join(meta_parts)}{RESET}")
            divider()
            print()
            for line in answer.split('\n'):
                print(f"  {line}")
            if files_used:
                print()
                print(f"  {CYAN}Files referenced:{RESET}")
                for f in files_used[:8]:
                    print(f"    {DIM}{_basename(f)}{RESET}")
            print()
        return

    # Live query with tools
    if not check_code_assistant():
        print(f"{'Code Assistant offline ({_CA_LABEL})' if IN_OI else f'{RED}Code Assistant offline{RESET} ({_CA_LABEL})'}")
        sys.exit(1)

    if not IN_OI:
        print()
        print_right(f"  {WHITE}Search: \"{query}\" in {hub_key}{RESET}", f"{GRAY}tools enabled{RESET}")
        divider()
        print()

    answer_chunks = []
    files_used = []
    tool_calls_seen = []
    start = time.time()

    try:
        for evt_type, evt in _stream_ask_with_tools(ca_key, query, model=MODEL_TOOLS):
            if evt_type == 'tool_call':
                tool = evt.get('tool', '')
                args = evt.get('arguments', {})
                tool_calls_seen.append(tool)
                if IN_OI:
                    if tool == 'search_code':
                        print(f"  [searching: {args.get('query', '')}]")
                    elif tool == 'read_files':
                        paths = args.get('paths', [])
                        fnames = [_basename(p) for p in paths[:3]]
                        print(f"  [reading: {', '.join(fnames)}]")
                    elif tool == 'list_files':
                        print(f"  [listing: {args.get('path', '/')}]")
                    elif tool != 'respond':
                        print(f"  [{tool}]")
                else:
                    if tool == 'search_code':
                        print(f"  {DIM}⟳ searching: {args.get('query', '')}{RESET}")
                    elif tool == 'read_files':
                        paths = args.get('paths', [])
                        fnames = [_basename(p) for p in paths[:3]]
                        print(f"  {DIM}⟳ reading: {', '.join(fnames)}{RESET}")
                    elif tool == 'list_files':
                        print(f"  {DIM}⟳ listing: {args.get('path', '/')}{RESET}")
                    elif tool != 'respond':
                        print(f"  {DIM}⟳ {tool}{RESET}")

            elif evt_type == 'chunk':
                chunk = evt.get('content', '')
                answer_chunks.append(chunk)
                if IN_OI:
                    sys.stdout.write(chunk)
                    sys.stdout.flush()
                else:
                    sys.stdout.write(chunk)
                    sys.stdout.flush()

            elif evt_type == 'done':
                files_used = evt.get('files_used', [])

    except Exception as e:
        if not answer_chunks:
            print(f"{'Search failed: ' + str(e) if IN_OI else f'{RED}Search failed:{RESET} {e}'}")
            sys.exit(1)

    answer = ''.join(answer_chunks)
    elapsed = time.time() - start

    # Trailing newline after streamed output
    if answer_chunks:
        print()

    if IN_OI:
        if files_used:
            fnames = [_basename(f) for f in files_used[:6]]
            print(f"Files: {', '.join(fnames)}")
        print(f"[{len(tool_calls_seen)} tool calls, {elapsed:.1f}s]")
    else:
        if files_used:
            print()
            print(f"  {CYAN}Files referenced:{RESET}")
            for f in files_used[:8]:
                print(f"    {DIM}{_basename(f)}{RESET}")
        print()
        print(f"  {GRAY}{len(tool_calls_seen)} tool calls | {elapsed:.1f}s{RESET}")
        print()

    # Cache the result
    _write_cache(hub_key, 'search', query, {
        'answer': answer,
        'files_used': files_used,
        'tool_calls': tool_calls_seen,
        'elapsed': elapsed,
    })
    _write_last(hub_key, 'search', {
        'answer': answer,
        'files_used': files_used,
    })


def cmd_ask(hub_key, question):
    """RAG architecture question — uses LLM on AGX."""
    ca_key = resolve_code_project(hub_key)
    if not ca_key:
        print(f"Project '{hub_key}' is not indexed in Code Assistant")
        print(f"Indexed: {', '.join(CODE_ASSISTANT_PROJECTS.keys())}")
        sys.exit(1)

    # Check cache
    cached = _read_cache(hub_key, 'ask', question, TTL_ASK)
    if cached:
        result = cached['data']
        from_cache = True
    else:
        if not check_code_assistant():
            print(f"{'Code Assistant offline ({_CA_LABEL})' if IN_OI else f'{RED}Code Assistant offline{RESET} ({_CA_LABEL})'}")
            sys.exit(1)

        from_cache = False
        with Spinner(f"Asking Code Assistant about {hub_key}..."):
            result = code_assistant_post('ask', {
                'question': question, 'project': ca_key,
                'model': MODEL_ASK,
            }, timeout=120)

        if result is None:
            print('Ask request failed (timeout or error)')
            sys.exit(1)

        cache_file = _write_cache(hub_key, 'ask', question, result)
        _write_last(hub_key, 'ask', result)

    answer = result.get('answer', '')
    files = result.get('files_used', [])
    context_size = result.get('context_size', 0)

    if IN_OI:
        meta_parts = [hub_key]
        if files:
            meta_parts.append(f"{len(files)} files")
        if context_size:
            meta_parts.append(f"{context_size // 1000}K context")
        if from_cache:
            meta_parts.append('cached')
        print(f"[Code Assistant — {', '.join(meta_parts)}]")
        truncated = _truncate(answer, 1500)
        print(truncated)
        if files:
            fnames = [_basename(f) if isinstance(f, str) else _basename(f.get('file_path', '')) for f in files[:6]]
            print(f"Files: {', '.join(fnames)}")
        if len(answer) > 1500:
            h = _cache_key(hub_key, 'ask', question)
            print(f"Full result: ~/.cache/code/{hub_key}_ask_{h}.json")
    else:
        print()
        meta_parts = [hub_key]
        if files:
            meta_parts.append(f"{len(files)} files")
        if context_size:
            meta_parts.append(f"{context_size // 1000}K context")
        if from_cache:
            meta_parts.append('cached')
        print_right(
            f"  {WHITE}Ask: {hub_key}{RESET}",
            f"{GRAY}{', '.join(meta_parts)}{RESET}"
        )
        divider()
        print()
        for line in answer.split('\n'):
            print(f"  {line}")
        if files:
            print()
            print(f"  {CYAN}Files referenced:{RESET}")
            for f in files[:8]:
                fname = f if isinstance(f, str) else f.get('file_path', '')
                print(f"    {DIM}{_basename(fname)}{RESET}")
        print()


def cmd_impact(hub_key, file_path):
    """Show what depends on a file."""
    ca_key = resolve_code_project(hub_key)
    if not ca_key:
        print(f"Project '{hub_key}' is not indexed in Code Assistant")
        print(f"Indexed: {', '.join(CODE_ASSISTANT_PROJECTS.keys())}")
        sys.exit(1)

    # Check cache
    cached = _read_cache(hub_key, 'impact', file_path, TTL_IMPACT)
    if cached:
        result = cached['data']
    else:
        if not check_code_assistant():
            print(f"{'Code Assistant offline ({_CA_LABEL})' if IN_OI else f'{RED}Code Assistant offline{RESET} ({_CA_LABEL})'}")
            sys.exit(1)

        result = code_assistant_post('impact', {
            'file_path': file_path, 'project': ca_key
        }, timeout=30)

        if result is None:
            print('Impact request failed')
            sys.exit(1)

        _write_cache(hub_key, 'impact', file_path, result)
        _write_last(hub_key, 'impact', result)

    direct = result.get('direct_dependents', [])
    indirect = result.get('indirect_dependents', [])
    risk = result.get('risk_level', 'unknown')
    total = result.get('total_affected', 0)

    if IN_OI:
        print(f"Impact: {_basename(file_path)} in {hub_key} — {total} affected, risk: {risk}")
        if direct:
            print(f"Direct ({len(direct)}):")
            for d in direct[:8]:
                fname = d if isinstance(d, str) else d.get('file_path', str(d))
                print(f"  {_basename(fname)}")
        if indirect:
            print(f"Indirect ({len(indirect)}):")
            for d in indirect[:5]:
                fname = d if isinstance(d, str) else d.get('file_path', str(d))
                print(f"  {_basename(fname)}")
    else:
        print()
        risk_color = GREEN if risk == 'low' else YELLOW if risk == 'medium' else RED
        print(f"  {WHITE}Impact: {_basename(file_path)}{RESET}  {risk_color}{risk} risk{RESET}  ({total} affected)")
        divider()
        if direct:
            print(f"  {CYAN}Direct dependents ({len(direct)}):{RESET}")
            for d in direct[:10]:
                fname = d if isinstance(d, str) else d.get('file_path', str(d))
                print(f"    {_basename(fname)}")
        if indirect:
            print(f"  {CYAN}Indirect dependents ({len(indirect)}):{RESET}")
            for d in indirect[:8]:
                fname = d if isinstance(d, str) else d.get('file_path', str(d))
                print(f"    {DIM}{_basename(fname)}{RESET}")
        if not direct and not indirect:
            print(f"  {GRAY}No dependents found{RESET}")
        print()


