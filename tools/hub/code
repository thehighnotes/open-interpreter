def _cache_key(hub_key, cmd, query):
    """Generate a short hash for cache filename."""
    h = hashlib.md5(f'{hub_key}:{cmd}:{query}'.encode()).hexdigest()[:8]
    return h


def _read_cache(hub_key, cmd, query, ttl):
    """Read cached result if fresh enough. Returns dict or None."""
    h = _cache_key(hub_key, cmd, query)
    cache_file = CODE_CACHE_DIR / f'{hub_key}_{cmd}_{h}.json'
    if not cache_file.exists():
        return None
    try:
        data = json.loads(cache_file.read_text())
        if time.time() - data.get('ts', 0) < ttl:
            return data
    except (json.JSONDecodeError, OSError):
        pass
    return None


def _write_cache(hub_key, cmd, query, result):
    """Write result to cache file."""
    h = _cache_key(hub_key, cmd, query)
    ensure_dir(CODE_CACHE_DIR)
    cache_file = CODE_CACHE_DIR / f'{hub_key}_{cmd}_{h}.json'
    data = {'ts': time.time(), 'hub_key': hub_key, 'cmd': cmd, 'query': query, 'data': result}
    cache_file.write_text(json.dumps(data, indent=2))
    return cache_file


def _write_last(hub_key, cmd, result):
    """Write latest query result for preamble injection."""
    ensure_dir(CODE_CACHE_DIR)
    last_file = CODE_CACHE_DIR / f'{hub_key}_last.json'
    data = {'ts': time.time(), 'type': cmd, 'data': result}
    last_file.write_text(json.dumps(data, indent=2))


