def age_color(age_days):
    """Return ANSI color based on item age."""
    if age_days <= 7:
        return WHITE
    elif age_days <= 30:
        return GRAY
    return DIM


def render_all_projects():
    """Render compact research digest for all projects."""
    print()
    header_bar()
    now = datetime.now().strftime('%a %d %b %H:%M')
    print_right(f"{BRIGHT_GREEN}  RESEARCH DIGEST{RESET}", f"{BRIGHT_GREEN}{now}{RESET}")
    header_bar()
    print()

    any_findings = False

    for pk in PROJECT_ORDER:
        digest_file = CACHE_DIR / f'{pk}.json'
        if not digest_file.exists():
            continue

        try:
            digest = json.loads(digest_file.read_text())
        except (json.JSONDecodeError, OSError):
            continue

        papers = digest.get('high_relevance', [])
        releases = digest.get('releases', [])

        if not papers and not releases:
            continue

        any_findings = True
        proj = PROJECTS[pk]
        print(f"  {CYAN}{proj['name']}{RESET}")
        divider()

        # Top 3 papers
        for item in papers[:3]:
            score = item.get('score', 0)
            age = item.get('age_days', 0)
            color = age_color(age)
            score_color = GREEN if score >= 8 else YELLOW
            age_label = f"{age}d" if age > 0 else "today"
            print(f"    {score_color}[{score:2d}]{RESET} {color}{item['title'][:65]}{RESET} {GRAY}({age_label}){RESET}")

        # Top 2 releases
        for item in releases[:2]:
            score = item.get('score', 0)
            score_color = GREEN if score >= 8 else YELLOW
            print(f"    {score_color}[{score:2d}]{RESET} {CYAN}↑{RESET} {item['title'][:65]}")

        remaining_papers = max(0, len(papers) - 3)
        remaining_releases = max(0, len(releases) - 2)
        if remaining_papers or remaining_releases:
            parts = []
            if remaining_papers:
                parts.append(f"+{remaining_papers} more papers")
            if remaining_releases:
                parts.append(f"+{remaining_releases} more releases")
            print(f"    {GRAY}{', '.join(parts)}{RESET}")

        print()

    if not any_findings:
        print(f"  {GRAY}No research data yet. Run {WHITE}research --fetch{GRAY} first.{RESET}")
        print()

    # Status line
    state = load_state()
    last_fetch = state.get('arxiv_last_fetch', 'never')
    items_data = load_items()
    total = len(items_data.get('items', []))
    header_bar()
    print(f"{GRAY}  Last fetch: {last_fetch} | {total} items in cache | threshold: {RELEVANCE_THRESHOLD}{RESET}")
    header_bar()


def render_project_detail(project_key):
    """Render detailed research view for a single project."""
    proj = PROJECTS[project_key]
    digest_file = CACHE_DIR / f'{project_key}.json'

    print()
    header_bar()
    now = datetime.now().strftime('%a %d %b %H:%M')
    print_right(f"{BRIGHT_GREEN}  RESEARCH — {proj['name']}{RESET}", f"{BRIGHT_GREEN}{now}{RESET}")
    header_bar()
    print()

    if not digest_file.exists():
        print(f"  {GRAY}No research data for {proj['name']}.{RESET}")
        print(f"  {GRAY}Run {WHITE}research --fetch{GRAY} first.{RESET}")
        print()
        header_bar()
        return

    try:
        digest = json.loads(digest_file.read_text())
    except (json.JSONDecodeError, OSError):
