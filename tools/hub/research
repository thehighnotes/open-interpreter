def do_calibrate():
    """Score test items and display threshold matrix."""
    ollama_host_name = HOSTS.get(OLLAMA_HOST, {}).get('name', OLLAMA_HOST)
    if OLLAMA_HOST != LOCAL_HOST and not check_host_reachable(OLLAMA_HOST):
        print(f"{RED}● {ollama_host_name} is offline — cannot calibrate{RESET}")
        sys.exit(1)

    print()
    header_bar()
    print(f"{BRIGHT_GREEN}  RESEARCH CALIBRATION{RESET}")
    header_bar()
    print()

    print(f"  {WHITE}Loading project contexts...{RESET}")
    project_contexts = build_project_contexts()

    print(f"  {WHITE}Scoring {len(CALIBRATION_ITEMS)} test items...{RESET}")
    print()

    results = []
    for item in CALIBRATION_ITEMS:
        with Spinner(f"Scoring: {item['title'][:50]}..."):
            scores = score_item(item, project_contexts)
        results.append((item, scores))

    # Display matrix
    # Header row
    proj_labels = [pk[:6] for pk in PROJECT_ORDER]
    header = f"  {'Item':<45s} " + ' '.join(f'{l:>6s}' for l in proj_labels)
    print(f"  {WHITE}Score Matrix{RESET} (threshold: {RELEVANCE_THRESHOLD})")
    divider()
    print(f"{WHITE}{header}{RESET}")
    divider()

    for item, scores in results:
        label = item['title'][:44]
        cols_str = ''
        for pk in PROJECT_ORDER:
            s = scores.get(pk, {}).get('score', 0)
            if s >= 8:
                color = GREEN
            elif s >= RELEVANCE_THRESHOLD:
                color = YELLOW
            elif s >= 3:
                color = GRAY
            else:
                color = DIM
            cols_str += f' {color}{s:>6d}{RESET}'
        print(f"  {label:<45s}{cols_str}")

    print()

    # Show reasons for high scores
    print(f"  {WHITE}High-scoring reasons:{RESET}")
    divider()
    for item, scores in results:
        for pk in PROJECT_ORDER:
            s = scores.get(pk, {}).get('score', 0)
            if s >= RELEVANCE_THRESHOLD:
                reason = scores[pk].get('reason', '?')
                print(f"  {GREEN}{pk}{RESET} [{s}] {item['title'][:40]}: {reason}")

    print()
    header_bar()


