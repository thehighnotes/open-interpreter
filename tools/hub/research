def do_fetch():
    """Main fetch + score pipeline. Called by --fetch."""
    ensure_cache_dir()
    now = datetime.now(timezone.utc).strftime('%Y-%m-%dT%H:%M:%S')

    # Check AGX is reachable (needed for Ollama scoring)
    ollama_host_name = HOSTS.get(OLLAMA_HOST, {}).get('name', OLLAMA_HOST)
    if OLLAMA_HOST != LOCAL_HOST and not check_host_reachable(OLLAMA_HOST):
        print(f"{RED}● {ollama_host_name} is offline — cannot score items{RESET}")
        sys.exit(1)

    state = load_state()
    items_data = load_items()
    known_ids = set(state.get('known_ids', []))

    # Fetch from sources
    print(f"  {WHITE}[1/4]{RESET} Fetching from sources...")

    new_items = []

    with Spinner("Fetching arxiv..."):
        arxiv_items = fetch_arxiv(known_ids)
    print(f"  {GREEN}●{RESET} arxiv: {len(arxiv_items)} new papers")
    new_items.extend(arxiv_items)

    with Spinner("Fetching GitHub releases..."):
        github_items, project_repo_map = fetch_github_releases(known_ids)
    project_repo_count = len(project_repo_map)
    global_count = len(GITHUB_REPOS)
    total_repos = len(set(GITHUB_REPOS) | set(project_repo_map.keys()))
    print(f"  {GREEN}●{RESET} GitHub: {len(github_items)} new releases ({total_repos} repos: {global_count} global + {project_repo_count} project-specific)")
    new_items.extend(github_items)

    if not new_items:
        print(f"\n  {GRAY}No new items to score.{RESET}")
        state['arxiv_last_fetch'] = now
        save_state(state)
        # Still regenerate digests in case threshold changed
        generate_digests(items_data)
        return

    # Build project contexts for scoring
    print(f"\n  {WHITE}[2/4]{RESET} Loading project contexts...")
    project_contexts = build_project_contexts()

    contexts_loaded = sum(1 for v in project_contexts.values() if 'no overview cache' not in v)
    print(f"  {GREEN}●{RESET} {contexts_loaded}/{len(PROJECT_ORDER)} project contexts loaded")

    # Score each new item
    print(f"\n  {WHITE}[3/4]{RESET} Scoring {len(new_items)} items via Ollama...")

    scored_count = 0
    failed_count = 0

    for i, item in enumerate(new_items):
        label = item['title'][:60]
        with Spinner(f"[{i+1}/{len(new_items)}] {label}..."):
            scores = score_item(item, project_contexts)

        if scores:
            item['scores'] = scores
            scored_count += 1
            # Show top score
            top_proj = max(scores.keys(), key=lambda k: scores[k]['score'])
            top_score = scores[top_proj]['score']
            color = GREEN if top_score >= 6 else YELLOW if top_score >= 3 else GRAY
            print(f"  {color}●{RESET} [{top_score:2d}] {item['title'][:70]}")
        else:
            failed_count += 1
            print(f"  {RED}●{RESET} Failed: {item['title'][:70]}")

    # Merge new items into cache
    items_data['items'].extend([item for item in new_items if item.get('scores')])
    items_data['last_fetch'] = now

    # Update known_ids
    for item in new_items:
        known_ids.add(item['id'])
    state['known_ids'] = list(known_ids)
    state['arxiv_last_fetch'] = now

    # Prune old items
    print(f"\n  {WHITE}[4/4]{RESET} Pruning and generating digests...")

    items_data, pruned = prune_old_items(items_data)
    if pruned:
        print(f"  {GRAY}Pruned {pruned} items older than 30 days{RESET}")

    save_items(items_data)
    save_state(state)
    generate_digests(items_data)

    print(f"\n  {GREEN}●{RESET} Done: {scored_count} scored, {failed_count} failed, {len(items_data['items'])} total in cache")
    if scored_count > 0:
        hub_notify("Research", f"{scored_count} new items scored", source='research')


