        for item in releases:
            score = item.get('score', 0)
            score_color = GREEN if score >= 8 else YELLOW
            age = item.get('age_days', 0)
            age_label = f"{age}d ago" if age > 0 else "today"

            print(f"    {score_color}[{score:2d}]{RESET} {CYAN}↑{RESET} {item['title']}")
            print(f"         {GRAY}{item.get('url', '')}  ({age_label}){RESET}")
            reason = item.get('reason', '')
            if reason:
                print(f"         {DIM}{reason}{RESET}")
            actionable = item.get('actionable', '')
