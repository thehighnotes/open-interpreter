def build_project_contexts():
    """Build scoring context from overview cache. Returns dict of {key: context_str}."""
    contexts = {}
    for pk in PROJECT_ORDER:
        cache_file = OVERVIEW_CACHE_DIR / f'{pk}.json'
        if not cache_file.exists():
            contexts[pk] = f'{pk}: (no overview cache)'
            continue
        try:
            data = json.loads(cache_file.read_text())
            phase = data.get('phase', '?')
            focus = ', '.join(data.get('current_focus', [])[:3])
            tech = ', '.join(data.get('tech_stack', [])[:5])
            blockers = ', '.join(data.get('blockers', [])[:2])
            contexts[pk] = (
                f"Phase={phase}. "
                f"Focus: {focus or 'unknown'}. "
                f"Tech: {tech or 'unknown'}. "
                f"Blockers: {blockers or 'none'}"
            )
        except (json.JSONDecodeError, OSError):
            contexts[pk] = f'{pk}: (cache read error)'
    return contexts


def score_item(item, project_contexts):
    """Score a single item against all projects via Ollama on AGX.

    Returns scores dict: {project_key: {score: N, reason: "...", actionable: "..."}}
    """
    source = item.get('source', 'unknown')
    title = item.get('title', '')
    abstract = item.get('abstract', '')
    source_projects = item.get('source_projects', [])

    projects_block = '\n'.join(
        f'  {pk}: {ctx}' for pk, ctx in project_contexts.items()
    )

    # Note if this item came from a project-specific repo
    source_hint = ''
    if source_projects:
        source_hint = f'\n  Tracked by: {", ".join(source_projects)} (score these projects carefully — this is a dependency they use)'

    system_msg = '/no_think\nYou are a relevance scoring tool for a multi-project development hub. Output ONLY a JSON object. No other text.'

    user_msg = f"""Score this item's relevance to each project (0-10) and explain how it could be applied.

Scoring rules:
- 0 = completely unrelated — no connection to the project's domain or tech
- 3 = tangentially related — same broad field but no direct application
- 5 = loosely related — shares some technology but not directly useful now
- 7 = relevant — addresses a technology or technique the project uses
- 8 = highly relevant — directly applicable to current work or active focus
- 10 = critical — solves an active blocker or is a direct dependency update

IMPORTANT: Only score ≥6 if the item directly mentions a technology the project uses, addresses a listed blocker, or is a tracked dependency release. Broad-field overlap alone is NOT enough for ≥6.

Item:
  Source: {source}
  Title: {title}
  Content: {abstract[:3000]}{source_hint}

Projects:
{projects_block}

Return: {{{', '.join(f'"{pk}": {{"score": N, "reason": "brief justification", "actionable": "how this could be applied (or empty if score < 7)"}}' for pk in PROJECT_ORDER)}}}"""

    data = ollama_query(
        model=DEFAULT_MODEL,
        system_msg=system_msg,
        user_msg=user_msg,
        timeout=90,
        temperature=0.2,
        num_predict=1024,
    )

    if data is None:
        return {}
    return parse_scores_from_dict(data)


def parse_scores_from_dict(data):
    """Validate and extract scores from already-parsed LLM JSON dict."""
    if not isinstance(data, dict):
        return {}

    scores = {}
    for pk in PROJECT_ORDER:
        if pk in data and isinstance(data[pk], dict):
            score = data[pk].get('score', 0)
            reason = data[pk].get('reason', '')
            actionable = data[pk].get('actionable', '')
            try:
                score = int(float(score))
            except (ValueError, TypeError):
                score = 0
            entry = {'score': max(0, min(10, score)), 'reason': str(reason)[:200]}
            if actionable and str(actionable).strip():
                entry['actionable'] = str(actionable)[:300]
            scores[pk] = entry
    return scores


