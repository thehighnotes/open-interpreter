def print_usage():
    print(f"""
{WHITE}research{RESET} — Continuous researcher for the Orin Nano hub

{WHITE}Usage:{RESET}
  research                     All projects' research digests
  research <project>           Detailed view for one project
  research --fetch             Fetch + score (cron mode)
  research --calibrate         Score test items, show threshold matrix
  research --status            Fetch state, item counts, source health
  research --help

{WHITE}Projects:{RESET}
  {', '.join(PROJECT_ORDER) if PROJECT_ORDER else '(none — run hub --scan first)'}

{WHITE}Sources:{RESET}
  arxiv:   {', '.join(ARXIV_CATEGORIES)}
  GitHub:  {', '.join(GITHUB_REPOS)} (global)
  + per-project repos from projects.json (auto-discovered from sessions)

{WHITE}Cron:{RESET}
  0 */6 * * * ~/research --fetch >> ~/.cache/research/research.log 2>&1
""")


def main():
    args = sys.argv[1:]

    if '-h' in args or '--help' in args:
        print_usage()
        sys.exit(0)

    ensure_cache_dir()

    if '--fetch' in args:
        do_fetch()
        return

    if '--calibrate' in args:
        do_calibrate()
        return

    if '--status' in args:
        render_status()
        return

    # Remove flags
    clean_args = [a for a in args if not a.startswith('--')]

    if not clean_args:
        render_all_projects()
    else:
        project_key = resolve_project(clean_args[0])
        if not project_key:
            sys.exit(1)
        render_project_detail(project_key)


if __name__ == '__main__':
    main()
