def fetch_arxiv(known_ids):
    """Fetch recent arxiv papers matching categories and keywords.

    Returns list of new item dicts (not yet scored).
    """
    try:
        import urllib.request
        import xml.etree.ElementTree as ET
    except ImportError as e:
        print(f"  {RED}● Missing module: {e}{RESET}")
        return []

    # Build query: categories OR'd, filtered by title keywords
    cat_query = '+OR+'.join(f'cat:{cat}' for cat in ARXIV_CATEGORIES)
    url = (f'http://export.arxiv.org/api/query?search_query={cat_query}'
           f'&sortBy=submittedDate&sortOrder=descending'
           f'&max_results={ARXIV_MAX_RESULTS}')

    try:
        req = urllib.request.Request(url, headers={'User-Agent': 'research-monitor/1.0'})
        with urllib.request.urlopen(req, timeout=30) as resp:
            xml_data = resp.read()
    except Exception as e:
        print(f"  {RED}● arxiv fetch failed: {e}{RESET}")
        return []

    # Parse Atom feed
    ns = {'atom': 'http://www.w3.org/2005/Atom'}
    try:
        root = ET.fromstring(xml_data)
    except ET.ParseError as e:
        print(f"  {RED}● arxiv parse failed: {e}{RESET}")
        return []

    items = []
    keywords_lower = [kw.lower() for kw in ARXIV_KEYWORDS]

    for entry in root.findall('atom:entry', ns):
        title_el = entry.find('atom:title', ns)
        summary_el = entry.find('atom:summary', ns)
        published_el = entry.find('atom:published', ns)
        id_el = entry.find('atom:id', ns)

        if title_el is None or id_el is None:
            continue

        title = ' '.join(title_el.text.strip().split())
        abstract = summary_el.text.strip() if summary_el is not None else ''
        arxiv_url = id_el.text.strip()

        # Extract arxiv ID from URL
        arxiv_id = arxiv_url.split('/abs/')[-1] if '/abs/' in arxiv_url else arxiv_url
        item_id = f'arxiv:{arxiv_id}'

        if item_id in known_ids:
            continue

        # Keyword filter on title
        title_lower = title.lower()
        if not any(kw in title_lower for kw in keywords_lower):
            continue

        # Parse published date
        published = ''
        if published_el is not None:
            try:
                pub_dt = datetime.strptime(published_el.text[:10], '%Y-%m-%d')
                published = pub_dt.strftime('%Y-%m-%d')
            except ValueError:
                published = published_el.text[:10]

        items.append({
            'id': item_id,
            'source': 'arxiv',
            'title': title,
            'url': f'https://arxiv.org/abs/{arxiv_id}',
            'published': published,
            'fetched': datetime.now(timezone.utc).strftime('%Y-%m-%dT%H:%M:%S'),
            'abstract': abstract[:4000],
            'scores': {},
        })

    return items


def _collect_all_github_repos():
    """Build combined set of global + per-project GitHub repos.

    Returns (all_repos_set, project_repo_map) where project_repo_map is
    {repo: [project_keys]} for per-project repos (used for scoring context).
    """
    all_repos = set(GITHUB_REPOS)
    project_repo_map = {}  # repo → [project_keys that care about it]

    for pk in PROJECT_ORDER:
        proj = PROJECTS[pk]
        for repo in proj.get('related_repos', []):
            all_repos.add(repo)
            project_repo_map.setdefault(repo, []).append(pk)

    return all_repos, project_repo_map


def fetch_github_releases(known_ids):
    """Fetch latest releases from tracked GitHub repos (global + per-project).

    Returns (items_list, project_repo_map) where project_repo_map links
    per-project repos to their owning projects for scoring context.
    """
    try:
        import urllib.request
    except ImportError:
        return [], {}

    all_repos, project_repo_map = _collect_all_github_repos()
    items = []

    for repo in sorted(all_repos):
        url = f'https://api.github.com/repos/{repo}/releases?per_page=3'
        try:
            req = urllib.request.Request(url, headers={
                'User-Agent': 'research-monitor/1.0',
                'Accept': 'application/vnd.github.v3+json',
            })
            with urllib.request.urlopen(req, timeout=15) as resp:
                releases = json.loads(resp.read())
        except Exception as e:
            print(f"  {YELLOW}● GitHub {repo}: {e}{RESET}")
            continue

        if not isinstance(releases, list):
            continue

        for release in releases:
            tag = release.get('tag_name', '')
            item_id = f'github:{repo}:{tag}'

            if item_id in known_ids:
                continue

            name = release.get('name', '') or tag
            body = release.get('body', '') or ''
            published_at = release.get('published_at', '')
            html_url = release.get('html_url', '')

            # Parse published date
            published = ''
            if published_at:
                try:
                    pub_dt = datetime.strptime(published_at[:10], '%Y-%m-%d')
                    published = pub_dt.strftime('%Y-%m-%d')
                except ValueError:
                    published = published_at[:10]

            item = {
                'id': item_id,
                'source': 'github',
                'title': f'{repo} {name}',
                'url': html_url,
                'published': published,
                'fetched': datetime.now(timezone.utc).strftime('%Y-%m-%dT%H:%M:%S'),
                'abstract': body[:4000],
                'scores': {},
            }

            # Tag with source projects if this is a per-project repo
            if repo in project_repo_map:
                item['source_projects'] = project_repo_map[repo]

            items.append(item)

    return items, project_repo_map


