# Research config — reads from hub config with hardcoded fallback defaults
# ─────────────────────────────────────────────────────────────────────────────
_research_cfg = HUB_CONFIG.get('research', {})

RELEVANCE_THRESHOLD = _research_cfg.get('threshold', 7)

ARXIV_CATEGORIES = _research_cfg.get('arxiv_categories',
    ['eess.AS', 'cs.SD', 'cs.CL', 'cs.LG', 'cs.AI'])

ARXIV_KEYWORDS = _research_cfg.get('arxiv_keywords', [
    'TTS', 'speech', 'synthesis', 'voice', 'vocoder',
    'transformer', 'memory', 'attention', 'inference', 'embedding',
    'knowledge graph', 'continual learning', 'curriculum',
    'interactive', 'tutorial',
])

ARXIV_MAX_RESULTS = _research_cfg.get('arxiv_max_results', 30)

GITHUB_REPOS = _research_cfg.get('github_repos', [
    'NVIDIA/TensorRT',
    'ollama/ollama',
    'pytorch/pytorch',
    'ggml-org/llama.cpp',
])


# ─────────────────────────────────────────────────────────────────────────────
# Cache management
# ─────────────────────────────────────────────────────────────────────────────

def ensure_cache_dir():
    ensure_dir(CACHE_DIR)


def load_items():
    """Load all scored items from cache. Returns dict with 'items' list."""
    items_file = CACHE_DIR / 'items.json'
    if not items_file.exists():
        return {'version': 1, 'last_fetch': None, 'items': []}
    try:
        return json.loads(items_file.read_text())
    except (json.JSONDecodeError, OSError):
        return {'version': 1, 'last_fetch': None, 'items': []}


def save_items(data):
    """Save all scored items to cache."""
    ensure_cache_dir()
    items_file = CACHE_DIR / 'items.json'
    items_file.write_text(json.dumps(data, indent=2))


def load_state():
    """Load fetch state (deduplication + timestamps). Returns dict."""
    state_file = CACHE_DIR / 'state.json'
    if not state_file.exists():
        return {'arxiv_last_fetch': None, 'github_last_fetch': {}, 'known_ids': []}
    try:
        return json.loads(state_file.read_text())
    except (json.JSONDecodeError, OSError):
        return {'arxiv_last_fetch': None, 'github_last_fetch': {}, 'known_ids': []}


def save_state(state):
    """Save fetch state."""
    ensure_cache_dir()
    state_file = CACHE_DIR / 'state.json'
    state_file.write_text(json.dumps(state, indent=2))


def generate_digests(items_data):
    """Generate per-project digest JSON files from scored items."""
    ensure_cache_dir()
    now = datetime.now(timezone.utc).strftime('%Y-%m-%dT%H:%M:%S')

    for pk in PROJECT_ORDER:
        high_relevance = []
        releases = []

        for item in items_data.get('items', []):
            scores = item.get('scores', {})
            proj_score = scores.get(pk, {})
            score_val = proj_score.get('score', 0)

            if score_val < RELEVANCE_THRESHOLD:
                continue

            # Calculate age
            try:
                pub_date = datetime.strptime(item['published'], '%Y-%m-%d')
                age_days = (datetime.now() - pub_date).days
            except (ValueError, KeyError):
                age_days = 0

            entry = {
                'title': item.get('title', ''),
                'url': item.get('url', ''),
                'source': item.get('source', ''),
                'published': item.get('published', ''),
                'score': score_val,
                'reason': proj_score.get('reason', ''),
                'actionable': proj_score.get('actionable', ''),
                'age_days': age_days,
            }

            if item.get('source') == 'github':
                releases.append(entry)
            else:
                high_relevance.append(entry)

        # Sort by score descending
        high_relevance.sort(key=lambda x: x['score'], reverse=True)
        releases.sort(key=lambda x: x['score'], reverse=True)

        # Build summary
        paper_count = len(high_relevance)
        release_count = len(releases)
        summary_parts = []
        if paper_count:
            summary_parts.append(f"{paper_count} relevant paper{'s' if paper_count != 1 else ''}")
        if release_count:
            summary_parts.append(f"{release_count} tracked release{'s' if release_count != 1 else ''}")
        summary = ', '.join(summary_parts) if summary_parts else 'no relevant items'

        digest = {
            'generated': now,
            'project': pk,
            'high_relevance': high_relevance[:10],
            'releases': releases[:10],
            'summary': summary,
        }

        digest_file = CACHE_DIR / f'{pk}.json'
        digest_file.write_text(json.dumps(digest, indent=2))


def prune_old_items(items_data, max_age_days=30):
    """Remove items older than max_age_days. Returns pruned data."""
    now = datetime.now()
    kept = []
    pruned_count = 0

    for item in items_data.get('items', []):
        try:
            pub_date = datetime.strptime(item['published'], '%Y-%m-%d')
            age = (now - pub_date).days
            if age <= max_age_days:
                kept.append(item)
            else:
                pruned_count += 1
        except (ValueError, KeyError):
            kept.append(item)  # Keep items with unparseable dates

    items_data['items'] = kept

    # Also prune known_ids from state
    if pruned_count > 0:
        state = load_state()
        kept_ids = {item['id'] for item in kept}
        state['known_ids'] = [id_ for id_ in state.get('known_ids', []) if id_ in kept_ids]
        save_state(state)

    return items_data, pruned_count


