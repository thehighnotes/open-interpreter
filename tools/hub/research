    # Footer
    header_bar()
    generated = digest.get('generated', '?')
    print(f"{GRAY}  Generated: {generated} | Summary: {digest.get('summary', '?')}{RESET}")
    header_bar()


def render_status():
    """Render fetch status and source health."""
    print()
    header_bar()
    print(f"{BRIGHT_GREEN}  RESEARCH STATUS{RESET}")
    header_bar()
    print()

    state = load_state()
    items_data = load_items()

    # Last fetch times
    print(f"  {WHITE}FETCH STATE{RESET}")
    divider()
    print(f"  arxiv last fetch:  {state.get('arxiv_last_fetch', 'never')}")

    gh_fetches = state.get('github_last_fetch', {})
    for repo in GITHUB_REPOS:
        last = gh_fetches.get(repo, 'never')
        print(f"  GitHub {repo}:  {last}")
    print()

    # Item counts
    items = items_data.get('items', [])
    print(f"  {WHITE}CACHE{RESET}")
    divider()
    print(f"  Total items:  {len(items)}")
    print(f"  Known IDs:    {len(state.get('known_ids', []))}")

    # Count by source
    arxiv_count = sum(1 for i in items if i.get('source') == 'arxiv')
    github_count = sum(1 for i in items if i.get('source') == 'github')
    print(f"  arxiv:        {arxiv_count}")
    print(f"  GitHub:       {github_count}")

    # Age distribution
    now = datetime.now()
    fresh = 0
    aging = 0
    for item in items:
        try:
            pub_date = datetime.strptime(item['published'], '%Y-%m-%d')
            age = (now - pub_date).days
            if age <= 7:
                fresh += 1
            else:
                aging += 1
        except (ValueError, KeyError):
            pass
    print(f"  Fresh (≤7d):  {fresh}")
    print(f"  Aging (>7d):  {aging}")
    print()

    # Per-project tracked repos
    all_project_repos = _collect_all_github_repos()[1]
    if all_project_repos:
        print(f"  {WHITE}PROJECT-SPECIFIC REPOS{RESET}")
        divider()
        for pk in PROJECT_ORDER:
            proj = PROJECTS[pk]
            repos = proj.get('related_repos', [])
            if repos:
                print(f"  {pk:12s}  {', '.join(repos[:5])}{' +' + str(len(repos)-5) if len(repos) > 5 else ''}")
        print()

    # Per-project digest stats
    print(f"  {WHITE}DIGESTS{RESET}")
    divider()
    for pk in PROJECT_ORDER:
        digest_file = CACHE_DIR / f'{pk}.json'
        if digest_file.exists():
            try:
                digest = json.loads(digest_file.read_text())
                summary = digest.get('summary', '?')
                print(f"  {pk:12s}  {summary}")
            except (json.JSONDecodeError, OSError):
                print(f"  {pk:12s}  {RED}read error{RESET}")
        else:
            print(f"  {pk:12s}  {GRAY}no digest{RESET}")
    print()

    # Ollama host health
    ollama_host_name = HOSTS.get(OLLAMA_HOST, {}).get('name', OLLAMA_HOST)
    print(f"  {WHITE}{ollama_host_name} / OLLAMA{RESET}")
    divider()
    ollama_reachable = check_host_reachable(OLLAMA_HOST) if OLLAMA_HOST != LOCAL_HOST else True
    if ollama_reachable:
        if OLLAMA_HOST != LOCAL_HOST:
            print(f"  {GREEN}●{RESET} {ollama_host_name} is online")
        ok, output = ssh_cmd(OLLAMA_HOST, f'curl -s http://localhost:{OLLAMA_PORT}/api/ps 2>/dev/null', timeout=5)
        if ok and output:
            try:
                data = json.loads(output)
                models = data.get('models', [])
                if models:
                    names = [m.get('name', '?') for m in models]
                    print(f"  {GREEN}●{RESET} Ollama loaded: {', '.join(names)}")
                else:
                    print(f"  {GREEN}●{RESET} Ollama running (idle)")
            except json.JSONDecodeError:
                print(f"  {GREEN}●{RESET} Ollama running")
        else:
            print(f"  {RED}●{RESET} Ollama not responding")
    else:
        print(f"  {RED}●{RESET} {ollama_host_name} is offline")
    print()

    header_bar()


