#!/usr/bin/env python3
"""research — Continuous researcher for the Orin Nano hub.

Monitors arxiv papers and GitHub releases, scores relevance against each
project using Ollama on AGX informed by cached overview data, and surfaces
findings inside the existing overview ecosystem.

Usage:
    research                     All projects' research digests
    research <project>           Detailed view for one project
    research --fetch             Fetch + score (cron mode)
    research --calibrate         Score test items, show threshold matrix
    research --status            Fetch state, item counts, source health
    research --help
"""

import json
import sys
import time
from datetime import datetime, timezone
from pathlib import Path

